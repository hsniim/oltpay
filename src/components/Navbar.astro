      </div>
    </div>

    <hr class="dd-divider" />

    <div class="dd-footer-row">
      <div class="dd-footer-help">Butuh Bantuan?</div>
    </div>
  </div>
</div>

<!-- ══════════════ MOBILE MENU ══════════════ -->
<div id="mobile-menu">
  <a href="/" class="mob-link mob-close">Beranda</a>

  <!-- Produk & Layanan accordion -->
  <button class="mob-acc-btn" id="mob-acc-produk">
    Produk &amp; Layanan
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2.5"><polyline points="6 9 12 15 18 9"></polyline></svg
    >
  </button>
  <div class="mob-sub-panel" id="mob-panel-produk">
    <div style="padding: 0.5rem 0 1.25rem;">
      <div class="mob-sub-label">Isi Ulang</div>
      <a href="/products/topup/pulsa/" class="mob-sub-link mob-close"
        >Pulsa Reguler</a
      >
      <a href="/products/topup/data/" class="mob-sub-link mob-close"
        >Paket Data Internet</a
      >
      <a href="/" class="mob-sub-link mob-close">Topup E-Wallet</a>
      <a href="/?tab=game" class="mob-sub-link mob-close">Voucher Game Online</a
      >
      <a href="/products/topup/plntoken/" class="mob-sub-link mob-close"
        >Token PLN</a
      >
      <div class="mob-sub-label" style="margin-top:1.25rem">Tagihan</div>
      <a href="/tagihan/pln" class="mob-sub-link mob-close">PLN</a>
      <a href="/tagihan/pdam" class="mob-sub-link mob-close">PDAM</a>
      <a href="/tagihan/bpjs" class="mob-sub-link mob-close">BPJS Kesehatan</a>
      <a href="/tagihan/isp-wifi" class="mob-sub-link mob-close">ISP/Wi-Fi</a>
      <a href="/tagihan/tv-berbayar" class="mob-sub-link mob-close"
        >TV Berbayar</a
      >
      <div class="mob-sub-label" style="margin-top:1.25rem">Game</div>
      <a href="/products/game/ml/" class="mob-sub-link mob-close"
        >Mobile Legends</a
      >
      <a href="/products/game/ff" class="mob-sub-link mob-close">Free Fire</a>
      <a href="/products/game/pubgm" class="mob-sub-link mob-close"
        >PUBG Mobile</a
      >
      <a href="/products/game/garena" class="mob-sub-link mob-close">Garena</a>
    </div>
  </div>

  <!-- Harga accordion -->
  <button class="mob-acc-btn" id="mob-acc-harga">
    Cek Harga
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2.5"><polyline points="6 9 12 15 18 9"></polyline></svg
    >
  </button>
  <div class="mob-sub-panel" id="mob-panel-harga">
    <div style="padding: 0.5rem 0 1.25rem;">
      <div class="mob-sub-label">Cek Harga</div>
      <a href="/prices?tab=pulsa" class="mob-sub-link mob-close"
        >Pulsa Reguler</a
      >
      <a href="/prices?tab=data" class="mob-sub-link mob-close"
        >Paket Data Internet</a
      >
      <a href="/prices?tab=ewallet" class="mob-sub-link mob-close"
        >Topup E-Wallet</a
      >
      <a href="/prices?tab=token" class="mob-sub-link mob-close">Token PLN</a>
      <div class="mob-sub-label" style="margin-top:1.25rem">Lainnya</div>
      <a href="/prices" class="mob-sub-link mob-close"
        >Perpanjang Masa Aktif Kartu</a
      >
      <a href="/prices?tab=game" class="mob-sub-link mob-close"
        >Voucher Game Online</a
      >
    </div>
  </div>

  <a href="/contact" class="mob-kontak mob-close">Kontak</a>
</div>

<script>
  (function () {
    const navbar = document.getElementById("navbar");
    const overlay = document.getElementById("dd-overlay");
    const panel = document.getElementById("dd-panel");
    const ddGrid = document.getElementById("dd-grid");
    const btnProduk = document.getElementById("btn-produk");
    const btnHarga = document.getElementById("btn-harga");
    const mobMenu = document.getElementById("mobile-menu");
    const mobToggle = document.getElementById("mob-toggle");

    // ── Scroll ──
    window.addEventListener(
      "scroll",
      () => {
        navbar.classList.toggle("scrolled", window.scrollY > 10);
      },
      { passive: true },
    );

    // ── Desktop Dropdown ──
    const panelHarga = document.getElementById("dd-panel-harga");
    const ddGridHarga = document.getElementById("dd-grid-harga");

    let activeBtn = null;
    let panelOpen = false;

    function getPanel(btn) {
      return btn === btnHarga ? panelHarga : panel;
    }
    function getGrid(btn) {
      return btn === btnHarga ? ddGridHarga : ddGrid;
    }

    function openPanel(btn) {
      if (activeBtn && activeBtn !== btn) {
        // Close the other panel immediately
        const otherPanel = getPanel(activeBtn);
        const otherGrid = getGrid(activeBtn);
        otherPanel.classList.remove("visible");
        otherPanel.style.display = "none";
        otherGrid
          .querySelectorAll(".dd-col")
          .forEach((c) => c.classList.remove("show"));
        activeBtn.classList.remove("active");
        activeBtn.setAttribute("aria-expanded", "false");
      }

      activeBtn = btn;
      btn.classList.add("active");
      btn.setAttribute("aria-expanded", "true");

      const activePanel = getPanel(btn);
      const activeGrid = getGrid(btn);

      activeGrid
        .querySelectorAll(".dd-col")
        .forEach((c) => c.classList.remove("show"));

      overlay.style.display = "block";
      activePanel.style.display = "block";
      panelOpen = true;

      requestAnimationFrame(() =>
        requestAnimationFrame(() => {
          activePanel.classList.add("visible");
          activeGrid
            .querySelectorAll(".dd-col")
            .forEach((c) => c.classList.add("show"));
        }),
      );
    }

    function closePanel() {
      if (activeBtn) {
        const activePanel = getPanel(activeBtn);
        const activeGrid = getGrid(activeBtn);
        activePanel.classList.remove("visible");
        activeBtn.classList.remove("active");
        activeBtn.setAttribute("aria-expanded", "false");
        activeBtn = null;

        panelOpen = false;
        setTimeout(() => {
          if (!panelOpen) {
            activePanel.style.display = "none";
            overlay.style.display = "none";
            activeGrid
              .querySelectorAll(".dd-col")
              .forEach((c) => c.classList.remove("show"));
          }
        }, 230);
      } else {
        panelOpen = false;
        panel.style.display = "none";
        panelHarga.style.display = "none";
        overlay.style.display = "none";
      }
    }

    function togglePanel(btn) {
      if (panelOpen && activeBtn === btn) {
        closePanel();
      } else {
        openPanel(btn);
      }
    }

    // ── Hover & Click trigger ──
    let closeTimer = null;

    function scheduleClose() {
      closeTimer = setTimeout(() => {
        closePanel();
      }, 120); // small delay so mouse can travel to panel
    }

    function cancelClose() {
      if (closeTimer) {
        clearTimeout(closeTimer);
        closeTimer = null;
      }
    }

    // Hover on buttons
    btnProduk.addEventListener("mouseenter", () => {
      cancelClose();
      openPanel(btnProduk);
    });
    btnHarga.addEventListener("mouseenter", () => {
      cancelClose();
      openPanel(btnHarga);
    });

    btnProduk.addEventListener("mouseleave", scheduleClose);
    btnHarga.addEventListener("mouseleave", scheduleClose);

    // Hover on panels — keep open while inside
    panel.addEventListener("mouseenter", cancelClose);
    panel.addEventListener("mouseleave", scheduleClose);
    panelHarga.addEventListener("mouseenter", cancelClose);
    panelHarga.addEventListener("mouseleave", scheduleClose);

    // Click still works as toggle (for touch / keyboard users)
    btnProduk.addEventListener("click", (e) => {
      e.stopPropagation();
      togglePanel(btnProduk);
    });
    btnHarga.addEventListener("click", (e) => {
      e.stopPropagation();
      togglePanel(btnHarga);
    });

    overlay.addEventListener("click", closePanel);

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && panelOpen) closePanel();
    });

    // Close if click outside
    document.addEventListener("click", (e) => {
      if (
        panelOpen &&
        !panel.contains(e.target) &&
        !panelHarga.contains(e.target) &&
        !btnProduk.contains(e.target) &&
        !btnHarga.contains(e.target)
      ) {
        closePanel();
      }
    });

    // ── Mobile Menu ──
    mobToggle.addEventListener("click", () => {
      const isOpen = mobMenu.classList.toggle("open");
      mobToggle.classList.toggle("open", isOpen);
      document.body.style.overflow = isOpen ? "hidden" : "";
    });

    document.querySelectorAll(".mob-close").forEach((el) => {
      el.addEventListener("click", () => {
        mobMenu.classList.remove("open");
        mobToggle.classList.remove("open");
        document.body.style.overflow = "";
      });
    });

    // Mobile Accordion
    function setupAccordion(btnId, panelId) {
      const btn = document.getElementById(btnId);
      const pnl = document.getElementById(panelId);
      let open = false;

      btn.addEventListener("click", () => {
        open = !open;
        btn.classList.toggle("open", open);
        pnl.style.height = open ? pnl.scrollHeight + "px" : "0";
      });
    }

    setupAccordion("mob-acc-produk", "mob-panel-produk");
    setupAccordion("mob-acc-harga", "mob-panel-harga");
  })();
</script>