---
// Navbar.astro — Oltpay
// ✅ Pure inline CSS + vanilla JS, no dependencies
---

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap");

  :root {
    --navbar-height: 80px;
    --font-display: "Plus Jakarta Sans", sans-serif;
    --font-body: "Plus Jakarta Sans", sans-serif;
    --color-bg: #ffffff;
    --color-text: #0a0a0a;
    --color-muted: #6b6b6b;
    --color-border: #e8e8e8;
    --color-hover-bg: #f5f5f5;
    --color-dropdown-bg: #ffffff;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* ── NAVBAR ── */
  #navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--color-bg);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s ease;
    font-family: var(--font-display);
  }
  #navbar.scrolled {
    border-bottom-color: var(--color-border);
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .nav-inner {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 2.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--navbar-height);
  }

  @media (max-width: 1023px) {
    :root {
      --navbar-height: 56px;
    }
  }

  @media (max-width: 640px) {
    .nav-inner {
      padding: 0 20px;
    }
  }

  /* ── LOGO ── */
  .nav-logo {
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0rem;
    flex-shrink: 0;
  }

  .nav-logo img {
    width: 50px;
    height: auto;
    object-fit: contain;
  }

  .nav-logo-text {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  /* ── DESKTOP LINKS ── */
  .nav-links {
    display: none;
    align-items: center;
    gap: 0;
  }
  @media (min-width: 1024px) {
    .nav-links {
      display: flex;
    }
  }

  .nav-link {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    padding: 0.5rem 1.5rem;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    white-space: nowrap;
    letter-spacing: 0em;
  }
  .nav-link.active svg {
    transform: rotate(180deg);
  }

  .nav-link svg {
    width: 0.9rem;
    height: 0.9rem;
    flex-shrink: 0;
    transition: transform 0.25s ease;
  }

  /* ── RIGHT: KONTAK ── */
  .nav-right {
    display: none;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .nav-right {
      display: flex;
    }
  }

  .nav-kontak {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    padding: 0.5rem 1.5rem;
    letter-spacing: -0.01em;
    transition: opacity 0.15s;
  }
  .nav-kontak:hover {
    opacity: 0.55;
  }

  /* ── HAMBURGER ── */
  .nav-mobile-btn {
    display: flex;
    z-index: 110;
  }
  @media (min-width: 1024px) {
    .nav-mobile-btn {
      display: none;
    }
  }

  .hamburger {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    color: var(--color-text);
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .hamburger span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--color-text);
    transition: all 0.25s ease;
    transform-origin: center;
  }
  .hamburger.open span:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .hamburger.open span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .hamburger.open span:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* ══════════════════════════════════════
     MEGA DROPDOWN
  ══════════════════════════════════════ */
  #dd-overlay {
    position: fixed;
    inset: 0;
    z-index: 90;
    display: none;
  }

  #dd-panel {
    position: fixed;
    top: var(--navbar-height);
    left: 0;
    right: 0;
    z-index: 95;
    background: var(--color-dropdown-bg);
    border-bottom: 1px solid var(--color-border);
    display: none;
    opacity: 0;
    transform: translateY(-6px);
    transition:
      opacity 0.22s ease,
      transform 0.22s ease;
  }
  #dd-panel.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .dd-inner {
    max-width: 1300px;
    margin: 0 auto;
    padding: 2.5rem 2.5rem 2rem;
  }

  .dd-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0 3rem;
  }

  .dd-col-label {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-muted);
    letter-spacing: 0.02em;
    margin-bottom: 1rem;
    padding-bottom: 0;
  }

  .dd-col-items {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .dd-item {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    display: block;
    padding: 0.35rem 0;
    letter-spacing: -0.01em;
    line-height: 1.2;
    position: relative;
    transition: color 0.15s;
  }
  /* Dim-others effect: ketika grid di-hover, semua item jadi abu-abu */
  .dd-grid:hover .dd-item,
  .dd-grid-2:hover .dd-item {
    color: #b0b0b0;
    transition: color 0.15s;
  }
  /* Item yang sedang di-hover balik ke hitam */
  .dd-grid .dd-item:hover,
  .dd-grid-2 .dd-item:hover {
    color: var(--color-text);
  }

  .dd-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 1.75rem 0 1.25rem;
  }

  .dd-footer-row {
    display: flex;
    align-items: center;
  }
  .dd-footer-help {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-muted);
  }
  .dd-footer-help a {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 2px;
    margin-left: 0.3rem;
  }
  .dd-footer-help a:hover {
    opacity: 0.5;
  }

  .dd-grid-2 {
    grid-template-columns: repeat(2, 1fr);
  }

  #dd-panel-harga {
    position: fixed;
    top: var(--navbar-height);
    left: 0;
    right: 0;
    z-index: 95;
    background: var(--color-dropdown-bg);
    border-bottom: 1px solid var(--color-border);
    display: none;
    opacity: 0;
    transform: translateY(-6px);
    transition:
      opacity 0.22s ease,
      transform 0.22s ease;
  }
  #dd-panel-harga.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .dd-col {
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.25s ease,
      transform 0.25s ease;
  }
  .dd-col.show {
    opacity: 1;
    transform: translateY(0);
  }
  .dd-col:nth-child(1) {
    transition-delay: 0ms;
  }
  .dd-col:nth-child(2) {
    transition-delay: 50ms;
  }
  .dd-col:nth-child(3) {
    transition-delay: 100ms;
  }

  /* ══════════════════════════════════════
     MOBILE MENU
  ══════════════════════════════════════ */
  #mobile-menu {
    position: fixed;
    inset: 0;
    top: var(--navbar-height);
    background: white;
    z-index: 99;
    overflow-y: auto;
    transform: translateX(100%);
    transition: transform 0.3s ease;
    padding: 2rem 2rem 3rem;
    font-family: var(--font-display);
  }
  #mobile-menu.open {
    transform: translateX(0);
  }

  .mob-link {
    display: block;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--color-border);
    letter-spacing: -0.03em;
  }

  .mob-acc-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text);
    background: none;
    border: none;
    border-bottom: 1px solid var(--color-border);
    padding: 0.85rem 0;
    cursor: pointer;
    font-family: var(--font-display);
    letter-spacing: -0.03em;
    text-align: left;
  }
  .mob-acc-btn svg {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    transition: transform 0.2s;
  }
  .mob-acc-btn.open svg {
    transform: rotate(180deg);
  }

  .mob-sub-panel {
    height: 0;
    overflow: hidden;
    transition: height 0.25s ease;
  }

  .mob-sub-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-muted);
    margin: 1rem 0 0.5rem;
    letter-spacing: 0.03em;
  }

  .mob-sub-link {
    display: block;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    padding: 0.4rem 0;
    letter-spacing: -0.02em;
  }
  .mob-sub-link:hover {
    opacity: 0.5;
  }

  .mob-kontak {
    display: block;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--color-border);
    letter-spacing: -0.03em;
  }
</style>

<!-- ══════════════ NAVBAR ══════════════ -->
<nav id="navbar">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <img src="/logos/oltpay_logoblack.svg" alt="Oltpay Logo" />
      <span class="nav-logo-text">Oltpay</span>
    </a>

    <!-- Desktop Nav (semua link di kanan) -->
    <div class="nav-links">
      <a href="/" class="nav-link">Beranda</a>

      <button class="nav-link" id="btn-produk" aria-expanded="false">
        Produk &amp; Layanan
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>

      <button class="nav-link" id="btn-harga" aria-expanded="false">
        Cek Harga
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <polyline points="6 9 12 15 18 9"></polyline>
