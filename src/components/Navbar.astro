      </div>

      <!-- Col 2: Lainnya -->
      <div class="dd-col">
        <div class="dd-col-label">Lainnya</div>
        <div class="dd-col-items">
          <a href="/prices" class="dd-item">Perpanjang Masa Aktif Kartu</a>
          <a href="/prices?tab=game" class="dd-item">Voucher Game Online</a>
