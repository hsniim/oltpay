      <a href="/contact" class="nav-link">Kontak</a>
    </div>

    <!-- Mobile Toggle -->
    <div class="nav-mobile-btn">
      <button id="mob-toggle" class="hamburger" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</nav>

<!-- ══════════════ MEGA DROPDOWN ══════════════ -->
<div id="dd-overlay"></div>
