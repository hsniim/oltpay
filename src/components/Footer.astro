---
// src/components/Footer.astro
const year = new Date().getFullYear();

const produkTagihan = [
  { label: "Listrik PLN Pasca", href: "/products/bill/plnpasca/" },
  { label: "PDAM", href: "/products/bill/pdam/" },
  { label: "BPJS Kesehatan", href: "/products/bill/bpjs/" },
  { label: "Internet / ISP", href: "/products/bill/isp/" },
  { label: "TV Berbayar", href: "/products/bill/tv/" },
  { label: "Asuransi", href: "/products/bill/insurance/" },
  { label: "Pulsa Pascabayar", href: "/products/bill/pulsapasca/" },
];

const produkIsi = [
  { label: "Pulsa", href: "/products/topup/pulsa" },
  { label: "Paket Data", href: "/products/topup/data" },
];

const produkGame = [
  { label: "Mobile Legends", href: "/products/game/ml/" },
  { label: "Free Fire", href: "/products/game/ff/" },
  { label: "PUBG Mobile", href: "/products/game/pubgm/" },
  { label: "Garena Shell", href: "/products/game/garena/" },
];

const links = [
  { label: "Beranda", href: "/" },
  { label: "Kontak", href: "/kontak/" },
];
---

<footer class="footer">
  <div class="footer__inner">
    <!-- ══ TOP ROW ══ -->
    <div class="footer__top">
      <!-- Brand -->
      <div class="footer__brand">
        <a href="/" class="footer__logo" aria-label="Oltpay">
          <!-- Logo mark — dari /logos/oltpay_logoblack.svg -->
          <img
            src="/logos/oltpay_logoblack.svg"
            width="32"
            height="32"
            alt=""
            aria-hidden="true"
            style="flex-shrink:0;display:block"
          />
          <span>Oltpay</span>
        </a>
        <p class="footer__tagline">
          Platform PPOB terpercaya untuk bayar tagihan listrik, air, BPJS,
          internet, dan isi pulsa&nbsp;&amp;&nbsp;data dengan harga terbaik.
        </p>

        <!-- Sosial -->
        <div class="footer__social">
          <a
            href="https://wa.me/6289501450667"
            target="_blank"
            rel="noopener noreferrer"
            class="footer__social-btn"
            aria-label="WhatsApp Oltpay"
          >
            <!-- WhatsApp -->
            <svg
              viewBox="0 0 24 24"
              fill="currentColor"
              width="17"
              height="17"
              aria-hidden="true"
            >
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
              ></path>
              <path
                d="M11.99 0C5.374 0 0 5.373 0 11.988c0 2.114.549 4.099 1.504 5.83L0 24l6.335-1.652A11.939 11.939 0 0 0 11.99 24C18.626 24 24 18.626 24 12.012 24 5.373 18.626 0 11.99 0zm0 21.785a9.796 9.796 0 0 1-4.994-1.365l-.357-.212-3.758.98.999-3.647-.233-.374A9.722 9.722 0 0 1 2.203 12c0-5.398 4.394-9.791 9.787-9.791 5.394 0 9.788 4.393 9.788 9.791 0 5.398-4.394 9.785-9.788 9.785z"
              ></path>
            </svg>
            WhatsApp
          </a>
          <a
            href="https://t.me/oltpaychatt"
            target="_blank"
            rel="noopener noreferrer"
            class="footer__social-btn"
            aria-label="Telegram Oltpay"
          >
            <!-- Telegram -->
            <svg
              viewBox="0 0 24 24"
              fill="currentColor"
              width="17"
              height="17"
              aria-hidden="true"
            >
              <path
                d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12L8.32 13.617l-2.96-.924c-.643-.204-.657-.643.136-.953l11.57-4.461c.537-.194 1.006.131.828.942z"
              ></path>
            </svg>
            Telegram
          </a>
        </div>
      </div>

      <!-- Nav kolom -->
      <nav class="footer__nav" aria-label="Footer navigasi">
        <div class="footer__col">
          <p class="footer__col-title">Tagihan</p>
          <ul>
            {
              produkTagihan.map((item) => (
                <li>
                  <a href={item.href}>{item.label}</a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="footer__col">
          <p class="footer__col-title">Isi Ulang</p>
          <ul>
            {
              produkIsi.map((item) => (
                <li>
                  <a href={item.href}>{item.label}</a>
                </li>
              ))
            }
          </ul>

          <p class="footer__col-title" style="margin-top:24px">Game</p>
          <ul>
            {
              produkGame.map((item) => (
                <li>
                  <a href={item.href}>{item.label}</a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="footer__col">
          <p class="footer__col-title">Perusahaan</p>
          <ul>
            {
              links.map((item) => (
                <li>
                  <a href={item.href}>{item.label}</a>
                </li>
              ))
            }
          </ul>
        </div>
      </nav>
    </div>

    <!-- ══ BOTTOM ROW ══ -->
    <div class="footer__bottom">
      <p class="footer__copy">
        &copy; {year} Oltpay. Semua hak dilindungi.
      </p>
      <p class="footer__disclaimer">
        Oltpay adalah reseller resmi produk PPOB — bukan afiliasi langsung PLN,
        BPJS, atau operator telekomunikasi.
      </p>
    </div>
  </div>
</footer>

<style>
  /* ── Variables (sama dengan pages lain) ── */
  .footer {
    --color-bg: #ffffff;
    --color-text: #0a0a0a;
    --color-muted: #6b6b6b;
    --color-border: #e8e8e8;
    --content-max: 1300px;
    --content-px: 2.5rem;

    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    margin-top: 0;
  }

  .footer__inner {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 56px var(--content-px) 32px;
  }

  /* ── Top row ── */
  .footer__top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px 64px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--color-border);
  }

  /* ── Brand ── */
  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 360px;
  }

  .footer__logo {
    display: inline-flex;
    align-items: center;
    gap: 1px;
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.4px;
    text-decoration: none;
  }

  .footer__tagline {
    font-size: 13px;
    color: var(--color-muted);
    line-height: 1.7;
  }

  /* ── Social buttons ── */
  .footer__social {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .footer__social-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 16px;
    border-radius: 99px;
    border: 1.5px solid var(--color-border);
    font-size: 12.5px;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    transition:
      border-color 0.2s,
      background 0.2s;
    white-space: nowrap;
  }

  .footer__social-btn:hover {
    border-color: var(--color-text);
    background: #f5f5f5;
  }

  /* ── Nav grid ── */
  .footer__nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .footer__col-title {
    font-size: 12px;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .footer__col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer__col ul a {
    font-size: 13px;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer__col ul a:hover {
    color: var(--color-text);
  }

  /* ── Bottom row ── */
  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-top: 28px;
    flex-wrap: wrap;
  }

  .footer__copy {
    font-size: 12.5px;
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
  }

  .footer__disclaimer {
    font-size: 11.5px;
    color: var(--color-muted);
    text-align: right;
    max-width: 480px;
    line-height: 1.6;
  }

  /* ════════════════════════════════
     RESPONSIVE
  ════════════════════════════════ */

  /* Tablet — 1024px */
  @media (max-width: 1024px) {
    .footer__inner {
      padding: 48px 2rem 28px;
    }
    .footer__top {
      gap: 40px;
    }
  }

  /* Tablet kecil — 768px: brand full-width di atas, nav tetap 3 kolom */
  @media (max-width: 768px) {
    .footer__inner {
      padding: 44px 1.5rem 24px;
    }
    .footer__top {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    .footer__brand {
      max-width: 100%;
    }
    .footer__nav {
      grid-template-columns: repeat(3, 1fr);
      gap: 24px 16px;
    }
    .footer__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
    .footer__disclaimer {
      text-align: left;
      max-width: 100%;
    }
  }

  /* Mobile — 520px: 2 kolom simetris, kiri Tagihan | kanan Isi+Game+Perusahaan */
  @media (max-width: 520px) {
    .footer__inner {
      padding: 36px 1.25rem 24px;
    }

    .footer__tagline {
      font-size: 12.5px;
    }
    .footer__social {
      gap: 8px;
    }
    .footer__social-btn {
      font-size: 12px;
      padding: 7px 14px;
    }

    /* Nav: 2 kolom, 3 baris — kolom 1 hanya Tagihan */
    .footer__nav {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
      gap: 0;
      align-items: start;
    }

    /* Kolom 1 — Tagihan: bentang 2 baris, ada garis pemisah kanan */
    .footer__col:nth-child(1) {
      grid-column: 1;
      grid-row: 1 / 3;
      padding-right: 20px;
      border-right: 1px solid var(--color-border);
    }

    /* Kolom 2 — Isi Ulang + Game: baris 1 kanan */
    .footer__col:nth-child(2) {
      grid-column: 2;
      grid-row: 1;
      padding-left: 20px;
    }

    /* margin-top "Game" lebih kompak di mobile */
    .footer__col:nth-child(2) .footer__col-title:nth-of-type(2) {
      margin-top: 20px !important;
    }

    /* Kolom 3 — Perusahaan: baris 2 kanan */
    .footer__col:nth-child(3) {
      grid-column: 2;
      grid-row: 2;
      padding-left: 20px;
      padding-top: 24px;
    }

    .footer__copy {
      font-size: 12px;
    }
    .footer__disclaimer {
      font-size: 11px;
    }
  }
</style>