                        d="M17 6H7a5 5 0 0 0-5 5v2a5 5 0 0 0 5 5h10a5 5 0 0 0 5-5v-2a5 5 0 0 0-5-5z"
                      ></path></svg
                    >
                  </div><span class="service-label">Garena</span>
                </div>
              </div>
            </div>
          </div><!-- end tab-panels-wrap -->
        </section>
      </main>
    </div>

    <script>
      // ══ TAB SWITCHING — no height jump ══
      (function () {
        const tabBtns = document.querySelectorAll(".tab-btn");
        const tabPanels = document.querySelectorAll(".tab-panel");
        const wrap = document.querySelector(".tab-panels-wrap");

        // Find the tallest panel across all tabs and lock height to it
        function lockToTallest() {
          // Temporarily show all panels to measure
          tabPanels.forEach((p) => {
            p.style.display = "block";
            p.style.visibility = "hidden";
          });
          let maxH = 0;
          tabPanels.forEach((p) => {
            if (p.offsetHeight > maxH) maxH = p.offsetHeight;
          });
          // Restore
          tabPanels.forEach((p) => {
            p.style.display = "";
            p.style.visibility = "";
          });
          wrap.style.minHeight = maxH + "px";
        }

        window.addEventListener("load", lockToTallest);
        window.addEventListener("resize", lockToTallest);

        tabBtns.forEach((btn) => {
          btn.addEventListener("click", () => {
            tabBtns.forEach((b) => b.classList.remove("active"));
            tabPanels.forEach((p) => p.classList.remove("active"));
            btn.classList.add("active");
            document
              .getElementById("tab-" + btn.dataset.tab)
              .classList.add("active");
          });
        });
      })();
    </script>
  </body>
</html>
