---
import Navbar from "../components/Navbar.astro";
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Oltpay – Bayar Semua Tagihan Jadi Lebih Mudah & Cepat</title>

    <style>
      :root {
        --navbar-height: 80px;
        --font-display: "Plus Jakarta Sans", sans-serif;
        --color-bg: #ffffff;
        --color-text: #0a0a0a;
        --color-muted: #6b6b6b;
        --color-border: #e8e8e8;
        --page-bg: #f2f2ed;
        --content-max: 1300px;
        --content-px: 2.5rem;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: var(--font-display);
        background: var(--page-bg);
        color: var(--color-text);
        min-height: 100vh;
      }

      /* ══ PAGE LAYOUT ══ */
      .page-wrapper {
        padding-top: var(--navbar-height);
      }
      main {
        max-width: var(--content-max);
        margin: 0 auto;
        padding: 32px var(--content-px) 80px;
      }

      /* ══ HERO BANNER ══ */
      .hero {
        border-radius: 20px;
        overflow: hidden;
        background: linear-gradient(
          135deg,
          #9b1fd4 0%,
          #e91e8c 55%,
          #ff4db8 100%
        );
        line-height: 0;
      }
      /*
      CARA MENGGANTI BANNER:
      Hapus <div class="hero-banner-ph"> dan ganti dengan:
      <img class="hero-banner-img" src="/images/banner.png" alt="Banner Oltpay" />
    */
      .hero-banner-ph {
        width: 100%;
        display: block;
        line-height: 0;
      }
      .hero-banner-img {
        width: 100%;
        height: auto;
        display: block;
      }
      .hero-banner-ph img {
        width: 100%;
        height: auto;
        display: block;
        object-fit: contain;
      }

      /* ══ SERVICE SECTION ══ */
      .services-section {
        margin-top: 20px;
        background: #fff;
        border-radius: 20px;
        overflow: hidden;
      }

      .tab-bar {
        display: flex;
        border-bottom: 1px solid var(--color-border);
        padding: 0 28px;
      }
      .tab-btn {
        background: none;
        border: none;
        cursor: pointer;
        font-family: var(--font-display);
        font-size: 15px;
        font-weight: 600;
        color: var(--color-muted);
        padding: 20px 20px 16px;
        position: relative;
        transition: color 0.2s;
      }
      .tab-btn.active {
        color: var(--color-text);
      }
      .tab-btn.active::after {
        content: "";
        position: absolute;
        bottom: -1px;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--color-text);
        border-radius: 2px 2px 0 0;
      }
      .tab-btn:hover:not(.active) {
        color: var(--color-text);
      }

      /* Fixed-height wrapper — prevents page height jump on tab switch */
      .tab-panels-wrap {
        padding: 28px 28px 32px;
      }

      .tab-panel {
        display: none;
      }
      .tab-panel.active {
        display: block;
      }

      .services-grid {
        display: grid;
        grid-template-columns: repeat(10, 1fr);
        gap: 4px;
      }
      @media (max-width: 900px) {
        .services-grid {
          grid-template-columns: repeat(5, 1fr);
        }
      }
      @media (max-width: 540px) {
        .services-grid {
          grid-template-columns: repeat(4, 1fr);
        }
      }

      .service-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        padding: 16px 8px;
        border-radius: 14px;
        cursor: pointer;
        transition:
          background 0.15s,
          transform 0.15s;
        text-align: center;
      }
      .service-item:hover {
        background: var(--page-bg);
        transform: translateY(-2px);
      }
      .service-icon {
        width: 52px;
        height: 52px;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .service-icon img {
        width: 100%;
        height: 100%;
        object-fit: contain;
      }
      .service-icon svg {
        width: 30px;
        height: 30px;
        color: var(--color-text);
      }
      .service-label {
        font-size: 12px;
        font-weight: 600;
        color: var(--color-text);
        line-height: 1.3;
      }
    </style>
