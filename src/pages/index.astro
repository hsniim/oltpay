---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <div class="min-h-screen flex items-center justify-center bg-gray-50">
    <div class="text-center p-8">
      <h1 class="text-5xl font-bold text-primary mb-4">
        Selamat datang di HumiPay
      </h1>

      <p class="text-xl text-slate-600 mb-8">
        PPOB terpercaya – Pulsa, Token PLN, PDAM, BPJS & banyak lagi
      </p>

      <div
        class="inline-block bg-accent text-white px-8 py-4 rounded-xl text-lg font-semibold hover:bg-emerald-600 transition"
      >
        Mulai Pesan via WhatsApp
      </div>
    </div>
  </div>
</BaseLayout>
