---
// src/pages/products/bill/[brand]/index.astro
//
// Static pages untuk tagihan pascabayar:
//   /products/bill/plnpasca    → Listrik PLN Pascabayar
//   /products/bill/pdam        → PDAM
//   /products/bill/bpjs        → BPJS Kesehatan
//   /products/bill/isp         → Internet/ISP
//   /products/bill/tv          → TV Berbayar
//   /products/bill/insurance   → Asuransi
//   /products/bill/pulsapasca  → Pulsa Pascabayar

import Navbar from "../../../../components/Navbar.astro";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { tagihanProducts } from "../../../../data/products.js";

export function getStaticPaths() {
  return tagihanProducts.map((item) => ({
    params: { brand: item.name },
    props: item,
  }));
}

const {
  name,
  title,
  icon, // SVG path string — sama persis dengan homepage tab Tagihan
  inputLabel,
  inputType,
  inputMode, // 'numeric' | null — override inputmode attribute
  inputPrefix, // '+62' | null
  inputPlaceholder: rawInputPlaceholder,
  inputMinLength,
  inputMaxLength,
  validationPattern, // RegExp string untuk validasi nomor pelanggan/ID
  inputHint,
  inputHintTyping, // Pesan saat user masih mengetik
  inputHintInvalid, // Pesan saat format salah
  skuCode,
} = Astro.props;

const waNumber = "6289501450667";
const tgUsername = "oltpaychat"; // username Telegram CS (tanpa @)

// Warna aksen per brand — konsisten dengan accentMap di topup
const accentMap: Record<string, string> = {
  plnpasca: "#00A0E3",
  pdam: "#2B6CB0",
  bpjs: "#00A651",
  isp: "#553C9A",
  tv: "#D97706",
  insurance: "#276749",
  pulsapasca: "#E53E3E",
};

const accent = accentMap[name] ?? "#0a0a0a";

// Apakah input pakai format +62 (nomor HP)?
const isPhoneInput = inputPrefix === "+62";

// Input numerik: ditentukan oleh inputMode dari data produk, atau fallback nama brand
const isNumericInput =
  inputMode === "numeric" || ["plnpasca", "bpjs"].includes(name);

// Placeholder — gunakan dari data produk jika tersedia, fallback ke generik
const inputPlaceholder =
  rawInputPlaceholder ??
  (isPhoneInput ? "8xx xxxx xxxx" : `Masukkan ${inputLabel.toLowerCase()}`);

const configData = JSON.stringify({
  wa: waNumber,
  tg: tgUsername,
  name,
  title,
  inputLabel,
  isPhoneInput,
  isNumericInput,
  inputMinLength,
  inputMaxLength,
  validationPattern: validationPattern ?? null,
  inputHint: inputHint ?? null,
  inputHintTyping: inputHintTyping ?? null,
  inputHintInvalid: inputHintInvalid ?? null,
  accent,
  skuCode,
});
---

<BaseLayout>
  <Navbar />

  <!-- ══ SVG SYMBOLS — identik dengan topup ══ -->
  <svg
    aria-hidden="true"
    style="display:none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <symbol
      id="icon-phone"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect>
      <line x1="12" y1="18" x2="12.01" y2="18"></line>
    </symbol>
    <symbol
      id="icon-close"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </symbol>
    <symbol
      id="icon-clock"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="12" cy="12" r="10"></circle>
      <path d="M12 6v6l4 2"></path>
    </symbol>
    <symbol
      id="icon-search"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </symbol>
    <symbol id="icon-wa" viewBox="0 0 24 24" fill="currentColor">
      <path
        d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
      ></path>
      <path
        d="M11.99 0C5.374 0 0 5.373 0 11.988c0 2.114.549 4.099 1.504 5.83L0 24l6.335-1.652A11.939 11.939 0 0 0 11.99 24C18.626 24 24 18.626 24 12.012 24 5.373 18.626 0 11.99 0zm0 21.785a9.796 9.796 0 0 1-4.994-1.365l-.357-.212-3.758.98.999-3.647-.233-.374A9.722 9.722 0 0 1 2.203 12c0-5.398 4.394-9.791 9.787-9.791 5.394 0 9.788 4.393 9.788 9.791 0 5.398-4.394 9.785-9.788 9.785z"
      ></path>
    </symbol>
    <symbol id="icon-tg" viewBox="0 0 24 24" fill="currentColor">
      <path
        d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12L8.32 13.617l-2.96-.924c-.643-.204-.657-.643.136-.953l11.57-4.461c.537-.194 1.006.131.828.942z"
      ></path>
    </symbol>
  </svg>

  <div class="page-wrapper">
    <main>
      <!-- ══ INPUT SECTION — identik dengan topup ══ -->
      <section class="input-section">
        <div class="page-title-row">
          <div class="page-title-icon">
            <!-- Icon sama persis dengan yang tampil di homepage tab Tagihan -->
            <svg
              viewBox="0 0 24 24"
              width="24"
              height="24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              set:html={icon}
            />
          </div>
          <div>
            <h1 class="page-title">Bayar {title}</h1>
            <p class="page-subtitle">
              Cek &amp; bayar tagihan {title}, instan proses cepat
            </p>
          </div>
        </div>

        <div class="input-card">
          <label class="input-label" for="user-input">{inputLabel}</label>
          <div class="input-row">
            <div class="input-wrap" id="input-wrap">
              {inputPrefix && <span class="input-prefix">{inputPrefix}</span>}
              <input
                type={inputType}
                id="user-input"
                placeholder={inputPlaceholder}
                autocomplete={isPhoneInput ? "tel" : "off"}
                inputmode={inputMode ?? (isPhoneInput ? "numeric" : undefined)}
                maxlength={inputMaxLength}
              />
            </div>
            <button class="btn-cek" id="btn-cek" disabled>
              <svg
                viewBox="0 0 24 24"
                width="15"
                height="15"
                aria-hidden="true"
              >
                <use href="#icon-search"></use>
              </svg>
              Cek Tagihan
            </button>
          </div>
          <p class="input-hint" id="input-hint">
            {
              isPhoneInput
                ? `Masukkan nomor HP ${title} Anda`
                : `Masukkan ${inputLabel.toLowerCase()} Anda`
            }
          </p>
        </div>
      </section>

      <!-- ══ RESULT SECTION — pola sama dengan products-section topup ══ -->
      <section class="products-section" id="result-section">
        <!-- Empty state -->
        <div class="state-wrap" id="empty-state">
          <div class="state-icon">
            <svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true">
              <use href="#icon-phone"></use>
            </svg>
          </div>
          <p class="state-title">
            {isPhoneInput ? "Masukkan nomor HP" : `Masukkan ${inputLabel}`}
          </p>
          <p class="state-desc">
            Informasi tagihan akan muncul setelah {
              isPhoneInput ? "nomor diisi" : "data diisi"
            } dan dicek
          </p>
        </div>

        <!-- CS Card — muncul setelah input valid & klik Cek Tagihan -->
        <div class="hidden" id="cs-card">
          <div class="cs-card__inner">
            <!-- Header -->
            <div class="cs-card__header">
              <div class="cs-card__header-text">
                <p class="cs-card__title">Konfirmasi via CS</p>
                <p class="cs-card__desc">
                  Kirim permintaan cek tagihan ke CS kami
                </p>
              </div>
            </div>

            <!-- Tab bar -->
            <div class="cs-tab-bar">
              <div class="cs-tab-bar__inner">
                <button
                  class="cs-tab-btn cs-tab-btn--active"
                  id="tab-wa"
                  data-channel="wa"
                >
                  WhatsApp
                </button>
                <button class="cs-tab-btn" id="tab-tg" data-channel="tg">
                  Telegram
                </button>
              </div>
            </div>

            <!-- Info pelanggan -->
            <div class="cs-card__info" id="cs-card-info"></div>

            <!-- Preview pesan -->
            <div class="cs-wa-preview" id="cs-wa-preview">
              <div class="cs-wa-preview__header" id="cs-preview-header">
                <svg
                  viewBox="0 0 24 24"
                  fill="#25d366"
                  width="13"
                  height="13"
                  aria-hidden="true"
                  id="cs-preview-icon"
                >
                  <use href="#icon-wa"></use>
                </svg>
                <span>Pesan yang akan dikirim</span>
              </div>
              <div class="cs-wa-preview__bubble" id="cs-wa-preview-text">—</div>
            </div>

            <!-- Tombol -->
            <button class="cs-card__btn cs-card__btn--wa" id="btn-cs-channel">
              <svg
                viewBox="0 0 24 24"
                fill="currentColor"
                width="17"
                height="17"
                aria-hidden="true"
                id="cs-btn-icon"
              >
                <use href="#icon-wa"></use>
              </svg>
              <span id="cs-btn-label">Chat CS via WhatsApp</span>
            </button>
          </div>
        </div>
      </section>
    </main>
  </div>

  <script id="config" type="application/json" set:html={configData} />

  <!-- ══ FLOATING WA BUTTON — identik dengan topup ══ -->
  <div class="wa-fab-wrap" id="wa-fab-wrap">
    <a
      href={`https://wa.me/${waNumber}`}
      target="_blank"
      rel="noopener noreferrer"
      class="wa-fab"
      id="wa-fab"
      aria-label="Chat WhatsApp Admin"
    >
      <svg
        class="wa-fab__icon"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <use href="#icon-wa"></use>
      </svg>
      <span class="wa-fab__label">Butuh bantuan?</span>
    </a>
  </div>
</BaseLayout>

<style>
  /* ── Layout — identik dengan topup ── */
  main {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 48px var(--content-px) 80px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* ── Input Section — identik dengan topup ── */
  .input-section {
    background: var(--color-bg);
    border-radius: 20px;
    padding: 28px 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .page-title-row {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .page-title-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .page-title-icon svg {
    width: 24px;
    height: 24px;
    color: var(--color-text);
  }
  .page-title {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-text);
    margin: 0 0 3px;
    letter-spacing: -0.3px;
  }
  .page-subtitle {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin: 0;
  }
  .input-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .input-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
  }
  .input-row {
    display: flex;
    gap: 12px;
    align-items: stretch;
  }
  .input-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    border: 1.5px solid var(--color-border);
    border-radius: 14px;
    overflow: hidden;
    background: var(--color-bg);
    transition: border-color 0.2s;
  }
  .input-wrap:focus-within {
    border-color: var(--color-text);
  }
  .input-wrap.error {
    border-color: #e53e3e;
  }
  .input-prefix {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-muted);
    background: #f0f0f0;
    padding: 0 16px;
    height: 52px;
    display: flex;
    align-items: center;
    border-right: 1.5px solid var(--color-border);
    flex-shrink: 0;
  }
  .input-wrap input {
    flex: 1;
    height: 52px;
    padding: 0 16px;
    border: none;
    outline: none;
    font-size: 15px;
    font-weight: 500;
    color: var(--color-text);
    background: transparent;
    letter-spacing: 0.3px;
  }
  .input-wrap input::placeholder {
    color: #c4c4c4;
    font-weight: 400;
    letter-spacing: 0;
  }
  .input-hint {
    font-size: 12px;
    color: #b0b0b0;
    margin: 0;
    transition: color 0.2s;
  }
  .input-hint.success {
    color: #22863a;
  }
  .input-hint.error {
    color: #e53e3e;
  }

  /* Tombol Cek — ukuran dan radius sama dengan btn-order topup */
  .btn-cek {
    height: 52px;
    padding: 0 20px;
    border-radius: 14px;
    border: none;
    background: var(--color-text);
    color: var(--color-bg);
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 7px;
    flex-shrink: 0;
    white-space: nowrap;
    transition:
      opacity 0.2s,
      transform 0.15s;
  }
  .btn-cek:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }
  .btn-cek:not(:disabled):hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }
  .btn-cek:not(:disabled):active {
    transform: translateY(0);
  }

  /* ── Result Section — identik dengan products-section topup ── */
  .products-section {
    background: var(--color-bg);
    border-radius: 20px;
    overflow: hidden;
    min-height: 240px;
    display: flex;
    align-items: center;
    justify-content: center;
    contain: layout style;
  }
  /* Saat cs-card aktif, hilangkan background/border container luar */
  .products-section:has(#cs-card:not(.hidden)) {
    background: transparent;
    min-height: unset;
  }
  .state-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 56px 24px;
    text-align: center;
    gap: 10px;
    width: 100%;
  }
  .state-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 4px;
  }
  .state-icon svg {
    width: 26px;
    height: 26px;
    color: #000;
  }
  .state-icon--error svg {
    color: #e53e3e;
  }
  .state-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }
  .state-desc {
    font-size: 13px;
    color: var(--color-muted);
    margin: 0;
    max-width: 280px;
    line-height: 1.5;
  }

  /* Spinner loading */
  .spinner {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-text);
    animation: spin 0.7s linear infinite;
    margin-bottom: 4px;
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* Result container — identik dengan #products-container topup */
  #result-container {
    width: 100%;
    padding: 28px 28px 32px;
  }
  .products-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 24px;
  }
  .products-header-left {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .provider-logo {
    width: 40px;
    height: 40px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 900;
    color: white;
    flex-shrink: 0;
    overflow: hidden;
    background: transparent;
  }
  .provider-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .products-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 2px;
  }
  .products-count {
    font-size: 12px;
    color: var(--color-muted);
    margin: 0;
  }

  /* Status badge */
  .result-status {
    font-size: 11px;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 99px;
    background: #fee2e2;
    color: #dc2626;
    flex-shrink: 0;
  }
  .result-status.paid {
    background: #dcfce7;
    color: #16a34a;
  }

  /* Detail card — via JS :global */
  :global(.result-detail-card) {
    background: #f0f0f0;
    border: 1.5px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    animation: cardIn 0.22s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  :global(.detail-row) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 13px 18px;
    gap: 16px;
  }
  :global(.detail-row:not(:last-child)) {
    border-bottom: 1px solid var(--color-border);
  }
  :global(.detail-row--total) {
    background: var(--color-bg);
  }
  :global(.detail-label) {
    font-size: 12px;
    font-weight: 500;
    color: var(--color-muted);
    flex-shrink: 0;
  }
  :global(.detail-label--total) {
    font-weight: 700;
    color: var(--color-text);
  }
  :global(.detail-value) {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
    text-align: right;
  }
  :global(.detail-value--total) {
    font-size: 18px;
    font-weight: 900;
    letter-spacing: -0.5px;
  }
  :global(.btn-bayar) {
    width: 100%;
    height: 46px;
    margin-top: 12px;
    background: #25d366;
    border: none;
    border-radius: 12px;
    font-size: 13px;
    font-weight: 700;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    transition:
      background 0.2s,
      transform 0.15s;
    letter-spacing: -0.1px;
    animation: cardIn 0.22s 0.1s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  :global(.btn-bayar:hover) {
    background: #1dba58;
    transform: translateY(-1px);
  }
  :global(.btn-bayar:active) {
    transform: translateY(0);
  }

  /* ── Modal — identik dengan topup ── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(10, 10, 10, 0.45);
    backdrop-filter: blur(6px);
    z-index: 1000;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    animation: fadeIn 0.2s ease;
  }
  .modal {
    background: var(--color-bg);
    width: 100%;
    max-width: 440px;
    border-radius: 24px 24px 0 0;
    overflow: hidden;
    animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 20px 16px;
    border-bottom: 1px solid var(--color-border);
  }
  .modal-header-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .modal-provider-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-border);
    flex-shrink: 0;
    transition: background 0.3s;
  }
  .modal-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }
  .modal-close {
    width: 32px;
    height: 32px;
    border-radius: 9px;
    border: 1.5px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }
  .modal-close:hover {
    background: var(--page-bg);
  }
  .modal-body {
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .modal-nominal-hero {
    border-radius: 14px;
    padding: 16px 18px;
    background: #f0f0f0;
    border: 1.5px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .modal-nominal-hero__label {
    font-size: 10px;
