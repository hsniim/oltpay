</style>

<script>
  (function () {
    // ── CONFIG ──────────────────────────────────────────────────────────────
    const cfg: {
      wa: string;
      name: string;
      title: string;
      inputLabel: string;
      isPhoneInput: boolean;
      isNumericInput: boolean;
      inputMinLength: number;
      inputMaxLength: number;
      accent: string;
      skuCode: string | null;
    } = JSON.parse(
      (document.getElementById("config") as HTMLScriptElement).textContent!,
    );

    const {
      wa: waNumber,
      tg: tgUsername,
      title: brandTitle,
      isPhoneInput,
      isNumericInput,
      inputMinLength,
      inputMaxLength,
    } = cfg;

    // ── DOM REFS ────────────────────────────────────────────────────────────
    const $ = (id: string) => document.getElementById(id)!;
    const userInput = $("user-input") as HTMLInputElement;
    const inputWrap = $("input-wrap");
    const inputHint = $("input-hint");
    const btnCek = $("btn-cek") as HTMLButtonElement;
    const resultSection = $("result-section");
    const emptyState = $("empty-state");
    const csCard = $("cs-card");
    const csCardInfo = $("cs-card-info");
    const csWaPreviewText = $("cs-wa-preview-text");
    const btnCsChannel = $("btn-cs-channel") as HTMLButtonElement;
    const tabWa = $("tab-wa") as HTMLButtonElement;
    const tabTg = $("tab-tg") as HTMLButtonElement;
    const csPreviewIcon = $("cs-preview-icon");
    const csBtnIcon = $("cs-btn-icon");
    const csBtnLabel = $("cs-btn-label");

    // ── TAB STATE ────────────────────────────────────────────────────────────
    let activeChannel: "wa" | "tg" = "wa";
    let currentMsg = "";
    const csCardInner = csCard.querySelector(".cs-card__inner") as HTMLElement;

    function setChannel(ch: "wa" | "tg") {
      activeChannel = ch;
      const isWa = ch === "wa";

      // Tab active state
      tabWa.classList.toggle("cs-tab-btn--active", isWa);
      tabTg.classList.toggle("cs-tab-btn--active", !isWa);

      // Card color theme
      csCardInner.classList.toggle("cs-channel--tg", !isWa);

      // Preview icon
      csPreviewIcon
        .querySelector("use")!
        .setAttribute("href", isWa ? "#icon-wa" : "#icon-tg");
      csPreviewIcon.style.fill = isWa ? "#25d366" : "#229ed9";

      // Button
      csBtnIcon
        .querySelector("use")!
        .setAttribute("href", isWa ? "#icon-wa" : "#icon-tg");
      csBtnLabel.textContent = isWa
        ? "Chat CS via WhatsApp"
        : "Chat CS via Telegram";
      btnCsChannel.className = `cs-card__btn cs-card__btn--${ch}`;

      if (currentMsg) renderPreview();
    }

    function renderPreview() {
      csWaPreviewText.textContent = currentMsg;
      btnCsChannel.onclick = () => {
        if (activeChannel === "wa") {
          window.open(
            `https://wa.me/${waNumber}?text=${encodeURIComponent(currentMsg)}`,
            "_blank",
          );
        } else {
          window.open(
            `https://t.me/${tgUsername}?text=${encodeURIComponent(currentMsg)}`,
            "_blank",
          );
        }
      };
    }

    tabWa.addEventListener("click", () => setChannel("wa"));
    tabTg.addEventListener("click", () => setChannel("tg"));

    // ── HELPERS ─────────────────────────────────────────────────────────────
    function normalizePhone(val: string) {
      let n = val.replace(/\D/g, "");
      if (n.startsWith("62")) n = "0" + n.slice(2);
      if (n.startsWith("8")) n = "0" + n;
      return n;
    }

    function getDisplayValue(raw: string) {
      return isPhoneInput ? `+62 ${normalizePhone(raw).slice(1)}` : raw.trim();
    }

    function getCustomerNo(raw: string) {
      return isPhoneInput ? normalizePhone(raw) : raw.trim();
    }

    function debounce<T extends (...a: unknown[]) => void>(fn: T, ms: number) {
      let t: ReturnType<typeof setTimeout>;
      return (...a: Parameters<T>) => {
        clearTimeout(t);
        t = setTimeout(() => fn(...a), ms);
      };
    }

    // ── VALIDASI ─────────────────────────────────────────────────────────────
    const VALID_PREFIXES = new Set([
      "0811",
      "0812",
      "0813",
      "0821",
      "0822",
      "0823",
      "0851",
      "0852",
      "0853",
      "0814",
      "0815",
      "0816",
      "0855",
      "0856",
      "0857",
      "0858",
      "0817",
      "0818",
      "0819",
      "0859",
      "0877",
      "0878",
      "0831",
      "0832",
      "0833",
      "0838",
      "0895",
      "0896",
      "0897",
      "0898",
      "0899",
      "0881",
      "0882",
      "0883",
      "0884",
      "0885",
      "0886",
      "0887",
      "0888",
      "0889",
      "0820",
      "0840",
    ]);

    function phoneStatus(
      raw: string,
    ): "empty" | "typing" | "invalid_prefix" | "valid" {
      const n = normalizePhone(raw);
      if (!n) return "empty";
      if (n.length < 7) return "typing";
      if (n.length >= 4 && !VALID_PREFIXES.has(n.slice(0, 4)))
        return "invalid_prefix";
      if (n.length < 10) return "typing";
      return "valid";
    }

    function nonPhoneStatus(
      raw: string,
    ): "empty" | "typing" | "invalid" | "valid" {
      const val = raw.trim();
      if (!val) return "empty";

      // Untuk input numerik: tolak karakter non-digit sejak awal
      if (isNumericInput && !/^\d+$/.test(val)) return "invalid";

      // Jika ada validationPattern dari config, gunakan sebagai validasi utama
      if (cfg.validationPattern) {
        const re = new RegExp(cfg.validationPattern);
        // Masih mengetik: panjang belum mencapai minimum
        if (val.length < inputMinLength) return "typing";
        // Sudah di rentang panjang yang benar — uji regex penuh
        if (re.test(val)) return "valid";
        return "invalid";
      }

      // Fallback: validasi generik (tanpa pattern)
      if (val.length < inputMinLength) return "typing";
      if (val.length > inputMaxLength) return "invalid";
      return "valid";
    }

    function isInputValid(raw: string) {
      return isPhoneInput
        ? phoneStatus(raw) === "valid"
        : nonPhoneStatus(raw) === "valid";
    }

    // ── UI STATE ─────────────────────────────────────────────────────────────
    function setMode(mode: "empty" | "cs") {
      resultSection.style.alignItems = mode === "cs" ? "flex-start" : "center";
      emptyState.classList.toggle("hidden", mode !== "empty");
      csCard.classList.toggle("hidden", mode !== "cs");
    }

    // ── INPUT HANDLER ────────────────────────────────────────────────────────
    function updateUI() {
      const raw = userInput.value.trim();
      inputWrap.classList.remove("error");

      if (isPhoneInput) {
        const s = phoneStatus(raw);
        if (s === "empty") {
          inputHint.textContent = `Masukkan nomor HP ${brandTitle} Anda`;
          inputHint.className = "input-hint";
          btnCek.disabled = true;
        } else if (s === "typing") {
          inputHint.textContent = "Lanjutkan mengetik nomor HP Anda…";
          inputHint.className = "input-hint";
          btnCek.disabled = true;
        } else if (s === "invalid_prefix") {
          inputHint.textContent =
            "Nomor tidak dikenali — pastikan nomor HP Indonesia yang valid";
          inputHint.className = "input-hint error";
          inputWrap.classList.add("error");
          btnCek.disabled = true;
        } else {
          inputHint.textContent = `✓ ${getDisplayValue(raw)} siap dicek`;
          inputHint.className = "input-hint success";
          btnCek.disabled = false;
        }
        // Sembunyikan cs-card saat input berubah
        setMode("empty");
        return;
      }

      const s = nonPhoneStatus(raw);
      if (s === "empty") {
        inputHint.textContent =
          cfg.inputHint ?? `Masukkan ${cfg.inputLabel.toLowerCase()} Anda`;
        inputHint.className = "input-hint";
        btnCek.disabled = true;
      } else if (s === "typing") {
        inputHint.textContent =
          cfg.inputHintTyping ??
          `Lanjutkan mengisi… (${raw.trim().length}/${inputMinLength} karakter minimum)`;
        inputHint.className = "input-hint";
        btnCek.disabled = true;
      } else if (s === "invalid") {
        inputHint.textContent =
          cfg.inputHintInvalid ?? "Format tidak valid — periksa kembali";
        inputHint.className = "input-hint error";
        inputWrap.classList.add("error");
        btnCek.disabled = true;
      } else {
        inputHint.textContent = `✓ ${raw.trim()} siap dicek`;
        inputHint.className = "input-hint success";
        btnCek.disabled = false;
      }
      // Sembunyikan cs-card saat input berubah
      setMode("empty");
    }

    // ── CEK TAGIHAN — tampilkan CS card langsung ─────────────────────────────
    function cekTagihan() {
      const raw = userInput.value.trim();
      if (!isInputValid(raw)) return;

      const display = getDisplayValue(raw);
      const customerNo = getCustomerNo(raw);

      // Isi info pelanggan di card
      csCardInfo.innerHTML = `
        <div class="cs-info-row">
          <span class="cs-info-label">${cfg.inputLabel}</span>
          <span class="cs-info-value">${display}</span>
        </div>
        <div class="cs-info-row">
          <span class="cs-info-label">Layanan</span>
          <span class="cs-info-value">${brandTitle}</span>
        </div>`;

      // Simpan pesan (sama untuk WA & Telegram)
      currentMsg =
        `Halo min! 👋\n\n` +
        `Saya ingin cek & bayar tagihan *${brandTitle}*\n` +
        `${cfg.inputLabel}: *${display}*\n\n` +
        `Mohon dibantu dicek tagihan saya, terima kasih 🙏`;

      renderPreview();
      setMode("cs");
    }

    // ── INPUT SANITIZATION ───────────────────────────────────────────────────
    if (isPhoneInput || isNumericInput) {
      // Hanya izinkan digit untuk input numerik / nomor HP
      userInput.addEventListener("keydown", (e) => {
        const allowed = [
          "Backspace",
          "Delete",
          "ArrowLeft",
          "ArrowRight",
          "ArrowUp",
          "ArrowDown",
          "Tab",
          "Enter",
          "Home",
          "End",
        ];
        if (allowed.includes(e.key)) return;
        if (!/^\d$/.test(e.key)) e.preventDefault();
      });
      userInput.addEventListener("paste", (e) => {
        e.preventDefault();
        const text =
          (e.clipboardData ?? (window as any).clipboardData)?.getData("text") ??
          "";
        document.execCommand("insertText", false, text.replace(/\D/g, ""));
      });
    } else if (cfg.validationPattern) {
      // Untuk input teks dengan pattern: strip karakter ilegal saat paste
      userInput.addEventListener("paste", (e) => {
        e.preventDefault();
        const text =
          (e.clipboardData ?? (window as any).clipboardData)?.getData("text") ??
          "";
        // Hapus spasi dan karakter kontrol, pertahankan karakter yang mungkin valid
        const cleaned = text.replace(/[\s\x00-\x1F\x7F]/g, "");
        document.execCommand(
          "insertText",
          false,
          cleaned.slice(0, inputMaxLength),
        );
      });
    }

    // ── BOOT ─────────────────────────────────────────────────────────────────
    setMode("empty");
    const debouncedUpdate = debounce(updateUI, 120);
    userInput.addEventListener("input", debouncedUpdate, { passive: true });
    userInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter" && !btnCek.disabled) cekTagihan();
    });
    btnCek.addEventListener("click", cekTagihan);
  })();
</script>

<script>
  /* ── FAB drag + collapse — identik dengan topup ── */
  (function () {
    const wrap = document.getElementById("wa-fab-wrap") as HTMLElement;
    if (!wrap) return;
    let isDragging = false,
      didDrag = false;
    let startX = 0,
      startY = 0,
      origLeft = 0,
      origTop = 0,
      collapsed = false;

    window.addEventListener(
      "scroll",
      () => {
        if (window.innerWidth <= 480) return;
        const y = window.scrollY;
        if (y > 80 && !collapsed) {
          collapsed = true;
          wrap.classList.add("collapsed");
        } else if (y <= 80 && collapsed) {
          collapsed = false;
          wrap.classList.remove("collapsed");
        }
      },
      { passive: true },
    );

    function startDrag(cx: number, cy: number) {
      isDragging = true;
      didDrag = false;
      const r = wrap.getBoundingClientRect();
      origLeft = r.left;
      origTop = r.top;
      startX = cx;
      startY = cy;
      wrap.style.right = "auto";
      wrap.style.bottom = "auto";
      wrap.style.left = origLeft + "px";
      wrap.style.top = origTop + "px";
      wrap.classList.add("dragging");
    }
    function moveDrag(cx: number, cy: number) {
      if (!isDragging) return;
      const dx = cx - startX,
        dy = cy - startY;
      if (Math.abs(dx) > 3 || Math.abs(dy) > 3) didDrag = true;
      wrap.style.left =
        Math.max(
          8,
          Math.min(window.innerWidth - wrap.offsetWidth - 8, origLeft + dx),
        ) + "px";
      wrap.style.top =
        Math.max(
          8,
          Math.min(window.innerHeight - wrap.offsetHeight - 8, origTop + dy),
        ) + "px";
    }
    function endDrag(e: Event) {
      if (!isDragging) return;
      isDragging = false;
      wrap.classList.remove("dragging");
      if (!didDrag) return;
      const r = wrap.getBoundingClientRect();
      wrap.style.left = "auto";
      wrap.style.right = "auto";
      wrap.style.top = r.top + "px";
      wrap.style.bottom = "auto";
      wrap.style[
        r.left + r.width / 2 < window.innerWidth / 2 ? "left" : "right"
      ] = "20px";
      e.preventDefault();
    }

    wrap.addEventListener("mousedown", (e) => startDrag(e.clientX, e.clientY));
    window.addEventListener("mousemove", (e) => moveDrag(e.clientX, e.clientY));
    window.addEventListener("mouseup", endDrag);
    wrap.addEventListener(
      "touchstart",
      (e) => startDrag(e.touches[0].clientX, e.touches[0].clientY),
      { passive: true },
    );
    window.addEventListener(
      "touchmove",
      (e) => moveDrag(e.touches[0].clientX, e.touches[0].clientY),
      { passive: true },
    );
    window.addEventListener("touchend", endDrag);
  })();
</script>