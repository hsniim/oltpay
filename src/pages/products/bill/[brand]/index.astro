  }
  .order-value {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
    text-align: right;
  }
  .order-value--desc {
    font-size: 12px;
    font-weight: 500;
    color: var(--color-muted);
  }
  .order-value--phone {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.5px;
  }
  .order-value--price {
    font-size: 16px;
    font-weight: 900;
    letter-spacing: -0.5px;
  }
  .wa-preview {
    border-radius: 12px;
    overflow: hidden;
    border: 1.5px solid #d4f0d8;
    background: #f0faf1;
  }
  .wa-preview__header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    background: #e4f7e6;
    border-bottom: 1px solid #d4f0d8;
    font-size: 10.5px;
    font-weight: 600;
    color: #2d7a3a;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }
  .wa-preview__bubble {
    font-size: 12.5px;
    color: #1a3a1f;
    line-height: 1.65;
    padding: 10px 14px;
    white-space: pre-line;
  }
  .modal-footer {
    padding: 12px 20px 20px;
    display: flex;
    gap: 8px;
  }
  .btn-cancel {
    height: 46px;
    padding: 0 18px;
    border: 1.5px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-bg);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-muted);
    cursor: pointer;
    transition:
      background 0.15s,
      border-color 0.15s;
    flex-shrink: 0;
  }
  .btn-cancel:hover {
    background: var(--page-bg);
    border-color: #c0c0c0;
  }
  .btn-order {
    flex: 1;
    height: 46px;
    background: #25d366;
    border: none;
    border-radius: 12px;
    font-size: 13px;
    font-weight: 700;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    transition:
      background 0.2s,
      transform 0.15s;
    letter-spacing: -0.1px;
  }
  .btn-order:hover {
    background: #1dba58;
    transform: translateY(-1px);
  }
  .btn-order:active {
    transform: translateY(0);
  }

  /* ── FAB — identik dengan topup ── */
  .wa-fab-wrap {
    position: fixed;
    bottom: 28px;
    right: 24px;
    z-index: 900;
    animation: fabIn 0.5s 1.5s cubic-bezier(0.16, 1, 0.3, 1) both;
    touch-action: none;
    user-select: none;
  }
  .wa-fab {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #25d366;
    color: #fff;
    text-decoration: none;
    border-radius: 50px;
    padding: 13px 20px 13px 15px;
    box-shadow:
      0 4px 20px rgba(37, 211, 102, 0.4),
      0 2px 8px rgba(0, 0, 0, 0.12);
    font-size: 13px;
    font-weight: 700;
    white-space: nowrap;
    transition:
      background 0.2s,
      box-shadow 0.2s,
      border-radius 0.35s,
      padding 0.35s,
      gap 0.35s;
  }
  .wa-fab:hover {
    background: #1dba58;
    box-shadow:
      0 8px 28px rgba(37, 211, 102, 0.45),
      0 4px 12px rgba(0, 0, 0, 0.14);
  }
  .wa-fab__icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }
  .wa-fab__label {
    display: inline-block;
    max-width: 160px;
    overflow: hidden;
    opacity: 1;
    transition:
      max-width 0.35s,
      opacity 0.2s,
      margin 0.35s;
    line-height: 1;
  }
  .wa-fab-wrap.collapsed .wa-fab {
    border-radius: 50%;
    padding: 15px;
    gap: 0;
  }
  .wa-fab-wrap.collapsed .wa-fab__label {
    max-width: 0;
    opacity: 0;
    margin: 0;
  }
  .wa-fab-wrap.dragging .wa-fab {
    opacity: 0.9;
    transform: scale(1.06);
  }

  /* ── Animations — identik dengan topup ── */
  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  @keyframes slideUp {
    from {
      transform: translateY(100%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }
  @keyframes scaleIn {
    from {
      transform: scale(0.96);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }
  @keyframes cardIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes fabIn {
    from {
      opacity: 0;
      transform: translateY(16px) scale(0.9);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* ── Responsive — identik dengan topup ── */
  @media (min-width: 600px) {
    .modal {
      border-radius: 20px;
      animation: scaleIn 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .modal-overlay {
      align-items: center;
      padding: 24px;
    }
  }
  @media (max-width: 640px) {
    main {
      padding: 20px 12px 80px;
    }
  }
  @media (max-width: 600px) {
    main {
      padding: 28px 16px 80px;
      gap: 12px;
    }
    .input-section {
      padding: 20px 16px 24px;
      gap: 18px;
    }
    #result-container {
      padding: 20px 16px 24px;
    }
    .products-header {
      padding-bottom: 16px;
      margin-bottom: 18px;
    }
    .input-row {
      flex-direction: column;
    }
    .btn-cek {
      width: 100%;
      justify-content: center;
    }
  }
  @media (max-width: 480px) {
    .wa-fab-wrap {
      bottom: 20px;
      right: 16px;
    }
    .wa-fab {
      width: 52px;
      height: 52px;
      padding: 0 !important;
      border-radius: 50% !important;
      justify-content: center;
      gap: 0 !important;
    }
    .wa-fab__label {
      display: none !important;
    }
  }

  .hidden {
    display: none !important;
  }
</style>

<script>
  (function () {
    // ── CONFIG ──────────────────────────────────────────────────────────────
    const cfg: {
      wa: string;
      name: string;
      title: string;
      inputLabel: string;
      isPhoneInput: boolean;
      isNumericInput: boolean;
      inputMinLength: number;
      inputMaxLength: number;
      accent: string;
      skuCode: string | null;
    } = JSON.parse(
      (document.getElementById("config") as HTMLScriptElement).textContent!,
    );

    const {
      wa: waNumber,
      title: brandTitle,
      isPhoneInput,
      isNumericInput,
      inputMinLength,
      inputMaxLength,
      accent,
      skuCode,
    } = cfg;

    const WORKER_URL = "https://oltpay.husnovember21.workers.dev";

    // ── DOM REFS ────────────────────────────────────────────────────────────
    const $ = (id: string) => document.getElementById(id)!;
    const userInput = $("user-input") as HTMLInputElement;
    const inputWrap = $("input-wrap");
    const inputHint = $("input-hint");
    const btnCek = $("btn-cek") as HTMLButtonElement;
    const resultSection = $("result-section");
    const emptyState = $("empty-state");
    const loadingState = $("loading-state");
    const errorState = $("error-state");
    const resultContainer = $("result-container");
    const resultBrand = $("result-brand");
    const resultPeriod = $("result-period");
    const resultStatus = $("result-status");
    const resultLogoEl = $("result-provider-logo");
    const resultGrid = $("result-grid");
    const modalOverlay = $("modal-overlay");
    const detailTotal = $("detail-total");
    const detailProduct = $("detail-product");
    const detailTarget = $("detail-target");
    const detailName = $("detail-name");
    const detailPeriodModal = $("detail-period-modal");
    const detailPeriodRow = $("detail-period-row");
    const detailTagihan = $("detail-tagihan");
    const detailTagihanRow = $("detail-tagihan-row");
    const detailAdmin = $("detail-admin");
    const detailAdminRow = $("detail-admin-row");
    const detailBayar = $("detail-bayar");
    const waPreviewText = $("wa-preview-text");
    const errorTitle = $("error-title");
    const errorDesc = $("error-desc");

    // Set accent pada modal dot
    ($("modal-provider-dot") as HTMLElement).style.background = accent;

    // ── HELPERS ─────────────────────────────────────────────────────────────
    const rpFmt = new Intl.NumberFormat("id-ID", {
      style: "currency",
      currency: "IDR",
      minimumFractionDigits: 0,
    });
    const formatRp = (n: number) => rpFmt.format(n);

    function normalizePhone(val: string) {
      let n = val.replace(/\D/g, "");
      if (n.startsWith("62")) n = "0" + n.slice(2);
      if (n.startsWith("8")) n = "0" + n;
      return n;
    }

    function getDisplayValue(raw: string) {
      return isPhoneInput ? `+62 ${normalizePhone(raw).slice(1)}` : raw.trim();
    }

    function getCustomerNo(raw: string) {
      return isPhoneInput ? normalizePhone(raw) : raw.trim();
    }

    // ── VALIDASI ─────────────────────────────────────────────────────────────
    const VALID_PREFIXES = new Set([
      "0811",
      "0812",
      "0813",
      "0821",
      "0822",
      "0823",
      "0851",
      "0852",
      "0853",
      "0814",
      "0815",
      "0816",
      "0855",
      "0856",
      "0857",
      "0858",
      "0817",
      "0818",
      "0819",
      "0859",
      "0877",
      "0878",
      "0831",
      "0832",
      "0833",
      "0838",
      "0895",
      "0896",
      "0897",
      "0898",
      "0899",
      "0881",
      "0882",
      "0883",
      "0884",
      "0885",
      "0886",
      "0887",
      "0888",
      "0889",
      "0820",
      "0840",
    ]);

    function phoneStatus(
      raw: string,
    ): "empty" | "typing" | "invalid_prefix" | "valid" {
      const n = normalizePhone(raw);
      if (!n) return "empty";
      if (n.length < 7) return "typing";
      if (n.length >= 4 && !VALID_PREFIXES.has(n.slice(0, 4)))
        return "invalid_prefix";
      if (n.length < 10) return "typing";
      return "valid";
    }

    function nonPhoneStatus(
      raw: string,
    ): "empty" | "typing" | "invalid" | "valid" {
      const val = raw.trim();
      if (!val) return "empty";
      if (isNumericInput) {
        if (!/^\d+$/.test(val)) return "invalid";
        if (val.length < inputMinLength) return "typing";
        if (val.length > inputMaxLength) return "invalid";
        return "valid";
      }
      if (val.length < inputMinLength) return "typing";
      if (val.length > inputMaxLength) return "invalid";
      return "valid";
    }

    function isInputValid(raw: string) {
      return isPhoneInput
        ? phoneStatus(raw) === "valid"
        : nonPhoneStatus(raw) === "valid";
    }

    function debounce<T extends (...a: unknown[]) => void>(fn: T, ms: number) {
      let t: ReturnType<typeof setTimeout>;
      return (...a: Parameters<T>) => {
        clearTimeout(t);
        t = setTimeout(() => fn(...a), ms);
      };
    }

    // ── UI STATE ─────────────────────────────────────────────────────────────
    function setMode(mode: "empty" | "loading" | "error" | "result") {
      const isResult = mode === "result";
      resultSection.style.alignItems = isResult ? "flex-start" : "center";
      emptyState.classList.toggle("hidden", mode !== "empty");
      loadingState.classList.toggle("hidden", mode !== "loading");
      errorState.classList.toggle("hidden", mode !== "error");
      resultContainer.classList.toggle("hidden", mode !== "result");
    }

    // ── INPUT HANDLER ────────────────────────────────────────────────────────
    function updateUI() {
      const raw = userInput.value.trim();
      inputWrap.classList.remove("error");

      if (isPhoneInput) {
        const s = phoneStatus(raw);
        if (s === "empty") {
          inputHint.textContent = `Masukkan nomor HP ${brandTitle} Anda`;
          inputHint.className = "input-hint";
          btnCek.disabled = true;
        } else if (s === "typing") {
          inputHint.textContent = "Lanjutkan mengetik nomor HP Anda…";
          inputHint.className = "input-hint";
          btnCek.disabled = true;
        } else if (s === "invalid_prefix") {
          inputHint.textContent =
            "Nomor tidak dikenali — pastikan nomor HP Indonesia yang valid";
          inputHint.className = "input-hint error";
          inputWrap.classList.add("error");
          btnCek.disabled = true;
        } else {
          inputHint.textContent = `✓ ${getDisplayValue(raw)} siap dicek`;
          inputHint.className = "input-hint success";
          btnCek.disabled = false;
        }
        return;
      }

      const s = nonPhoneStatus(raw);
      if (s === "empty") {
        inputHint.textContent = `Masukkan ${cfg.inputLabel.toLowerCase()} Anda`;
        inputHint.className = "input-hint";
        btnCek.disabled = true;
      } else if (s === "typing") {
        inputHint.textContent = `Lanjutkan mengisi… (${raw.trim().length}/${inputMinLength} karakter minimum)`;
        inputHint.className = "input-hint";
        btnCek.disabled = true;
      } else if (s === "invalid") {
        inputHint.textContent = "Format tidak valid — periksa kembali";
        inputHint.className = "input-hint error";
        inputWrap.classList.add("error");
        btnCek.disabled = true;
      } else {
        inputHint.textContent = `✓ ${raw.trim()} siap dicek`;
        inputHint.className = "input-hint success";
        btnCek.disabled = false;
      }
    }

    // ── CEK TAGIHAN ──────────────────────────────────────────────────────────
    async function cekTagihan() {
      const raw = userInput.value.trim();
      if (!isInputValid(raw)) return;

      const customerNo = getCustomerNo(raw);
      btnCek.disabled = true;
      setMode("loading");

      try {
        const res = await fetch(WORKER_URL, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            type: "cek-tagihan",
            customer_no: customerNo,
            buyer_sku_code: skuCode ?? cfg.name,
          }),
        });
        const data = await res.json();

        if (data.result !== "success" || data.data?.rc !== "00") {
          errorTitle.textContent = "Tagihan tidak ditemukan";
          errorDesc.textContent =
            data.data?.message ??
            data.error ??
            "Periksa kembali nomor yang Anda masukkan";
          setMode("error");
          return;
        }

        renderResult(data.data, customerNo);
        setMode("result");
      } catch {
        errorTitle.textContent = "Gagal menghubungi server";
        errorDesc.textContent = "Periksa koneksi internet Anda dan coba lagi";
        setMode("error");
      } finally {
        btnCek.disabled = !isInputValid(userInput.value.trim());
      }
    }

    // ── RENDER RESULT ────────────────────────────────────────────────────────
    function renderResult(d: any, customerNo: string) {
      resultBrand.textContent = d.product_name ?? brandTitle;
      resultPeriod.textContent = d.period ?? d.bl_th ?? "—";
      resultStatus.textContent = "Belum Bayar";
      resultStatus.className = "result-status";

      // Logo — pola sama dengan topup
      const img = document.createElement("img");
      img.src = `/logos/${cfg.name}_logo.svg`;
      img.alt = brandTitle;
      img.onload = () => {
        resultLogoEl.style.cssText =
          "background:transparent;border:none;border-radius:0";
        resultLogoEl.innerHTML = "";
        resultLogoEl.appendChild(img);
      };
      img.onerror = () => {
        resultLogoEl.textContent = brandTitle.slice(0, 2).toUpperCase();
        resultLogoEl.style.cssText = `background:${accent};border-radius:14px;border:none`;
      };

      const tagihan = Number(d.selling_price ?? d.price ?? 0);
      const admin = Number(d.admin ?? 0);
      const total = tagihan + admin;
      const display = getDisplayValue(userInput.value.trim());

      const waMsg =
        `Halo min! 👋\n\n` +
        `Saya mau bayar *${d.product_name ?? brandTitle}*\n` +
        `Nomor: *${display}*\nNama: ${d.customer_name ?? "—"}\n` +
        (d.period ? `Periode: ${d.period}\n` : "") +
        `\nTotal Bayar: *${formatRp(total)}*\n\nMohon diproses, terima kasih 🙏`;

      // Build detail card (struktur mirip nominal-btn topup)
      const rows: { label: string; value: string; isTotal?: boolean }[] = [
        { label: "Nama Pelanggan", value: d.customer_name ?? "—" },
        { label: "Nomor Pelanggan", value: customerNo },
        ...(d.period || d.bl_th
          ? [{ label: "Periode", value: d.period ?? d.bl_th }]
          : []),
        ...(tagihan > 0
          ? [{ label: "Tagihan", value: formatRp(tagihan) }]
          : []),
        ...(admin > 0
          ? [{ label: "Biaya Admin", value: formatRp(admin) }]
          : []),
        { label: "Total Bayar", value: formatRp(total), isTotal: true },
      ];

      const card = document.createElement("div");
      card.className = "result-detail-card";
      rows.forEach((row) => {
        const el = document.createElement("div");
        el.className = `detail-row${row.isTotal ? " detail-row--total" : ""}`;
        el.innerHTML = `
          <span class="detail-label${row.isTotal ? " detail-label--total" : ""}">${row.label}</span>
          <span class="detail-value${row.isTotal ? " detail-value--total" : ""}">${row.value}</span>`;
        card.appendChild(el);
      });

      // WA Preview
      const waPrev = document.createElement("div");
      waPrev.style.cssText =
        "border-radius:12px;overflow:hidden;border:1.5px solid #d4f0d8;background:#f0faf1;margin-top:12px";
      waPrev.innerHTML = `
        <div style="display:flex;align-items:center;gap:6px;padding:8px 12px;background:#e4f7e6;border-bottom:1px solid #d4f0d8;font-size:10.5px;font-weight:600;color:#2d7a3a;text-transform:uppercase;letter-spacing:0.3px">
          <svg viewBox="0 0 24 24" fill="#25d366" width="14" height="14"><use href="#icon-wa"></use></svg>
          <span>Pesan yang akan dikirim</span>
        </div>
        <div style="font-size:12.5px;color:#1a3a1f;line-height:1.65;padding:10px 14px;white-space:pre-line">${waMsg}</div>`;

      // Tombol bayar langsung (tanpa modal)
      const btnBayar = document.createElement("button");
      btnBayar.className = "btn-bayar";
      btnBayar.innerHTML = `<svg viewBox="0 0 24 24" fill="currentColor" width="17" height="17"><use href="#icon-wa"></use></svg> Bayar via WhatsApp`;
      btnBayar.addEventListener("click", () => {
        window.open(
          `https://wa.me/${waNumber}?text=${encodeURIComponent(waMsg)}`,
          "_blank",
        );
      });

      resultGrid.innerHTML = "";
      resultGrid.appendChild(card);
      resultGrid.appendChild(waPrev);
      resultGrid.appendChild(btnBayar);

      // Isi modal juga (untuk konfirmasi ulang jika user klik)
      detailTotal.textContent = formatRp(total);
      detailProduct.textContent = `${d.product_name ?? brandTitle}${d.period ? " — " + d.period : ""}`;
      detailTarget.textContent = display;
      detailName.textContent = d.customer_name ?? "—";
      if (d.period || d.bl_th) {
        detailPeriodModal.textContent = d.period ?? d.bl_th;
        detailPeriodRow.classList.remove("hidden");
      } else {
        detailPeriodRow.classList.add("hidden");
      }
      if (tagihan > 0) {
        detailTagihan.textContent = formatRp(tagihan);
        detailTagihanRow.classList.remove("hidden");
      } else {
        detailTagihanRow.classList.add("hidden");
      }
      if (admin > 0) {
        detailAdmin.textContent = formatRp(admin);
        detailAdminRow.classList.remove("hidden");
      } else {
        detailAdminRow.classList.add("hidden");
      }
      detailBayar.textContent = formatRp(total);
      waPreviewText.textContent = waMsg;
      (btnCek as any)._waMsg = waMsg;
    }

    // ── MODAL ────────────────────────────────────────────────────────────────
    function closeModal() {
      modalOverlay.classList.add("hidden");
      document.body.style.overflow = "";
    }
    function sendOrder() {
      const msg = (btnCek as any)._waMsg ?? "";
      if (!msg) return;
      window.open(
        `https://wa.me/${waNumber}?text=${encodeURIComponent(msg)}`,
        "_blank",
      );
      closeModal();
    }

    // ── INPUT SANITIZATION — identik dengan topup ───────────────────────────
    if (isPhoneInput || isNumericInput) {
      userInput.addEventListener("keydown", (e) => {
        const allowed = [
          "Backspace",
          "Delete",
          "ArrowLeft",
          "ArrowRight",
          "ArrowUp",
          "ArrowDown",
          "Tab",
          "Enter",
          "Home",
          "End",
        ];
        if (allowed.includes(e.key)) return;
        if (!/^\d$/.test(e.key)) e.preventDefault();
      });
      userInput.addEventListener("paste", (e) => {
        e.preventDefault();
        const text =
          (e.clipboardData ?? (window as any).clipboardData)?.getData("text") ??
          "";
        document.execCommand("insertText", false, text.replace(/\D/g, ""));
      });
    }

    // ── BOOT ─────────────────────────────────────────────────────────────────
    setMode("empty");
    const debouncedUpdate = debounce(updateUI, 120);
    userInput.addEventListener("input", debouncedUpdate, { passive: true });
    userInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter" && !btnCek.disabled) cekTagihan();
    });
    btnCek.addEventListener("click", cekTagihan);
    $("modal-close").addEventListener("click", closeModal);
    $("btn-cancel").addEventListener("click", closeModal);
    $("btn-order").addEventListener("click", sendOrder);
    modalOverlay.addEventListener("click", (e) => {
      if (e.target === modalOverlay) closeModal();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeModal();
    });
  })();
</script>

<script>
  /* ── FAB drag + collapse — identik dengan topup ── */
  (function () {
    const wrap = document.getElementById("wa-fab-wrap") as HTMLElement;
    if (!wrap) return;
    let isDragging = false,
      didDrag = false;
    let startX = 0,
      startY = 0,
      origLeft = 0,
      origTop = 0,
      collapsed = false;

    window.addEventListener(
      "scroll",
      () => {
        if (window.innerWidth <= 480) return;
        const y = window.scrollY;
        if (y > 80 && !collapsed) {
          collapsed = true;
          wrap.classList.add("collapsed");
        } else if (y <= 80 && collapsed) {
          collapsed = false;
          wrap.classList.remove("collapsed");
        }
      },
      { passive: true },
    );

    function startDrag(cx: number, cy: number) {
      isDragging = true;
      didDrag = false;
      const r = wrap.getBoundingClientRect();
      origLeft = r.left;
      origTop = r.top;
      startX = cx;
      startY = cy;
      wrap.style.right = "auto";
      wrap.style.bottom = "auto";
      wrap.style.left = origLeft + "px";
      wrap.style.top = origTop + "px";
      wrap.classList.add("dragging");
    }
    function moveDrag(cx: number, cy: number) {
      if (!isDragging) return;
      const dx = cx - startX,
        dy = cy - startY;
      if (Math.abs(dx) > 3 || Math.abs(dy) > 3) didDrag = true;
      wrap.style.left =
        Math.max(
          8,
          Math.min(window.innerWidth - wrap.offsetWidth - 8, origLeft + dx),
        ) + "px";
      wrap.style.top =
        Math.max(
          8,
          Math.min(window.innerHeight - wrap.offsetHeight - 8, origTop + dy),
        ) + "px";
    }
    function endDrag(e: Event) {
      if (!isDragging) return;
      isDragging = false;
      wrap.classList.remove("dragging");
      if (!didDrag) return;
      const r = wrap.getBoundingClientRect();
      wrap.style.left = "auto";
      wrap.style.right = "auto";
      wrap.style.top = r.top + "px";
      wrap.style.bottom = "auto";
      wrap.style[
        r.left + r.width / 2 < window.innerWidth / 2 ? "left" : "right"
      ] = "20px";
      e.preventDefault();
    }

    wrap.addEventListener("mousedown", (e) => startDrag(e.clientX, e.clientY));
    window.addEventListener("mousemove", (e) => moveDrag(e.clientX, e.clientY));
    window.addEventListener("mouseup", endDrag);
    wrap.addEventListener(
      "touchstart",
      (e) => startDrag(e.touches[0].clientX, e.touches[0].clientY),
      { passive: true },
    );
    window.addEventListener(
      "touchmove",
      (e) => moveDrag(e.touches[0].clientX, e.touches[0].clientY),
      { passive: true },
    );
    window.addEventListener("touchend", endDrag);
  })();
</script>