  .modal-nominal-hero__value {
    font-size: 32px;
    font-weight: 900;
    color: var(--color-text);
    letter-spacing: -1px;
    line-height: 1;
  }
  .modal-nominal-hero__provider {
    font-size: 12px;
    font-weight: 500;
    color: var(--color-muted);
    margin-top: 2px;
  }
  .order-card {
    border: 1.5px solid var(--color-border);
    border-radius: 14px;
    overflow: hidden;
  }
  .order-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 11px 16px;
    gap: 16px;
  }
  .order-row:not(:last-child) {
    border-bottom: 1px solid var(--color-border);
  }
  .order-row--total {
    background: #f0f0f0;
  }
  .order-label {
    font-size: 12px;
    font-weight: 500;
