---
// src/pages/products/bill/[brand]/index.astro
//
// Static pages untuk tagihan pascabayar:
//   /products/bill/plnpasca    → Listrik PLN Pascabayar
//   /products/bill/pdam        → PDAM
//   /products/bill/bpjs        → BPJS Kesehatan
//   /products/bill/isp         → Internet/ISP
//   /products/bill/tv          → TV Berbayar
//   /products/bill/insurance   → Asuransi
//   /products/bill/pulsapasca  → Pulsa Pascabayar

import Navbar from "../../../../components/Navbar.astro";
import BaseLayout from "../../../../layouts/BaseLayout.astro";

const waNumber = "6289501450667";

// Definisi semua kategori tagihan
const tagihanProducts = [
  {
    name: "plnpasca",
    title: "Listrik PLN Pasca",
    subtitle: "Bayar tagihan listrik PLN pascabayar",
    icon: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>',
    inputLabel: "Nomor Pelanggan PLN",
    inputType: "number",
    inputPrefix: null,
    inputPlaceholder: "Masukkan nomor pelanggan",
    inputMinLength: 10,
    inputMaxLength: 12,
    inputHint: "Nomor pelanggan PLN terdiri dari 10–12 digit",
    skuCode: "pln", // Digiflazz buyer_sku_code untuk cek tagihan
    accent: "#00A0E3",
  },
  {
    name: "pdam",
    title: "PDAM",
    subtitle: "Bayar tagihan air PDAM",
    icon: '<path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"></path>',
    inputLabel: "Nomor Pelanggan PDAM",
    inputType: "text",
    inputPrefix: null,
    inputPlaceholder: "Masukkan nomor pelanggan PDAM",
    inputMinLength: 6,
    inputMaxLength: 20,
    inputHint: "Masukkan nomor pelanggan sesuai tagihan PDAM Anda",
    skuCode: null, // Pilih sub-brand dari dropdown
    accent: "#2B6CB0",
    subBrands: ["PDAM Kota", "PDAM Kabupaten"],
  },
  {
    name: "bpjs",
    title: "BPJS Kesehatan",
    subtitle: "Bayar iuran BPJS Kesehatan",
    icon: '<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>',
    inputLabel: "Nomor VA / Nomor Kartu BPJS",
    inputType: "number",
    inputPrefix: null,
    inputPlaceholder: "Masukkan nomor VA atau kartu BPJS",
    inputMinLength: 11,
    inputMaxLength: 13,
    inputHint: "Nomor VA BPJS terdiri dari 11–13 digit",
    skuCode: "bpjs",
    accent: "#00A651",
  },
  {
    name: "isp",
    title: "Internet/ISP",
    subtitle: "Bayar tagihan internet rumah",
    icon: '<circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>',
    inputLabel: "Nomor Pelanggan / ID",
    inputType: "text",
    inputPrefix: null,
    inputPlaceholder: "Masukkan nomor pelanggan",
    inputMinLength: 4,
    inputMaxLength: 20,
    inputHint: "Masukkan nomor pelanggan sesuai tagihan ISP Anda",
    skuCode: null,
    accent: "#553C9A",
  },
  {
    name: "tv",
    title: "TV Berbayar",
    subtitle: "Bayar tagihan TV berlangganan",
    icon: '<rect x="2" y="7" width="20" height="15" rx="2" ry="2"></rect><polyline points="17 2 12 7 7 2"></polyline>',
    inputLabel: "Nomor Pelanggan / ID",
    inputType: "text",
    inputPrefix: null,
    inputPlaceholder: "Masukkan nomor pelanggan",
    inputMinLength: 4,
    inputMaxLength: 20,
    inputHint: "Masukkan nomor pelanggan TV berlangganan Anda",
    skuCode: null,
    accent: "#D97706",
  },
  {
    name: "insurance",
    title: "Asuransi",
    subtitle: "Bayar premi asuransi",
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>',
    inputLabel: "Nomor Polis",
    inputType: "text",
    inputPrefix: null,
    inputPlaceholder: "Masukkan nomor polis asuransi",
    inputMinLength: 4,
    inputMaxLength: 25,
    inputHint: "Masukkan nomor polis sesuai kartu asuransi Anda",
    skuCode: null,
    accent: "#276749",
  },
  {
    name: "pulsapasca",
    title: "Pulsa Pascabayar",
    subtitle: "Bayar tagihan kartu pascabayar",
    icon: '<rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line>',
    inputLabel: "Nomor HP Pascabayar",
    inputType: "tel",
    inputPrefix: "+62",
    inputPlaceholder: "8xx xxxx xxxx",
    inputMinLength: 9,
    inputMaxLength: 13,
    inputHint: "Masukkan nomor HP kartu pascabayar Anda",
    skuCode: null,
    accent: "#E53E3E",
  },
];

export function getStaticPaths() {
  return tagihanProducts.map((item) => ({
    params: { brand: item.name },
    props: item,
  }));
}

const {
  name,
  title,
  subtitle,
  icon,
  inputLabel,
  inputType,
  inputPrefix,
  inputPlaceholder,
  inputMinLength,
  inputMaxLength,
  inputHint,
  skuCode,
  accent,
} = Astro.props;

const isPhoneInput = inputPrefix === "+62";

const configData = JSON.stringify({
  wa: waNumber,
  name,
  title,
  subtitle,
  inputLabel,
  isPhoneInput,
  inputMinLength,
  inputMaxLength,
  accent,
  skuCode,
});
---

<BaseLayout>
  <Navbar />

  <!-- SVG Symbols -->
  <svg
    aria-hidden="true"
    style="display:none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <symbol
      id="icon-tagihan"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <set:html={icon}></set:html={icon}>
    </symbol>
    <symbol
      id="icon-close"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <line x1="18" y1="6" x2="6" y2="18"></line><line
        x1="6"
        y1="6"
        x2="18"
        y2="18"></line>
    </symbol>
    <symbol id="icon-wa" viewBox="0 0 24 24" fill="currentColor">
      <path
        d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
      ></path>
      <path
        d="M11.99 0C5.374 0 0 5.373 0 11.988c0 2.114.549 4.099 1.504 5.83L0 24l6.335-1.652A11.939 11.939 0 0 0 11.99 24C18.626 24 24 18.626 24 12.012 24 5.373 18.626 0 11.99 0zm0 21.785a9.796 9.796 0 0 1-4.994-1.365l-.357-.212-3.758.98.999-3.647-.233-.374A9.722 9.722 0 0 1 2.203 12c0-5.398 4.394-9.791 9.787-9.791 5.394 0 9.788 4.393 9.788 9.791 0 5.398-4.394 9.785-9.788 9.785z"
      ></path>
    </symbol>
    <symbol
      id="icon-search"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="11" cy="11" r="8"></circle><line
        x1="21"
        y1="21"
        x2="16.65"
        y2="16.65"></line>
    </symbol>
    <symbol
      id="icon-check"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <polyline points="20 6 9 17 4 12"></polyline>
    </symbol>
  </svg>

  <div class="page-wrapper">
    <main>
      <!-- ══ INPUT SECTION ══ -->
      <section class="input-section">
        <div class="page-title-row">
          <div class="page-title-icon">
            <svg
              viewBox="0 0 24 24"
              width="24"
              height="24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <use href="#icon-tagihan"></use>
            </svg>
          </div>
          <div>
            <h1 class="page-title">{title}</h1>
            <p class="page-subtitle">{subtitle}</p>
          </div>
        </div>

        <div class="input-card">
          <label class="input-label" for="user-input">{inputLabel}</label>
          <div class="input-row">
            <div class="input-wrap" id="input-wrap">
              {inputPrefix && <span class="input-prefix">{inputPrefix}</span>}
              <input
                type={inputType}
                id="user-input"
                placeholder={inputPlaceholder}
                autocomplete="off"
                inputmode={inputType === "tel" || inputType === "number"
                  ? "numeric"
                  : undefined}
                maxlength={inputMaxLength}
              />
            </div>
            <button class="btn-cek" id="btn-cek" disabled>
              <svg
                viewBox="0 0 24 24"
                width="16"
                height="16"
                aria-hidden="true"
              >
                <use href="#icon-search"></use>
              </svg>
              Cek Tagihan
            </button>
          </div>
          <p class="input-hint" id="input-hint">{inputHint}</p>
        </div>
      </section>

      <!-- ══ RESULT SECTION ══ -->
      <section class="result-section" id="result-section">
        <!-- Empty state -->
        <div class="state-wrap" id="empty-state">
          <div class="state-icon">
            <svg
              viewBox="0 0 24 24"
              width="26"
              height="26"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <use href="#icon-tagihan"></use>
            </svg>
          </div>
          <p class="state-title">Masukkan {inputLabel}</p>
          <p class="state-desc">
            Klik "Cek Tagihan" untuk melihat informasi tagihan Anda
          </p>
        </div>

        <!-- Loading state -->
        <div class="state-wrap hidden" id="loading-state">
          <div class="spinner"></div>
          <p class="state-title">Mengecek tagihan...</p>
          <p class="state-desc">Mohon tunggu sebentar</p>
        </div>

        <!-- Error state -->
        <div class="state-wrap hidden" id="error-state">
          <div class="state-icon state-icon--error">
            <svg
              viewBox="0 0 24 24"
              width="26"
              height="26"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="8" x2="12" y2="12"></line>
              <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
          </div>
          <p class="state-title" id="error-title">Tagihan tidak ditemukan</p>
          <p class="state-desc" id="error-desc">
            Periksa kembali nomor yang Anda masukkan
          </p>
        </div>

        <!-- Result card -->
        <div class="result-container hidden" id="result-container">
          <div class="result-card">
            <!-- Header info tagihan -->
            <div class="result-header">
              <div class="result-header-left">
                <div class="result-provider-dot" id="result-provider-dot"></div>
                <div>
                  <p class="result-brand" id="result-brand">—</p>
                  <p class="result-period" id="result-period">—</p>
                </div>
              </div>
              <div class="result-status" id="result-status">Belum Bayar</div>
            </div>

            <!-- Detail tagihan -->
            <div class="result-details">
              <div class="detail-row">
                <span class="detail-label">Nama Pelanggan</span>
                <span class="detail-value" id="detail-name">—</span>
              </div>
              <div class="detail-row">
                <span class="detail-label">Nomor Pelanggan</span>
                <span class="detail-value" id="detail-number">—</span>
              </div>
              <div class="detail-row" id="detail-desc-row">
                <span class="detail-label">Keterangan</span>
                <span class="detail-value" id="detail-desc">—</span>
              </div>
              <div class="detail-row detail-row--total">
                <span class="detail-label detail-label--total"
                  >Total Tagihan</span
                >
                <span class="detail-value detail-value--total" id="detail-total"
                  >—</span
                >
              </div>
              <div class="detail-row" id="detail-admin-row">
                <span class="detail-label">Biaya Admin</span>
                <span class="detail-value" id="detail-admin">—</span>
              </div>
              <div class="detail-row detail-row--bayar">
                <span class="detail-label detail-label--bayar">Total Bayar</span
                >
                <span class="detail-value detail-value--bayar" id="detail-bayar"
                  >—</span
                >
              </div>
            </div>

            <!-- WA Preview -->
            <div class="wa-preview">
              <div class="wa-preview__header">
                <svg
                  viewBox="0 0 24 24"
                  fill="#25d366"
                  width="14"
                  height="14"
                  aria-hidden="true"
                >
                  <use href="#icon-wa"></use>
                </svg>
                <span>Pesan yang akan dikirim</span>
              </div>
              <div class="wa-preview__bubble" id="wa-preview-text">—</div>
            </div>
          </div>

          <!-- Tombol bayar -->
          <button class="btn-bayar" id="btn-bayar">
            <svg
              viewBox="0 0 24 24"
              fill="currentColor"
              width="17"
              height="17"
              aria-hidden="true"
            >
              <use href="#icon-wa"></use>
            </svg>
            Bayar via WhatsApp
          </button>
        </div>
      </section>
    </main>
  </div>

  <!-- Config -->
  <script id="config" type="application/json" set:html={configData} />

  <!-- FAB WhatsApp -->
  <div class="wa-fab-wrap" id="wa-fab-wrap">
    <a
      href={`https://wa.me/${waNumber}`}
      target="_blank"
      rel="noopener noreferrer"
      class="wa-fab"
      id="wa-fab"
      aria-label="Chat WhatsApp Admin"
    >
      <svg
        class="wa-fab__icon"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <use href="#icon-wa"></use>
      </svg>
      <span class="wa-fab__label">Butuh bantuan?</span>
    </a>
  </div>
</BaseLayout>

<style>
  main {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 48px var(--content-px) 80px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* ── Input Section ── */
  .input-section {
    background: var(--color-bg);
    border-radius: 20px;
    padding: 28px 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .page-title-row {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .page-title-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .page-title-icon svg {
    width: 24px;
    height: 24px;
    color: var(--color-text);
  }
  .page-title {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-text);
    margin: 0 0 3px;
    letter-spacing: -0.3px;
  }
  .page-subtitle {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin: 0;
  }
  .input-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .input-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
  }
  .input-row {
    display: flex;
    gap: 12px;
    align-items: stretch;
  }
  .input-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    border: 1.5px solid var(--color-border);
    border-radius: 14px;
    overflow: hidden;
    background: var(--color-bg);
    transition: border-color 0.2s;
  }
  .input-wrap:focus-within {
    border-color: var(--color-text);
  }
  .input-wrap.error {
    border-color: #e53e3e;
  }
  .input-prefix {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-muted);
    background: #f0f0f0;
    padding: 0 16px;
    height: 52px;
    display: flex;
    align-items: center;
    border-right: 1.5px solid var(--color-border);
    flex-shrink: 0;
  }
  .input-wrap input {
    flex: 1;
    height: 52px;
    padding: 0 16px;
    border: none;
    outline: none;
    font-size: 15px;
    font-weight: 500;
    color: var(--color-text);
    background: transparent;
    letter-spacing: 0.3px;
  }
  .input-wrap input::placeholder {
    color: #c4c4c4;
    font-weight: 400;
    letter-spacing: 0;
  }
  .input-hint {
    font-size: 12px;
    color: #b0b0b0;
    margin: 0;
    transition: color 0.2s;
  }
  .input-hint.success {
    color: #22863a;
  }
  .input-hint.error {
    color: #e53e3e;
  }

  /* Tombol Cek */
  .btn-cek {
    height: 52px;
    padding: 0 20px;
    border-radius: 14px;
    border: none;
    background: var(--color-text);
    color: var(--color-bg);
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 7px;
    flex-shrink: 0;
    transition:
      opacity 0.2s,
      transform 0.15s;
    white-space: nowrap;
  }
  .btn-cek:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }
  .btn-cek:not(:disabled):hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }
  .btn-cek:not(:disabled):active {
    transform: translateY(0);
  }

  /* ── Result Section ── */
  .result-section {
    background: var(--color-bg);
    border-radius: 20px;
    overflow: hidden;
    min-height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* State wrap */
  .state-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 56px 24px;
    text-align: center;
    gap: 10px;
    width: 100%;
  }
  .state-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 4px;
  }
  .state-icon svg {
    width: 26px;
    height: 26px;
    color: #000;
  }
  .state-icon--error svg {
    color: #e53e3e;
  }
  .state-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }
  .state-desc {
    font-size: 13px;
    color: var(--color-muted);
    margin: 0;
    max-width: 280px;
    line-height: 1.5;
  }

  /* Spinner */
  .spinner {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-text);
    animation: spin 0.8s linear infinite;
    margin-bottom: 4px;
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* Result container */
  .result-container {
    width: 100%;
    padding: 28px 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-self: flex-start;
  }

  /* Result card */
  .result-card {
    border: 1.5px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .result-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 18px;
    border-bottom: 1px solid var(--color-border);
    background: #f8f8f8;
  }
  .result-header-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .result-provider-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--color-border);
  }
  .result-brand {
    font-size: 14px;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 2px;
  }
  .result-period {
    font-size: 11px;
    color: var(--color-muted);
    margin: 0;
  }
  .result-status {
    font-size: 11px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 99px;
    background: #fee2e2;
    color: #dc2626;
    flex-shrink: 0;
  }
  .result-status.paid {
    background: #dcfce7;
    color: #16a34a;
  }

  /* Detail rows */
  .result-details {
    display: flex;
    flex-direction: column;
  }
  .detail-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 11px 18px;
    gap: 16px;
  }
  .detail-row:not(:last-child) {
    border-bottom: 1px solid var(--color-border);
  }
  .detail-row--total {
    background: #f8f8f8;
  }
  .detail-row--bayar {
    background: #0a0a0a;
  }
  .detail-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--color-muted);
    flex-shrink: 0;
  }
  .detail-label--total {
    font-weight: 700;
    color: var(--color-text);
  }
  .detail-label--bayar {
    font-weight: 700;
    color: #fff;
  }
  .detail-value {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
    text-align: right;
  }
  .detail-value--total {
    font-size: 16px;
    font-weight: 900;
    letter-spacing: -0.5px;
  }
  .detail-value--bayar {
    font-size: 18px;
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.5px;
  }

  /* WA Preview */
  .wa-preview {
    border-top: 1px solid var(--color-border);
  }
  .wa-preview__header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 18px;
    background: #e4f7e6;
    border-bottom: 1px solid #d4f0d8;
    font-size: 10.5px;
    font-weight: 600;
    color: #2d7a3a;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }
  .wa-preview__bubble {
    font-size: 12.5px;
    color: #1a3a1f;
    line-height: 1.65;
    padding: 12px 18px;
    white-space: pre-line;
    background: #f0faf1;
  }

  /* Tombol Bayar */
  .btn-bayar {
    height: 52px;
    width: 100%;
    border-radius: 14px;
    border: none;
    background: #25d366;
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition:
      background 0.2s,
      transform 0.15s;
    letter-spacing: -0.1px;
  }
  .btn-bayar:hover {
    background: #1dba58;
    transform: translateY(-1px);
  }
  .btn-bayar:active {
    transform: translateY(0);
  }

  /* FAB */
  .wa-fab-wrap {
    position: fixed;
    bottom: 28px;
    right: 24px;
    z-index: 900;
    animation: fabIn 0.5s 1.5s cubic-bezier(0.16, 1, 0.3, 1) both;
    touch-action: none;
    user-select: none;
  }
  .wa-fab {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #25d366;
    color: #fff;
    text-decoration: none;
    border-radius: 50px;
    padding: 13px 20px 13px 15px;
    box-shadow:
      0 4px 20px rgba(37, 211, 102, 0.4),
      0 2px 8px rgba(0, 0, 0, 0.12);
    font-size: 13px;
    font-weight: 700;
    white-space: nowrap;
    transition:
      background 0.2s,
      box-shadow 0.2s,
      border-radius 0.35s,
      padding 0.35s,
      gap 0.35s;
  }
  .wa-fab:hover {
    background: #1dba58;
  }
  .wa-fab__icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }
  .wa-fab__label {
    display: inline-block;
    max-width: 160px;
    overflow: hidden;
    opacity: 1;
    transition:
      max-width 0.35s,
      opacity 0.2s,
      margin 0.35s;
    line-height: 1;
  }
  .wa-fab-wrap.collapsed .wa-fab {
    border-radius: 50%;
    padding: 15px;
    gap: 0;
  }
  .wa-fab-wrap.collapsed .wa-fab__label {
    max-width: 0;
    opacity: 0;
    margin: 0;
  }

  .hidden {
    display: none !important;
  }

  @keyframes fabIn {
    from {
      opacity: 0;
      transform: translateY(16px) scale(0.9);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @media (max-width: 600px) {
    main {
      padding: 28px 16px 80px;
      gap: 12px;
    }
    .input-section {
      padding: 20px 16px 24px;
      gap: 18px;
    }
    .result-container {
      padding: 20px 16px 24px;
    }
    .input-row {
      flex-direction: column;
    }
    .btn-cek {
      width: 100%;
      justify-content: center;
    }
    .wa-fab-wrap {
      bottom: 20px;
      right: 16px;
    }
    .wa-fab {
      width: 52px;
      height: 52px;
      padding: 0 !important;
      border-radius: 50% !important;
      justify-content: center;
      gap: 0 !important;
    }
    .wa-fab__label {
      display: none !important;
    }
  }
</style>

<script>
  (() => {
    const cfg = JSON.parse(
      (document.getElementById("config") as HTMLScriptElement).textContent!,
    );

    const {
      wa: waNumber,
      name,
      title,
      inputLabel,
      isPhoneInput,
      inputMinLength,
      inputMaxLength,
      accent,
    } = cfg;

    const WORKER_URL = "https://oltpay.husnovember21.workers.dev";

    // DOM refs
    const userInput = document.getElementById("user-input") as HTMLInputElement;
    const inputWrap = document.getElementById("input-wrap")!;
    const inputHint = document.getElementById("input-hint")!;
    const btnCek = document.getElementById("btn-cek") as HTMLButtonElement;
    const btnBayar = document.getElementById("btn-bayar")!;
    const emptyState = document.getElementById("empty-state")!;
    const loadingState = document.getElementById("loading-state")!;
    const errorState = document.getElementById("error-state")!;
    const resultContainer = document.getElementById("result-container")!;
    const resultSection = document.getElementById("result-section")!;

    // Result elements
    const resultDot = document.getElementById("result-provider-dot")!;
    const resultBrand = document.getElementById("result-brand")!;
    const resultPeriod = document.getElementById("result-period")!;
    const resultStatus = document.getElementById("result-status")!;
    const detailName = document.getElementById("detail-name")!;
    const detailNumber = document.getElementById("detail-number")!;
    const detailDesc = document.getElementById("detail-desc")!;
    const detailDescRow = document.getElementById("detail-desc-row")!;
    const detailTotal = document.getElementById("detail-total")!;
    const detailAdmin = document.getElementById("detail-admin")!;
    const detailAdminRow = document.getElementById("detail-admin-row")!;
    const detailBayar = document.getElementById("detail-bayar")!;
    const waPreview = document.getElementById("wa-preview-text")!;
    const errorTitle = document.getElementById("error-title")!;
    const errorDesc = document.getElementById("error-desc")!;

    // Set accent color
    resultDot.style.background = accent;

    // Formatter
    const rpFmt = new Intl.NumberFormat("id-ID", {
      style: "currency",
      currency: "IDR",
      minimumFractionDigits: 0,
    });
    const formatRp = (n: number) => rpFmt.format(n);

    function normalizePhone(val: string) {
      let n = val.replace(/\D/g, "");
      if (n.startsWith("62")) n = "0" + n.slice(2);
      if (n.startsWith("8")) n = "0" + n;
      return n;
    }

    function getInputValue() {
      const raw = userInput.value.trim();
      if (isPhoneInput) return normalizePhone(raw);
      return raw.replace(
        /\D/g,
        name === "plnpasca" || name === "bpjs" ? "" : /[^a-zA-Z0-9]/g.source,
      );
    }

    function isValid(raw: string) {
      const val = isPhoneInput ? normalizePhone(raw) : raw.trim();
      return val.length >= inputMinLength && val.length <= inputMaxLength;
    }

    // ── Input handler ──
    function onInput() {
      const raw = userInput.value.trim();
      inputWrap.classList.remove("error");

      if (!raw) {
        inputHint.textContent =
          cfg.inputHint ?? `Masukkan ${inputLabel.toLowerCase()}`;
        inputHint.className = "input-hint";
        btnCek.disabled = true;
        return;
      }

      const val = isPhoneInput ? normalizePhone(raw) : raw;

      if (val.length < inputMinLength) {
        inputHint.textContent = `Lanjutkan mengisi… (${val.length}/${inputMinLength} karakter)`;
        inputHint.className = "input-hint";
        btnCek.disabled = true;
      } else if (val.length > inputMaxLength) {
        inputHint.textContent = `Terlalu panjang — maksimal ${inputMaxLength} karakter`;
        inputHint.className = "input-hint error";
        inputWrap.classList.add("error");
        btnCek.disabled = true;
      } else {
        inputHint.textContent = `✓ ${isPhoneInput ? "+62 " + val.slice(1) : val} siap dicek`;
        inputHint.className = "input-hint success";
        btnCek.disabled = false;
      }
    }

    // ── Mode switcher ──
    function setMode(mode: "empty" | "loading" | "error" | "result") {
      const isResult = mode === "result";
      resultSection.style.alignItems = isResult ? "flex-start" : "center";
      emptyState.classList.toggle("hidden", mode !== "empty");
      loadingState.classList.toggle("hidden", mode !== "loading");
      errorState.classList.toggle("hidden", mode !== "error");
      resultContainer.classList.toggle("hidden", mode !== "result");
    }

    // ── Cek Tagihan via Worker (Digiflazz pasca) ──
    async function cekTagihan() {
      const raw = userInput.value.trim();
      if (!isValid(raw)) return;

      const customerNo = isPhoneInput ? normalizePhone(raw) : raw.trim();
      btnCek.disabled = true;
      setMode("loading");

      try {
        const res = await fetch(WORKER_URL, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            type: "cek-tagihan",
            customer_no: customerNo,
            buyer_sku_code: cfg.skuCode ?? name,
          }),
        });

        const data = await res.json();

        if (data.result !== "success" || data.data?.rc !== "00") {
          const msg =
            data.data?.message ?? data.error ?? "Tagihan tidak ditemukan";
          errorTitle.textContent = "Tagihan tidak ditemukan";
          errorDesc.textContent = msg;
          setMode("error");
          return;
        }

        const d = data.data;

        // Render hasil
        resultBrand.textContent = d.product_name ?? title;
        resultPeriod.textContent = d.period ?? d.bl_th ?? "—";
        resultStatus.textContent = "Belum Bayar";
        resultStatus.className = "result-status";

        detailName.textContent = d.customer_name ?? "—";
        detailNumber.textContent = customerNo;

        if (d.desc) {
          detailDesc.textContent = d.desc;
          detailDescRow.classList.remove("hidden");
        } else {
          detailDescRow.classList.add("hidden");
        }

        const tagihan = Number(d.selling_price ?? d.price ?? 0);
        const admin = Number(d.admin ?? 0);
        const total = tagihan + admin;

        detailTotal.textContent = formatRp(tagihan);

        if (admin > 0) {
          detailAdmin.textContent = formatRp(admin);
          detailAdminRow.classList.remove("hidden");
        } else {
          detailAdminRow.classList.add("hidden");
        }

        detailBayar.textContent = formatRp(total);

        // WA Preview
        const display = isPhoneInput
          ? "+62 " + customerNo.slice(1)
          : customerNo;
        const waMsg =
          `Halo min! 👋\n\n` +
          `Saya mau bayar *${d.product_name ?? title}*\n` +
          `Nomor: *${display}*\n` +
          `Nama: ${d.customer_name ?? "—"}\n` +
          (d.period ? `Periode: ${d.period}\n` : "") +
          `\nTotal Bayar: *${formatRp(total)}*\n\n` +
          `Mohon diproses, terima kasih 🙏`;

        waPreview.textContent = waMsg;

        // Simpan untuk tombol bayar
        (btnBayar as any)._waMsg = waMsg;

        setMode("result");
      } catch (err) {
        errorTitle.textContent = "Gagal menghubungi server";
        errorDesc.textContent = "Periksa koneksi internet Anda dan coba lagi";
        setMode("error");
      } finally {
        btnCek.disabled = !isValid(userInput.value.trim());
      }
    }

    // ── Bayar via WA ──
    btnBayar.addEventListener("click", () => {
      const msg = (btnBayar as any)._waMsg ?? "";
      if (!msg) return;
      window.open(
        `https://wa.me/${waNumber}?text=${encodeURIComponent(msg)}`,
        "_blank",
      );
    });

    // ── Numerik only ──
    if (isPhoneInput || ["plnpasca", "bpjs"].includes(name)) {
      userInput.addEventListener("keydown", (e) => {
        const allowed = [
          "Backspace",
          "Delete",
          "ArrowLeft",
          "ArrowRight",
          "ArrowUp",
          "ArrowDown",
          "Tab",
          "Enter",
          "Home",
          "End",
        ];
        if (allowed.includes(e.key)) return;
        if (!/^\d$/.test(e.key)) e.preventDefault();
      });
      userInput.addEventListener("paste", (e) => {
        e.preventDefault();
        const text =
          (e.clipboardData ?? (window as any).clipboardData)?.getData("text") ??
          "";
        document.execCommand("insertText", false, text.replace(/\D/g, ""));
      });
    }

    userInput.addEventListener("input", onInput);
    userInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter" && !btnCek.disabled) cekTagihan();
    });
    btnCek.addEventListener("click", cekTagihan);

    // Init
    setMode("empty");
  })();
</script>

<script>
  /* ── FAB collapse on scroll ── */
  (() => {
    const wrap = document.getElementById("wa-fab-wrap") as HTMLElement;
    if (!wrap) return;
    let collapsed = false;
    window.addEventListener(
      "scroll",
      () => {
        const y = window.scrollY;
        if (y > 80 && !collapsed) {
          collapsed = true;
          wrap.classList.add("collapsed");
        } else if (y <= 80 && collapsed) {
          collapsed = false;
          wrap.classList.remove("collapsed");
        }
      },
      { passive: true },
    );

    let isDragging = false,
      didDrag = false;
    let startX = 0,
      startY = 0,
      origLeft = 0,
      origTop = 0;
    function startDrag(cx: number, cy: number) {
      isDragging = true;
      didDrag = false;
      const r = wrap.getBoundingClientRect();
      origLeft = r.left;
      origTop = r.top;
      startX = cx;
      startY = cy;
      wrap.style.right = "auto";
      wrap.style.bottom = "auto";
      wrap.style.left = origLeft + "px";
      wrap.style.top = origTop + "px";
      wrap.classList.add("dragging");
    }
    function moveDrag(cx: number, cy: number) {
      if (!isDragging) return;
      const dx = cx - startX,
        dy = cy - startY;
      if (Math.abs(dx) > 3 || Math.abs(dy) > 3) didDrag = true;
      wrap.style.left =
        Math.max(
          8,
          Math.min(window.innerWidth - wrap.offsetWidth - 8, origLeft + dx),
        ) + "px";
      wrap.style.top =
        Math.max(
          8,
          Math.min(window.innerHeight - wrap.offsetHeight - 8, origTop + dy),
        ) + "px";
    }
    function endDrag(e: Event) {
      if (!isDragging) return;
      isDragging = false;
      wrap.classList.remove("dragging");
      if (!didDrag) return;
      const r = wrap.getBoundingClientRect();
      wrap.style.left = "auto";
      wrap.style.right = "auto";
      wrap.style.top = r.top + "px";
      wrap.style.bottom = "auto";
      wrap.style[
        r.left + r.width / 2 < window.innerWidth / 2 ? "left" : "right"
      ] = "20px";
      e.preventDefault();
    }
    wrap.addEventListener("mousedown", (e) => startDrag(e.clientX, e.clientY));
    window.addEventListener("mousemove", (e) => moveDrag(e.clientX, e.clientY));
    window.addEventListener("mouseup", endDrag);
    wrap.addEventListener(
      "touchstart",
      (e) => startDrag(e.touches[0].clientX, e.touches[0].clientY),
      { passive: true },
    );
    window.addEventListener(
      "touchmove",
      (e) => moveDrag(e.touches[0].clientX, e.touches[0].clientY),
      { passive: true },
    );
    window.addEventListener("touchend", endDrag);
  })();
</script>