<script>
  (function () {
    // ── CONFIG ──────────────────────────────────────────────────────────────
    const cfg: {
      wa: string;
      name: string;
      title: string;
      inputLabel: string;
      isPhoneInput: boolean;
      accent: string;
      unit: string;
      packages: Array<{
        code: string;
        name: string;
        desc: string;
        price: number;
      }>;
    } = JSON.parse(
      (document.getElementById("config") as HTMLScriptElement).textContent!,
    );

    const {
      wa: waNumber,
      title: gameTitle,
      isPhoneInput,
      accent,
      unit,
      inputMinLength,
      packages,
    } = cfg;

    // ── STATE ───────────────────────────────────────────────────────────────
    let selectedPkg: (typeof packages)[0] | null = null;

    // ── DOM REFS ────────────────────────────────────────────────────────────
    const $ = (id: string) => document.getElementById(id)!;
    const userInput = $("user-input") as HTMLInputElement;
    const inputWrap = $("input-wrap");
    const inputHint = $("input-hint");
    const emptyState = $("empty-state");
    const productsSection = $("products-section");
    const productsContainer = $("products-container");
    const productsGrid = $("products-grid");
    const productsTitleEl = $("products-title");
    const productsCountEl = $("products-count");
    const productsLogoEl = $("products-provider-logo");
    const modalOverlay = $("modal-overlay");
    const detailNominal = $("detail-nominal");
    const detailProduct = $("detail-product");
    const detailDesc = $("detail-desc");
    const detailTarget = $("detail-target");
    const detailPrice = $("detail-price");
    const waPreviewText = $("wa-preview-text");

    // ── HELPERS ─────────────────────────────────────────────────────────────
    const rpFmt = new Intl.NumberFormat("id-ID", {
      style: "currency",
      currency: "IDR",
      minimumFractionDigits: 0,
    });
    const formatRp = (n: number) => rpFmt.format(n);

    function normalizePhone(val: string) {
      let n = val.replace(/\D/g, "");
      if (n.startsWith("62")) n = "0" + n.slice(2);
      if (n.startsWith("8")) n = "0" + n;
      return n;
    }

    function debounce<T extends (...a: unknown[]) => void>(fn: T, ms: number) {
      let t: ReturnType<typeof setTimeout>;
      return (...a: Parameters<T>) => {
        clearTimeout(t);
        t = setTimeout(() => fn(...a), ms);
      };
    }

    function isInputValid(raw: string) {
      if (isPhoneInput) return normalizePhone(raw).length >= 10;
      // ID game: harus minimal inputMinLength digit sebelum produk tampil
      return raw.trim().replace(/\D/g, "").length >= inputMinLength;
    }

    // ── RENDER ──────────────────────────────────────────────────────────────
    function initProducts() {
      productsTitleEl.textContent = `Pilih ${unit} ${gameTitle}`;
      productsCountEl.textContent = `${packages.length} pilihan tersedia`;

      // Dot warna brand di modal
      ($("modal-provider-dot") as HTMLElement).style.background = accent;

      // Logo: sama persis dengan page paket data
      // → langsung append img, onerror fallback ke inisial berwarna
      const logoImg = document.createElement("img");
      logoImg.src = `/logos/${cfg.name}_logo.svg`;
      logoImg.alt = gameTitle;
      productsLogoEl.innerHTML = "";
      productsLogoEl.style.cssText =
        "background:transparent;border:none;border-radius:0";
      logoImg.onerror = () => {
        productsLogoEl.innerHTML = "";
        productsLogoEl.textContent = gameTitle.slice(0, 2).toUpperCase();
        productsLogoEl.style.cssText = `background:${accent};border-radius:14px;border:none`;
      };
      productsLogoEl.appendChild(logoImg);

      // Render kartu nominal
      const frag = document.createDocumentFragment();
      const header = document.createElement("div");
      header.className = "subcategory-header";
      header.innerHTML = `<span class="subcategory-title">${unit} ${gameTitle}</span><span class="subcategory-line"></span>`;
      frag.appendChild(header);

      const grid = document.createElement("div");
      grid.className = "nominals-grid";

      packages.forEach((pkg, i) => {
        const btn = document.createElement("button");
        btn.className = "nominal-btn";
        btn.style.animationDelay = `${i * 20}ms`;

        // Pisahkan angka dari satuan di nama paket (misal "355 Diamonds" → "355" + "Diamonds")
        const nameParts = pkg.name.match(/^([\d.,]+)\s*(.*)$/);
        const nameNumber = nameParts ? nameParts[1] : pkg.name;
        const nameUnit = nameParts ? nameParts[2] : unit;

        btn.innerHTML = `
          <div class="nominal-btn__top">
            <span class="nominal-btn__code">${pkg.code}</span>
            <span class="nominal-btn__badge">${gameTitle}</span>
          </div>
          <div class="nominal-btn__value-row">
            <div class="nominal-btn__value">${nameNumber}</div>
            <div class="nominal-btn__unit">${nameUnit || unit}</div>
          </div>
          <span class="nominal-btn__desc">${pkg.desc}</span>
          <div class="nominal-btn__footer">
            <div>
              <div class="nominal-btn__price-label">Harga</div>
              <div class="nominal-btn__price">${formatRp(pkg.price)}</div>
            </div>
            <div class="nominal-btn__cta">›</div>
          </div>`;
        btn.addEventListener("click", () => openModal(pkg));
        grid.appendChild(btn);
      });

      frag.appendChild(grid);
      productsGrid.innerHTML = "";
      productsGrid.appendChild(frag);
    }

    // ── UI STATE ─────────────────────────────────────────────────────────────
    function setMode(mode: "empty" | "products") {
      productsSection.style.alignItems =
        mode === "products" ? "flex-start" : "center";
      emptyState.classList.toggle("hidden", mode !== "empty");
      productsContainer.classList.toggle("hidden", mode !== "products");
    }

    // ── INPUT HANDLER ────────────────────────────────────────────────────────
    function updateUI() {
      const raw = userInput.value.trim();
      if (!raw) {
        inputHint.textContent = isPhoneInput
          ? `Masukkan nomor HP yang terdaftar di ${gameTitle}`
          : `Masukkan ${cfg.inputLabel.toLowerCase()} Anda`;
        inputHint.className = "input-hint";
        inputWrap.classList.remove("error");
        setMode("empty");
        return;
      }
      if (!isInputValid(raw)) {
        inputHint.textContent = isPhoneInput
          ? "Lanjutkan mengetik nomor HP Anda…"
          : `Lanjutkan mengisi ID… (min. ${inputMinLength} digit)`;
        inputHint.className = "input-hint";
        setMode("empty");
        return;
      }
      const display = isPhoneInput
        ? `+62 ${normalizePhone(raw).slice(1)}`
        : raw;
      inputHint.textContent = `✓ ${display} siap di-top up ${unit} ${gameTitle}`;
      inputHint.className = "input-hint success";
      inputWrap.classList.remove("error");
      setMode("products");
    }

    // ── MODAL ────────────────────────────────────────────────────────────────
    function openModal(pkg: (typeof packages)[0]) {
      const raw = userInput.value.trim();
      if (!isInputValid(raw)) {
        inputWrap.classList.add("error");
        inputHint.textContent = `Isi ${cfg.inputLabel.toLowerCase()} yang valid terlebih dahulu!`;
        inputHint.className = "input-hint error";
        userInput.focus();
        return;
      }
      selectedPkg = pkg;

      const display = isPhoneInput
        ? `+62 ${normalizePhone(raw).slice(1)}`
        : raw;

      // "kirim ke nomor" untuk HP, "kirim ke ID" untuk game ID
      const targetLabel = isPhoneInput ? "nomor" : "ID";

      detailNominal.textContent = pkg.name;
      detailProduct.textContent = `${gameTitle} — ${pkg.desc}`;
      detailDesc.textContent = pkg.desc;
      detailTarget.textContent = display;
      detailPrice.textContent = formatRp(pkg.price);
      waPreviewText.textContent =
        `Halo min! 👋\n\n` +
        `Saya mau *Top Up ${gameTitle} ${pkg.name}*, ` +
        `kirim ke ${targetLabel} *${display}* ya!\n\n` +
        `Detail:\n• Produk: ${pkg.desc}\n• Harga: ${formatRp(pkg.price)}\n\n` +
        `Mohon diproses, terima kasih 🙏`;

      modalOverlay.classList.remove("hidden");
      document.body.style.overflow = "hidden";
    }

    function closeModal() {
      modalOverlay.classList.add("hidden");
      document.body.style.overflow = "";
      selectedPkg = null;
    }

    // ── SEND WA ──────────────────────────────────────────────────────────────
    function sendOrder() {
      if (!selectedPkg) return;
      const raw = userInput.value.trim();
      const display = isPhoneInput
        ? `+62 ${normalizePhone(raw).slice(1)}`
        : raw;
      const targetLabel = isPhoneInput ? "nomor" : "ID";
      const msg = encodeURIComponent(
        `Halo min! 👋\n\n` +
          `Saya mau *Top Up ${gameTitle} ${selectedPkg.name}*, ` +
          `kirim ke ${targetLabel} *${display}* ya!\n\n` +
          `Detail:\n• Produk: ${selectedPkg.desc}\n• Harga: ${formatRp(selectedPkg.price)}\n\n` +
          `Mohon diproses, terima kasih 🙏`,
      );
      window.open(`https://wa.me/${waNumber}?text=${msg}`, "_blank");
      closeModal();
    }

    // ── BOOT ─────────────────────────────────────────────────────────────────
    initProducts();
    setMode("empty");

    const debouncedUpdate = debounce(updateUI, 120);
    userInput.addEventListener("input", debouncedUpdate, { passive: true });

    if (isPhoneInput) {
      userInput.addEventListener("keypress", (e) => {
        if (!/[\d\s\-+()]/.test(e.key)) e.preventDefault();
      });
    } else {
      // Game ID: hanya angka
      userInput.addEventListener("keypress", (e) => {
        if (!/[\d]/.test(e.key)) e.preventDefault();
      });
    }

    $("modal-close").addEventListener("click", closeModal);
    $("btn-cancel").addEventListener("click", closeModal);
    $("btn-order").addEventListener("click", sendOrder);
    modalOverlay.addEventListener("click", (e) => {
      if (e.target === modalOverlay) closeModal();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeModal();
    });
  })();
</script>

<script>
  /* ── FAB drag + collapse ── */
  (function () {
    const wrap = document.getElementById("wa-fab-wrap") as HTMLElement;
    if (!wrap) return;
    let isDragging = false,
      didDrag = false;
    let startX = 0,
      startY = 0,
      origLeft = 0,
      origTop = 0,
      collapsed = false;

    window.addEventListener(
      "scroll",
      () => {
        if (window.innerWidth <= 480) return;
        const y = window.scrollY;
        if (y > 80 && !collapsed) {
          collapsed = true;
          wrap.classList.add("collapsed");
        } else if (y <= 80 && collapsed) {
          collapsed = false;
          wrap.classList.remove("collapsed");
        }
      },
      { passive: true },
    );

    function startDrag(cx: number, cy: number) {
      isDragging = true;
      didDrag = false;
      const r = wrap.getBoundingClientRect();
      origLeft = r.left;
      origTop = r.top;
      startX = cx;
      startY = cy;
      wrap.style.right = "auto";
      wrap.style.bottom = "auto";
      wrap.style.left = origLeft + "px";
      wrap.style.top = origTop + "px";
      wrap.classList.add("dragging");
    }
    function moveDrag(cx: number, cy: number) {
      if (!isDragging) return;
      const dx = cx - startX,
        dy = cy - startY;
      if (Math.abs(dx) > 3 || Math.abs(dy) > 3) didDrag = true;
      wrap.style.left =
        Math.max(
          8,
          Math.min(window.innerWidth - wrap.offsetWidth - 8, origLeft + dx),
        ) + "px";
      wrap.style.top =
        Math.max(
          8,
          Math.min(window.innerHeight - wrap.offsetHeight - 8, origTop + dy),
        ) + "px";
    }
    function endDrag(e: Event) {
      if (!isDragging) return;
      isDragging = false;
      wrap.classList.remove("dragging");
      if (!didDrag) return;
      const r = wrap.getBoundingClientRect();
      wrap.style.left = "auto";
      wrap.style.right = "auto";
      wrap.style.top = r.top + "px";
      wrap.style.bottom = "auto";
      wrap.style[
        r.left + r.width / 2 < window.innerWidth / 2 ? "left" : "right"
      ] = "20px";
      e.preventDefault();
    }

    wrap.addEventListener("mousedown", (e) => startDrag(e.clientX, e.clientY));
    window.addEventListener("mousemove", (e) => moveDrag(e.clientX, e.clientY));
    window.addEventListener("mouseup", endDrag);
    wrap.addEventListener(
      "touchstart",
      (e) => startDrag(e.touches[0].clientX, e.touches[0].clientY),
      { passive: true },
    );
    window.addEventListener(
      "touchmove",
      (e) => moveDrag(e.touches[0].clientX, e.touches[0].clientY),
      { passive: true },
    );
    window.addEventListener("touchend", endDrag);
  })();
</script>
<script>
  /* ── LIVE PRICING — Digiflazz via Cloudflare Worker ── */
  (async () => {
    const WORKER_URL = "https://oltpay.husnovember21.workers.dev";

    // Mapping cfg.name (route) → Digiflazz category + brand
    // Sesuaikan brand name sesuai yang ada di akun Digiflazz Anda
    const BRAND_MAP = {
      ml: { category: "Games", brand: "Mobile Legends" },
      ff: { category: "Games", brand: "Free Fire" },
      pubgm: { category: "Games", brand: "PUBG Mobile" },
      garena: { category: "Games", brand: "Garena" },
    };

    // Ambil config
    let cfg;
    try {
      cfg = JSON.parse(document.getElementById("config").textContent);
    } catch {
      return;
    }

    const mapping = BRAND_MAP[cfg.name];
    if (!mapping) return;

    // Fetch harga live
    let liveMap;
    try {
      const res = await fetch(WORKER_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          type: "prepaid",
          category: mapping.category,
          brand: mapping.brand,
        }),
      });
      const data = await res.json();
      if (data.result !== "success" || !data.message.length) return;
      liveMap = new Map(
        data.message.map((item) => [item.buyer_sku_code, item]),
      );
    } catch {
      return;
    }

    // Patch cfg.packages dengan harga live
    cfg.packages = cfg.packages.map((pkg) => {
      const live = liveMap.get(pkg.code);
      return live ? { ...pkg, price: live.harga_jual } : pkg;
    });

    // Update script#config supaya openModal baca harga live
    const configEl = document.getElementById("config");
    if (configEl) configEl.textContent = JSON.stringify(cfg);

    // Update tampilan harga di grid
    const grid = document.getElementById("products-grid");
    if (!grid) return;

    grid.querySelectorAll(".nominal-btn").forEach((btn) => {
      const code = btn.querySelector(".nominal-btn__code")?.textContent?.trim();
      if (!code) return;
      const live = liveMap.get(code);
      if (!live) return;

      const priceEl = btn.querySelector(".nominal-btn__price");
      if (priceEl) priceEl.textContent = live.harga_jual_display;

      if (!live.tersedia) {
        btn.disabled = true;
        btn.style.opacity = "0.45";
        btn.style.cursor = "not-allowed";
        const badgeEl = btn.querySelector(".nominal-btn__badge");
        if (badgeEl) {
          badgeEl.textContent = "Habis";
          badgeEl.style.background = "#fee2e2";
          badgeEl.style.color = "#dc2626";
        }
      }
    });
  })();
</script>