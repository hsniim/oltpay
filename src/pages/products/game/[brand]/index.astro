---
// src/pages/products/game/[brand]/index.astro
//
// Static pages yang di-generate saat build:
//   /products/game/ml       → Mobile Legends
//   /products/game/ff       → Free Fire
//   /products/game/pubgm    → PUBG Mobile
//   /products/game/garena   → Garena Shell

import Navbar from "../../../../components/Navbar.astro";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { gameProducts } from "../../../../data/products.js";

export function getStaticPaths() {
  return gameProducts.map((item) => ({
    params: { brand: item.name },
    props: item,
  }));
}

const {
  name,
  title,
  icon, // SVG path string — sama persis dengan homepage tab Game
  inputLabel,
  inputType,
  inputPrefix, // '+62' | null
  packages,
} = Astro.props;

const waNumber = "6289501450667";

// Warna aksen per game
const accentMap: Record<string, string> = {
  ml: "#1B82D1", // biru MLBB
  ff: "#FF6B00", // oranye Free Fire
  pubgm: "#F5A623", // kuning PUBG
  garena: "#F04D2A", // merah Garena
};

const accent = accentMap[name] ?? "#0a0a0a";

// Satuan item per game (Diamond, UC, Shell, dll)
const unitMap: Record<string, string> = {
  ml: "Diamonds",
  ff: "Diamonds",
  pubgm: "UC",
  garena: "Shell",
};

const unit = unitMap[name] ?? "Item";

const isPhoneInput = inputPrefix === "+62";

const inputPlaceholder = isPhoneInput
  ? "8xx xxxx xxxx"
  : `Masukkan ${inputLabel.toLowerCase()}`;

// Minimum panjang ID per game sebelum produk ditampilkan
const minLengthMap: Record<string, number> = {
  ml: 9, // User ID MLBB: format 9-12 digit
  ff: 9, // User ID FF: minimal 9 digit
  pubgm: 8, // User ID PUBG: minimal 8 digit
  garena: 10, // Nomor HP: dihandle isPhoneInput
};
const inputMinLength = minLengthMap[name] ?? 6;

const configData = JSON.stringify({
  wa: waNumber,
  name,
  title,
  inputLabel,
  isPhoneInput,
  accent,
  unit,
  inputMinLength,
  packages,
});
---

<BaseLayout>
  <Navbar />

  <!-- ══ SVG SYMBOLS ══ -->
  <svg
    aria-hidden="true"
    style="display:none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <symbol
      id="icon-gamepad"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <line x1="6" y1="12" x2="10" y2="12"></line>
      <line x1="8" y1="10" x2="8" y2="14"></line>
      <circle cx="15" cy="13" r="1" fill="currentColor" stroke="none"></circle>
      <circle cx="17" cy="11" r="1" fill="currentColor" stroke="none"></circle>
      <path
        d="M17 6H7a5 5 0 0 0-5 5v2a5 5 0 0 0 5 5h10a5 5 0 0 0 5-5v-2a5 5 0 0 0-5-5z"
      ></path>
    </symbol>
    <symbol
      id="icon-phone"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect>
      <line x1="12" y1="18" x2="12.01" y2="18"></line>
    </symbol>
    <symbol
      id="icon-close"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </symbol>
    <symbol
      id="icon-clock"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="12" cy="12" r="10"></circle>
      <path d="M12 6v6l4 2"></path>
    </symbol>
    <symbol id="icon-wa" viewBox="0 0 24 24" fill="currentColor">
      <path
        d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
      ></path>
      <path
        d="M11.99 0C5.374 0 0 5.373 0 11.988c0 2.114.549 4.099 1.504 5.83L0 24l6.335-1.652A11.939 11.939 0 0 0 11.99 24C18.626 24 24 18.626 24 12.012 24 5.373 18.626 0 11.99 0zm0 21.785a9.796 9.796 0 0 1-4.994-1.365l-.357-.212-3.758.98.999-3.647-.233-.374A9.722 9.722 0 0 1 2.203 12c0-5.398 4.394-9.791 9.787-9.791 5.394 0 9.788 4.393 9.788 9.791 0 5.398-4.394 9.785-9.788 9.785z"
      ></path>
    </symbol>
  </svg>

  <div class="page-wrapper">
    <main>
      <!-- ══ INPUT SECTION ══ -->
      <section class="input-section">
        <div class="page-title-row">
          <div class="page-title-icon">
            <!-- Icon sama persis dengan yang tampil di homepage tab Game -->
            <svg
              viewBox="0 0 24 24"
              width="24"
              height="24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              set:html={icon}
            />
          </div>
          <div>
            <h1 class="page-title">Top Up {title}</h1>
            <p class="page-subtitle">
              Isi {unit}
              {title} murah, proses cepat &amp; langsung masuk
            </p>
          </div>
        </div>

        <div class="input-card">
          <label class="input-label" for="user-input">{inputLabel}</label>
          <div class="input-row">
            <div class="input-wrap" id="input-wrap">
              {inputPrefix === "+62" && <span class="input-prefix">+62</span>}
              <input
                type={inputType === "number" ? "text" : inputType}
                id="user-input"
                placeholder={inputPlaceholder}
                inputmode={inputType === "number" ? "numeric" : undefined}
                autocomplete="off"
                maxlength={isPhoneInput ? 15 : 30}
              />
            </div>
          </div>
          <p class="input-hint" id="input-hint">
            {
              isPhoneInput
                ? `Masukkan nomor HP yang terdaftar di ${title}`
                : `Masukkan ${inputLabel.toLowerCase()} Anda`
            }
          </p>
        </div>
      </section>

      <!-- ══ PRODUCTS SECTION ══ -->
      <section class="products-section" id="products-section">
        <!-- Empty state -->
        <div class="state-wrap" id="empty-state">
          <div class="state-icon">
            <!-- Selalu gamepad icon di semua page game -->
            <svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true">
              <use href="#icon-gamepad"></use>
            </svg>
          </div>
          <p class="state-title">
            {isPhoneInput ? "Masukkan nomor HP" : `Masukkan ${inputLabel}`}
          </p>
          <p class="state-desc">
            Pilihan {unit} akan muncul setelah {
              isPhoneInput ? "nomor diisi" : "ID diisi"
            }
          </p>
        </div>

        <!-- Products grid -->
        <div class="hidden" id="products-container">
          <div class="products-header">
            <div class="products-header-left">
              <div class="provider-logo" id="products-provider-logo"></div>
              <div>
                <h2 class="products-title" id="products-title">
                  Pilih {unit}
                  {title}
                </h2>
                <p class="products-count" id="products-count"></p>
              </div>
            </div>
          </div>
          <div id="products-grid"></div>
        </div>
      </section>
    </main>
  </div>

  <!-- ══ MODAL ══ -->
  <div class="modal-overlay hidden" id="modal-overlay">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-header-left">
          <div class="modal-provider-dot" id="modal-provider-dot"></div>
          <h3 class="modal-title">Konfirmasi Pesanan</h3>
        </div>
        <button class="modal-close" id="modal-close" aria-label="Tutup">
          <svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true">
            <use href="#icon-close"></use>
          </svg>
        </button>
      </div>

      <div class="modal-body">
        <div class="modal-nominal-hero">
          <div class="modal-nominal-hero__label">Item yang dibeli</div>
          <div class="modal-nominal-hero__value" id="detail-nominal">—</div>
          <div class="modal-nominal-hero__provider" id="detail-product">—</div>
        </div>

        <div class="order-card">
          <div class="order-row">
            <span class="order-label">
              <svg
                viewBox="0 0 24 24"
                width="13"
                height="13"
                aria-hidden="true"
              >
                <use href="#icon-phone"></use>
              </svg>
              {inputLabel}
            </span>
            <span class="order-value order-value--phone" id="detail-target"
              >—</span
            >
          </div>
          <div class="order-row">
            <span class="order-label">
              <svg
                viewBox="0 0 24 24"
                width="13"
                height="13"
                aria-hidden="true"
              >
                <use href="#icon-clock"></use>
              </svg>
              Keterangan
            </span>
            <span class="order-value order-value--desc" id="detail-desc">—</span
            >
          </div>
          <div class="order-row order-row--total">
            <span class="order-label order-label--total">Total Bayar</span>
            <span class="order-value order-value--price" id="detail-price"
              >—</span
            >
          </div>
        </div>

        <div class="wa-preview">
          <div class="wa-preview__header">
            <svg
              viewBox="0 0 24 24"
              fill="#25d366"
              width="14"
              height="14"
              aria-hidden="true"
            >
              <use href="#icon-wa"></use>
            </svg>
            <span>Pesan yang akan dikirim</span>
          </div>
          <div class="wa-preview__bubble" id="wa-preview-text">—</div>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn-cancel" id="btn-cancel">Batal</button>
        <button class="btn-order" id="btn-order">
          <svg
            viewBox="0 0 24 24"
            fill="currentColor"
            width="17"
            height="17"
            aria-hidden="true"
          >
            <use href="#icon-wa"></use>
          </svg>
          Chat WhatsApp Sekarang
        </button>
      </div>
    </div>
  </div>

  <script id="config" type="application/json" set:html={configData} />

  <!-- ══ FLOATING WA BUTTON ══ -->
  <div class="wa-fab-wrap" id="wa-fab-wrap">
    <a
      href={`https://wa.me/${waNumber}`}
      target="_blank"
      rel="noopener noreferrer"
      class="wa-fab"
      id="wa-fab"
      aria-label="Chat WhatsApp Admin"
    >
      <svg
        class="wa-fab__icon"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <use href="#icon-wa"></use>
      </svg>
      <span class="wa-fab__label">Butuh bantuan?</span>
    </a>
  </div>
</BaseLayout>

<style>
  /* ── Layout ── */
  main {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 48px var(--content-px) 80px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* ── Input Section ── */
  .input-section {
    background: var(--color-bg);
    border-radius: 20px;
    padding: 28px 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .page-title-row {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .page-title-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .page-title-icon svg {
    width: 24px;
    height: 24px;
    color: var(--color-text);
  }
  .page-title {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-text);
    margin: 0 0 3px;
    letter-spacing: -0.3px;
  }
  .page-subtitle {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin: 0;
  }
  .input-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .input-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
  }
  .input-row {
    display: flex;
    gap: 12px;
    align-items: stretch;
  }
  .input-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    border: 1.5px solid var(--color-border);
    border-radius: 14px;
    overflow: hidden;
    background: var(--color-bg);
    transition: border-color 0.2s;
  }
  .input-wrap:focus-within {
    border-color: var(--color-text);
  }
  .input-wrap.error {
    border-color: #e53e3e;
  }
  .input-prefix {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-muted);
    background: #f0f0f0;
    padding: 0 16px;
    height: 52px;
    display: flex;
    align-items: center;
    border-right: 1.5px solid var(--color-border);
    flex-shrink: 0;
  }
  .input-wrap input {
    flex: 1;
    height: 52px;
    padding: 0 16px;
    border: none;
    outline: none;
    font-size: 15px;
    font-weight: 500;
    color: var(--color-text);
    background: transparent;
    letter-spacing: 0.3px;
  }
  .input-wrap input::placeholder {
    color: #c4c4c4;
    font-weight: 400;
    letter-spacing: 0;
  }
  .input-hint {
    font-size: 12px;
    color: #b0b0b0;
    margin: 0;
    transition: color 0.2s;
  }
  .input-hint.success {
    color: #22863a;
  }
  .input-hint.error {
    color: #e53e3e;
  }

  /* ── Products Section ── */
  .products-section {
    background: var(--color-bg);
    border-radius: 20px;
    overflow: hidden;
    min-height: 240px;
    display: flex;
    align-items: center;
    justify-content: center;
    contain: layout style;
  }
  .state-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 56px 24px;
    text-align: center;
    gap: 10px;
    width: 100%;
  }
  .state-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 4px;
  }
  .state-icon svg {
    width: 26px;
    height: 26px;
    color: #000;
  }
  .state-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }
  .state-desc {
    font-size: 13px;
    color: var(--color-muted);
    margin: 0;
    max-width: 280px;
    line-height: 1.5;
  }

  #products-container {
    width: 100%;
    padding: 28px 28px 32px;
  }
  .products-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 24px;
  }
  .products-header-left {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .provider-logo {
    width: 40px;
    height: 40px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 900;
    color: white;
    flex-shrink: 0;
    overflow: hidden;
    background: transparent;
  }
  .provider-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .products-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 2px;
  }
  .products-count {
    font-size: 12px;
    color: var(--color-muted);
    margin: 0;
  }

  /* ── Grid (via JS innerHTML → :global) ── */
  :global(.subcategory-header) {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 16px 0 10px;
    margin-top: 8px;
  }
  :global(.subcategory-header:first-child) {
    padding-top: 0;
    margin-top: 0;
  }
  :global(.subcategory-title) {
    font-size: 12px;
    font-weight: 700;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    white-space: nowrap;
  }
  :global(.subcategory-line) {
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }
  :global(.nominals-grid) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-bottom: 8px;
  }

  :global(.nominal-btn) {
    background: #f0f0f0;
    border: 1.5px solid var(--color-border);
    border-radius: 12px;
    padding: 12px 14px;
    cursor: pointer;
    transition:
      border-color 0.15s,
      box-shadow 0.15s,
      transform 0.12s,
      background 0.15s;
    animation: cardIn 0.22s cubic-bezier(0.16, 1, 0.3, 1) both;
    display: flex;
    flex-direction: column;
    gap: 6px;
    width: 100%;
    text-align: left;
  }
  :global(.nominal-btn:hover) {
    border-color: var(--color-text);
    box-shadow: 0 3px 12px rgba(0, 0, 0, 0.08);
    transform: translateY(-1px);
    background: #fff;
  }
  :global(.nominal-btn:active) {
    transform: translateY(0);
    box-shadow: none;
  }
  :global(.nominal-btn__top) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 4px;
  }
  :global(.nominal-btn__code) {
    font-size: 10px;
    font-weight: 700;
    color: #a0a0a0;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    font-family: var(--font-mono);
    line-height: 1;
  }
  :global(.nominal-btn__badge) {
    font-size: 9px;
    font-weight: 700;
    color: var(--color-muted);
    background: var(--color-border);
    padding: 2px 6px;
    border-radius: 4px;
    letter-spacing: 0.2px;
    text-transform: uppercase;
    flex-shrink: 0;
    line-height: 1.4;
  }

  :global(.nominal-btn__value-row) {
    display: flex;
    align-items: baseline;
    gap: 4px;
    line-height: 1;
  }
  :global(.nominal-btn__value) {
    font-size: 18px;
    font-weight: 900;
    color: var(--color-text);
    letter-spacing: -0.5px;
    line-height: 1;
  }
  :global(.nominal-btn__unit) {
    font-size: 11px;
    font-weight: 600;
    color: var(--color-muted);
    line-height: 1;
  }

  :global(.nominal-btn__desc) {
    font-size: 10.5px;
    color: var(--color-muted);
    font-weight: 500;
    line-height: 1.4;
    word-break: break-word;
  }
  :global(.nominal-btn__footer) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 8px;
    border-top: 1px solid var(--color-border);
    margin-top: 2px;
  }
  :global(.nominal-btn__price-label) {
    font-size: 9px;
    font-weight: 600;
    color: #b0b0b0;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    line-height: 1;
    margin-bottom: 2px;
  }
  :global(.nominal-btn__price) {
    font-size: 13px;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.3px;
    line-height: 1;
  }
  :global(.nominal-btn__cta) {
    width: 22px;
    height: 22px;
    min-width: 22px;
    background: var(--color-text);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-bg);
    font-size: 13px;
    font-weight: 700;
    line-height: 1;
    opacity: 0;
    transform: scale(0.85);
    transition:
      opacity 0.15s,
      transform 0.15s;
  }
  :global(.nominal-btn:hover .nominal-btn__cta) {
    opacity: 1;
    transform: scale(1);
  }

  /* ── Modal ── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(10, 10, 10, 0.45);
    backdrop-filter: blur(6px);
    z-index: 1000;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    animation: fadeIn 0.2s ease;
  }
  .modal {
    background: var(--color-bg);
    width: 100%;
    max-width: 440px;
    border-radius: 24px 24px 0 0;
    overflow: hidden;
    animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 20px 16px;
    border-bottom: 1px solid var(--color-border);
  }
  .modal-header-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .modal-provider-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-border);
    flex-shrink: 0;
    transition: background 0.3s;
  }
  .modal-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }
  .modal-close {
    width: 32px;
    height: 32px;
