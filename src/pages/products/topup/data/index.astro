<script>
  (function () {
    /* ── CONFIG — baca dari <script type="application/json"> ── */
    const configEl = document.getElementById("config") as HTMLScriptElement;

    type SubCategory = {
      name: string;
      title: string;
      packages: Array<{
        code: string;
        name: string;
        desc: string;
        price: number;
      }>;
    };
    type ProviderInfo = { name: string; title: string; prefixes: string[] };

    const config: {
      wa: string;
      allProviders: ProviderInfo[];
      injectMap: Record<string, SubCategory[]>;
      voucherMap: Record<string, SubCategory[]>;
      activationCodes: Record<string, string>;
    } = JSON.parse(configEl.textContent!);

    const waNumber = config.wa;
    const providers = config.allProviders;
    const injectMap = config.injectMap;
    const voucherMap = config.voucherMap;
    const activationCodes = config.activationCodes;

    /* ── STATE ── */
    let currentProvider: ProviderInfo | null = null;
    let selectedPkg: {
      code: string;
      name: string;
      desc: string;
      price: number;
    } | null = null;
    let selectedSubCatTitle = "";
    let selectedIsVoucher = false;

    /* ── DOM ── */
    const phoneInput = document.getElementById(
      "phone-input",
    ) as HTMLInputElement;
    const inputWrap = document.getElementById("input-wrap")!;
    const providerPill = document.getElementById("provider-pill")!;
    const providerNameEl = document.getElementById("provider-name")!;
    const inputHint = document.getElementById("input-hint")!;

    const emptyState = document.getElementById("empty-state")!;
    const unknownState = document.getElementById("unknown-state")!;
    const productsContainer = document.getElementById("products-container")!;
    // products-grid-inject dan products-grid-voucher di-handle oleh renderProducts
    const productsTitleEl = document.getElementById("products-title")!;
    const productsCountEl = document.getElementById("products-count")!;
    const productsLogoEl = document.getElementById("products-provider-logo")!;
    const productsSection = document.getElementById("products-section")!;

    const modalOverlay = document.getElementById("modal-overlay")!;
    const modalClose = document.getElementById("modal-close")!;
    const btnCancel = document.getElementById("btn-cancel")!;
    const btnOrder = document.getElementById("btn-order")!;

    const detailProduct = document.getElementById("detail-product")!;
    const detailNominal = document.getElementById("detail-nominal")!;
    const detailDesc = document.getElementById("detail-desc")!;
    const detailPhone = document.getElementById("detail-phone")!;
    const detailPrice = document.getElementById("detail-price")!;

    /* ── PROVIDER DATA ── */
    const providerLogos: Record<string, string> = {
      "telkomsel-data": "/logos/telkomsel_logo.svg",
      "tri-data": "/logos/tri_logo.svg",
      "indosat-data": "/logos/indosat_logo.svg",
      "xl-data": "/logos/xl_logo.svg",
      "axis-data": "/logos/axis_logo.svg",
      "smartfren-data": "/logos/smartfren_logo.svg",
    };

    const providerColors: Record<string, string> = {
      "telkomsel-data": "linear-gradient(135deg,#e53e3e,#c53030)",
      "tri-data": "linear-gradient(135deg,#553c9a,#44337a)",
      "indosat-data": "linear-gradient(135deg,#d97706,#b45309)",
      "xl-data": "linear-gradient(135deg,#2b6cb0,#2c5282)",
      "axis-data": "linear-gradient(135deg,#276749,#22543d)",
      "smartfren-data": "linear-gradient(135deg,#e53e3e,#805ad5)",
    };

    const providerInitials: Record<string, string> = {
      "telkomsel-data": "TEL",
      "tri-data": "3",
      "indosat-data": "IM3",
      "xl-data": "XL",
      "axis-data": "AX",
      "smartfren-data": "SF",
    };

    /* ── HELPERS ── */
    // Cache formatter — hindari instansiasi ulang tiap render kartu
    const rpFormatter = new Intl.NumberFormat("id-ID", {
      style: "currency",
      currency: "IDR",
      minimumFractionDigits: 0,
    });
    const formatRp = (n: number) => rpFormatter.format(n);

    function normalizePhone(val: string): string {
      let n = val.replace(/\D/g, "");
      if (n.startsWith("62")) n = "0" + n.slice(2);
      if (n.startsWith("8")) n = "0" + n;
      return n;
    }

    // Semua prefix operator Indonesia yang valid (4 digit pertama)
    const VALID_PREFIXES = new Set([
      // Telkomsel
      "0811",
      "0812",
      "0813",
      "0821",
      "0822",
      "0823",
      "0851",
      "0852",
      "0853",
      // Indosat
      "0814",
      "0815",
      "0816",
      "0855",
      "0856",
      "0857",
      "0858",
      // XL Axiata
      "0817",
      "0818",
      "0819",
      "0859",
      "0877",
      "0878",
      // Axis
      "0831",
      "0832",
      "0833",
      "0838",
      // Tri
      "0895",
      "0896",
      "0897",
      "0898",
      "0899",
      // Smartfren
      "0881",
      "0882",
      "0883",
      "0884",
      "0885",
      "0886",
      "0887",
      "0888",
      "0889",
    ]);

    // Status validasi bertahap
    function phoneStatus(
      raw: string,
    ): "empty" | "typing" | "invalid_prefix" | "valid" {
      const n = normalizePhone(raw);
      if (!n) return "empty";
      if (n.length < 4) return "typing";
      if (!VALID_PREFIXES.has(n.slice(0, 4))) return "invalid_prefix";
      if (n.length < 10) return "typing";
      return "valid";
    }

    function detectProvider(raw: string) {
      const n = normalizePhone(raw);
      if (n.length < 5) return null;
      return providers.find((p) => p.prefixes.includes(n.slice(0, 4))) ?? null;
    }

    // Debounce helper — hindari deteksi tiap keystroke
    function debounce<T extends (...args: unknown[]) => void>(
      fn: T,
      ms: number,
    ) {
      let t: ReturnType<typeof setTimeout>;
      return (...args: Parameters<T>) => {
        clearTimeout(t);
        t = setTimeout(() => fn(...args), ms);
      };
    }

    /* ── RENDER PRODUCTS ── */
    const tabBar = document.getElementById("product-tab-bar")!;
    const tabBtnInject = document.getElementById("tab-btn-inject")!;
    const tabBtnVoucher = document.getElementById("tab-btn-voucher")!;
    const gridInject = document.getElementById("products-grid-inject")!;
    const gridVoucher = document.getElementById("products-grid-voucher")!;
    const voucherBanner = document.getElementById("voucher-info-banner")!;
    const injectBanner = document.getElementById("inject-info-banner")!;
    let activeTab: "inject" | "voucher" = "inject";

    function switchTab(tab: "inject" | "voucher") {
      activeTab = tab;
      const isVoucherTab = tab === "voucher";
      tabBtnInject.classList.toggle("active", !isVoucherTab);
      tabBtnVoucher.classList.toggle("active", isVoucherTab);
      gridInject.classList.toggle("hidden", isVoucherTab);
      gridVoucher.classList.toggle("hidden", !isVoucherTab);
      // Banner masing-masing tab
      injectBanner.classList.toggle("hidden", isVoucherTab);
      voucherBanner.classList.toggle("hidden", !isVoucherTab);
    }

    tabBtnInject.addEventListener("click", () => switchTab("inject"));
    tabBtnVoucher.addEventListener("click", () => switchTab("voucher"));

    function buildGrid(
      subCategories: SubCategory[],
      providerName: string,
      providerTitle: string,
      isVoucherTab: boolean,
      container: HTMLElement,
      noProductEl: HTMLElement,
      noProductDescEl: HTMLElement,
    ) {
      // Cek apakah provider ada di map yang sesuai
      const hasData = subCategories.length > 0;

      // Kosongkan container (kecuali elemen no-product yang sudah ada di HTML)
      // Hapus semua child kecuali no-product placeholder
      Array.from(container.children).forEach((child) => {
        if (!child.id.startsWith("no-product-")) child.remove();
      });

      if (!hasData) {
        // Tampilkan no-product untuk tab ini
        const typeLabel = isVoucherTab ? "manual" : "otomatis";
        noProductDescEl.textContent = `Maaf, belum ada paket data ${typeLabel} untuk nomor ${providerTitle}`;
        noProductEl.classList.remove("hidden");
        return 0;
      }

      noProductEl.classList.add("hidden");

      const frag = document.createDocumentFragment();
      let index = 0;

      subCategories.forEach((subCat) => {
        const headerEl = document.createElement("div");
        headerEl.className = "subcategory-header";
        headerEl.innerHTML = `<span class="subcategory-title">${subCat.title}</span><span class="subcategory-line"></span>`;
        frag.appendChild(headerEl);

        const gridEl = document.createElement("div");
        gridEl.className = "nominals-grid";

        subCat.packages.forEach((pkg) => {
          const btn = document.createElement("button");
          btn.className = "nominal-btn";
          btn.style.animationDelay = `${index * 20}ms`;
          const badgeClass = isVoucherTab
            ? "nominal-btn__badge nominal-btn__badge--voucher"
            : "nominal-btn__badge";
          const badgeLabel = isVoucherTab ? "Voucher" : "Data";
          btn.innerHTML = `
            <div class="nominal-btn__top">
              <span class="nominal-btn__code">${pkg.code}</span>
              <span class="${badgeClass}">${badgeLabel}</span>
            </div>
            <div class="nominal-btn__value">${pkg.name}</div>
            <span class="nominal-btn__desc">${pkg.desc}</span>
            <div class="nominal-btn__footer">
              <div>
                <div class="nominal-btn__price-label">Harga</div>
                <div class="nominal-btn__price">${formatRp(pkg.price)}</div>
              </div>
              <div class="nominal-btn__cta">›</div>
            </div>`;
          btn.addEventListener("click", () =>
            openModal(
              pkg,
              { name: providerName, title: providerTitle, prefixes: [] },
              subCat.title,
              isVoucherTab,
            ),
          );
          gridEl.appendChild(btn);
          index++;
        });

        frag.appendChild(gridEl);
      });

      container.appendChild(frag);
      return subCategories.reduce((s, sc) => s + sc.packages.length, 0);
    }

    function renderProducts(provider: ProviderInfo) {
      const injectSubs = injectMap[provider.name] ?? [];
      const voucherSubs = voucherMap[provider.name] ?? [];
      const totalPkgs =
        injectSubs.reduce((s, sc) => s + sc.packages.length, 0) +
        voucherSubs.reduce((s, sc) => s + sc.packages.length, 0);

      productsTitleEl.textContent = `Paket Data ${provider.title}`;
      productsCountEl.textContent = `${totalPkgs} pilihan tersedia`;

      // Update kode aktivasi di banner voucher sesuai operator
      const activationCode = activationCodes[provider.name] ?? "*KODEAKTIVASI#";
      document.getElementById("voucher-activation-code")!.textContent =
        activationCode;

      // Tab bar selalu tampil
      tabBar.classList.remove("hidden");
      injectBanner.classList.remove("hidden");
      voucherBanner.classList.add("hidden");

      // Reset ke tab inject saat provider berganti
      switchTab("inject");

      // Logo
      const logoUrl = providerLogos[provider.name];
      productsLogoEl.innerHTML = "";
      productsLogoEl.style.cssText =
        "background:transparent;border:none;border-radius:0";
      if (logoUrl) {
        const img = document.createElement("img");
        img.src = logoUrl;
        img.alt = provider.title;
        img.onerror = () => {
          productsLogoEl.textContent =
            providerInitials[provider.name] ??
            provider.title.slice(0, 3).toUpperCase();
          productsLogoEl.style.cssText = `background:${providerColors[provider.name] ?? "linear-gradient(135deg,#0a0a0a,#333)"};border-radius:14px;border:none`;
        };
        productsLogoEl.appendChild(img);
      } else {
        productsLogoEl.textContent =
          providerInitials[provider.name] ??
          provider.title.slice(0, 3).toUpperCase();
        productsLogoEl.style.cssText = `background:${providerColors[provider.name] ?? "linear-gradient(135deg,#0a0a0a,#333)"};border-radius:14px;border:none`;
      }

      // Render dua grid — masing-masing tampilkan no-product jika kosong
      const noProductInject = document.getElementById("no-product-inject")!;
      const noProductVoucher = document.getElementById("no-product-voucher")!;
      const noProductInjectDesc = document.getElementById(
        "no-product-inject-desc",
      )!;
      const noProductVoucherDesc = document.getElementById(
        "no-product-voucher-desc",
      )!;

      buildGrid(
        injectSubs,
        provider.name,
        provider.title,
        false,
        gridInject,
        noProductInject,
        noProductInjectDesc,
      );
      buildGrid(
        voucherSubs,
        provider.name,
        provider.title,
        true,
        gridVoucher,
        noProductVoucher,
        noProductVoucherDesc,
      );
    }

    /* ── UI STATE ── */
    const noProductState = document.getElementById("no-product-state")!;
    const noProductDesc = document.getElementById("no-product-desc")!;

    function setMode(mode: "empty" | "unknown" | "no_product" | "products") {
      productsSection.style.alignItems =
        mode === "products" ? "flex-start" : "center";
      emptyState.classList.toggle("hidden", mode !== "empty");
      unknownState.classList.toggle("hidden", mode !== "unknown");
      noProductState.classList.toggle("hidden", mode !== "no_product");
      productsContainer.classList.toggle("hidden", mode !== "products");
    }

    function updateUI() {
      const raw = phoneInput.value.trim();

      if (!raw) {
        currentProvider = null;
        providerPill.classList.remove("detected");
        providerNameEl.textContent = "Operator";
        inputHint.textContent = "Ketik nomor handphone";
        inputHint.className = "input-hint";
        inputWrap.classList.remove("error");
        setMode("empty");
        return;
      }

      const status = phoneStatus(raw);

      // Masih mengetik
      if (status === "typing") {
        providerPill.classList.remove("detected");
        providerNameEl.textContent = "Operator";
        inputHint.textContent = "Lanjutkan mengetik nomor HP Anda…";
        inputHint.className = "input-hint";
        inputWrap.classList.remove("error");
        setMode("empty");
        return;
      }

      // Prefix tidak dikenal sama sekali (bukan operator Indonesia)
      if (status === "invalid_prefix") {
        currentProvider = null;
        providerPill.classList.remove("detected");
        providerNameEl.textContent = "Operator";
        inputHint.textContent =
          "Nomor tidak dikenali — pastikan nomor HP Indonesia yang valid";
        inputHint.className = "input-hint error";
        inputWrap.classList.add("error");
        setMode("unknown");
        return;
      }

      // Prefix valid — cek apakah ada di daftar provider paket data
      const provider = detectProvider(raw);
      const n = normalizePhone(raw);

      if (provider) {
        // Operator ada & punya paket data
        providerPill.classList.add("detected");
        providerNameEl.textContent = provider.title;
        inputHint.textContent = `✓ Terdeteksi sebagai nomor ${provider.title}`;
        inputHint.className = "input-hint success";
        inputWrap.classList.remove("error");

        if (currentProvider?.name !== provider.name) {
          currentProvider = provider;
          setMode("products");
          renderProducts(provider);
        } else {
          setMode("products");
        }
      } else {
        // Prefix valid tapi operator tidak punya paket data di sistem
        // Cari nama operator dari VALID_PREFIXES untuk pesan yang informatif
        const prefix = n.slice(0, 4);
        const operatorName = getOperatorNameByPrefix(prefix);

        currentProvider = null;
        providerPill.classList.remove("detected");
        providerNameEl.textContent = operatorName ?? "Operator";
        if (operatorName) {
          providerPill.classList.add("detected");
        }
        inputHint.textContent = operatorName
          ? `Nomor terdeteksi sebagai ${operatorName}`
          : "Operator tidak dikenali";
        inputHint.className = "input-hint";
        inputWrap.classList.remove("error");
        noProductDesc.textContent = operatorName
          ? `Maaf, belum ada paket data untuk nomor ${operatorName}`
          : "Maaf, belum ada paket data untuk operator ini";
        setMode("no_product");
      }
    }

    // Petakan prefix → nama operator (untuk pesan no_product yang informatif)
    function getOperatorNameByPrefix(prefix: string): string | null {
      const map: Record<string, string> = {
        "0811": "Telkomsel",
        "0812": "Telkomsel",
        "0813": "Telkomsel",
        "0821": "Telkomsel",
        "0822": "Telkomsel",
        "0823": "Telkomsel",
        "0851": "Telkomsel",
        "0852": "Telkomsel",
        "0853": "Telkomsel",
        "0814": "Indosat",
        "0815": "Indosat",
        "0816": "Indosat",
        "0855": "Indosat",
        "0856": "Indosat",
        "0857": "Indosat",
        "0858": "Indosat",
        "0817": "XL",
        "0818": "XL",
        "0819": "XL",
        "0859": "XL",
        "0877": "XL",
        "0878": "XL",
        "0831": "Axis",
        "0832": "Axis",
        "0833": "Axis",
        "0838": "Axis",
        "0895": "Tri",
        "0896": "Tri",
        "0897": "Tri",
        "0898": "Tri",
        "0899": "Tri",
        "0881": "Smartfren",
        "0882": "Smartfren",
        "0883": "Smartfren",
        "0884": "Smartfren",
        "0885": "Smartfren",
        "0886": "Smartfren",
        "0887": "Smartfren",
        "0888": "Smartfren",
        "0889": "Smartfren",
      };
      return map[prefix] ?? null;
    }

    /* ── MODAL ── */
    const voucherNotice = document.getElementById("voucher-notice")!;

    function openModal(
      pkg: { code: string; name: string; desc: string; price: number },
      provider: ProviderInfo,
      subCatTitle: string,
      isVoucher: boolean = false,
    ) {
      const phone = normalizePhone(phoneInput.value.trim());
      if (phone.length < 10) {
        inputWrap.classList.add("error");
        inputHint.textContent = "Masukkan nomor HP yang valid terlebih dahulu!";
        inputHint.className = "input-hint error";
        phoneInput.focus();
        return;
      }

      selectedPkg = pkg;
      selectedSubCatTitle = subCatTitle;
      selectedIsVoucher = isVoucher;

      detailProduct.textContent = `${subCatTitle} — ${pkg.desc}`;
      detailNominal.textContent = pkg.name;
      detailDesc.textContent = pkg.desc;
      detailPhone.textContent = `+62 ${phone.slice(1)}`;
      detailPrice.textContent = formatRp(pkg.price);

      // Tampilkan/sembunyikan banner voucher
      voucherNotice.classList.toggle("hidden", !isVoucher);

      const colorMap: Record<string, string> = {
        "telkomsel-data": "#e53e3e",
        "tri-data": "#553c9a",
        "indosat-data": "#d97706",
        "xl-data": "#2b6cb0",
        "axis-data": "#276749",
        "smartfren-data": "#805ad5",
      };
      document.getElementById("modal-provider-dot")!.style.background =
        colorMap[provider.name] ?? "#0a0a0a";

      document.getElementById("wa-preview-text")!.textContent =
        `Halo min! 👋\n\n` +
        `Saya mau beli *Paket Data ${provider.title} ${pkg.name}*, ` +
        `kirim ke nomor *${phone}* ya!\n\n` +
        `Detail:\n• Produk: ${pkg.desc}\n• Harga: ${formatRp(pkg.price)}\n\n` +
        `Mohon diproses, terima kasih 🙏`;

      modalOverlay.classList.remove("hidden");
      document.body.style.overflow = "hidden";
    }

    function closeModal() {
      modalOverlay.classList.add("hidden");
      document.body.style.overflow = "";
      selectedPkg = null;
      selectedIsVoucher = false;
    }

    /* ── WHATSAPP ── */
    function sendOrder() {
      if (!selectedPkg || !currentProvider) return;
      const phone = normalizePhone(phoneInput.value.trim());
      const msg = encodeURIComponent(
        `Halo min! 👋\n\n` +
          `Saya mau beli *Paket Data ${currentProvider.title} ${selectedPkg.name}*, ` +
          `kirim ke nomor *${phone}* ya!\n\n` +
          `Detail:\n• Produk: ${selectedPkg.desc}\n• Harga: ${formatRp(selectedPkg.price)}\n\n` +
          `Mohon diproses, terima kasih 🙏`,
      );
      window.open(`https://wa.me/${waNumber}?text=${msg}`, "_blank");
      closeModal();
    }

    /* ── EVENTS ── */
    const debouncedUpdateUI = debounce(updateUI, 120);
    phoneInput.addEventListener("input", debouncedUpdateUI, { passive: true });

    // Hanya angka yang diizinkan — blokir keydown & sanitasi paste
    phoneInput.addEventListener("keydown", (e) => {
      const allowed = [
        "Backspace",
        "Delete",
        "ArrowLeft",
        "ArrowRight",
        "ArrowUp",
        "ArrowDown",
        "Tab",
        "Enter",
        "Home",
        "End",
      ];
      if (allowed.includes(e.key)) return;
      if (!/^\d$/.test(e.key)) e.preventDefault();
    });
    phoneInput.addEventListener("paste", (e) => {
      e.preventDefault();
      const text =
        (e.clipboardData ?? (window as any).clipboardData)?.getData("text") ??
        "";
      const digits = text.replace(/\D/g, "");
      document.execCommand("insertText", false, digits);
    });
    modalClose.addEventListener("click", closeModal);
    btnCancel.addEventListener("click", closeModal);
    btnOrder.addEventListener("click", sendOrder);
    modalOverlay.addEventListener("click", (e) => {
      if (e.target === modalOverlay) closeModal();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeModal();
    });
  })();
</script>

<script>
  /* ── FLOATING WA BUTTON — drag + collapse ── */
  (function () {
    const wrap = document.getElementById("wa-fab-wrap") as HTMLElement;
    const fab = document.getElementById("wa-fab") as HTMLAnchorElement;
    if (!wrap || !fab) return;

    /* ── COLLAPSE ON SCROLL (desktop only) ── */
    let collapsed = false;
    window.addEventListener(
      "scroll",
      () => {
        if (window.innerWidth <= 480) return;
        const y = window.scrollY;
        if (y > 80 && !collapsed) {
          collapsed = true;
          wrap.classList.add("collapsed");
        } else if (y <= 80 && collapsed) {
          collapsed = false;
          wrap.classList.remove("collapsed");
        }
      },
      { passive: true },
    );

    /* ── DRAG TO MOVE ── */
    let isDragging = false;
    let didDrag = false;
    let startX = 0,
      startY = 0;
    let origLeft = 0,
      origTop = 0;

    function getPos() {
      const rect = wrap.getBoundingClientRect();
      return { left: rect.left, top: rect.top };
    }

    function startDrag(clientX: number, clientY: number) {
      isDragging = true;
      didDrag = false;
      const pos = getPos();
      origLeft = pos.left;
      origTop = pos.top;
      startX = clientX;
      startY = clientY;
      wrap.style.right = "auto";
      wrap.style.bottom = "auto";
      wrap.style.left = origLeft + "px";
      wrap.style.top = origTop + "px";
      wrap.classList.add("dragging");
    }

    function moveDrag(clientX: number, clientY: number) {
      if (!isDragging) return;
      const dx = clientX - startX;
      const dy = clientY - startY;
      if (Math.abs(dx) > 3 || Math.abs(dy) > 3) didDrag = true;
      const newLeft = Math.max(
        8,
        Math.min(window.innerWidth - wrap.offsetWidth - 8, origLeft + dx),
      );
      const newTop = Math.max(
        8,
        Math.min(window.innerHeight - wrap.offsetHeight - 8, origTop + dy),
      );
      wrap.style.left = newLeft + "px";
      wrap.style.top = newTop + "px";
    }

    function endDrag(e: Event) {
      if (!isDragging) return;
      isDragging = false;
      wrap.classList.remove("dragging");
      if (!didDrag) return;
      const rect = wrap.getBoundingClientRect();
      const midX = rect.left + rect.width / 2;
      const snapLeft = midX < window.innerWidth / 2;
      const margin = 20;
      wrap.style.left = "auto";
      wrap.style.right = "auto";
      wrap.style.top = rect.top + "px";
      wrap.style.bottom = "auto";
      if (snapLeft) {
        wrap.style.left = margin + "px";
      } else {
        wrap.style.right = margin + "px";
      }
      e.preventDefault();
    }

    wrap.addEventListener("mousedown", (e) => startDrag(e.clientX, e.clientY));
    window.addEventListener("mousemove", (e) => moveDrag(e.clientX, e.clientY));
    window.addEventListener("mouseup", (e) => endDrag(e));

    wrap.addEventListener(
      "touchstart",
      (e) => {
        const t = e.touches[0];
        startDrag(t.clientX, t.clientY);
      },
      { passive: true },
    );
    window.addEventListener(
      "touchmove",
      (e) => {
        const t = e.touches[0];
        moveDrag(t.clientX, t.clientY);
      },
      { passive: true },
    );
    window.addEventListener("touchend", (e) => endDrag(e));
  })();
</script>

<script>
  /* ── LIVE PRICING — Digiflazz via Cloudflare Worker ── */
  (async () => {
    const WORKER_URL = "https://oltpay.husnovember21.workers.dev";

    // Mapping provider name → Digiflazz category + brand
    // Sesuaikan brand name jika berbeda di akun Digiflazz Anda
    const BRAND_MAP: Record<string, { category: string; brand: string }> = {
      "telkomsel-data": { category: "Data", brand: "Telkomsel" },
      "indosat-data": { category: "Data", brand: "Indosat" },
      "xl-data": { category: "Data", brand: "XL" },
      "tri-data": { category: "Data", brand: "Three" },
      "axis-data": { category: "Data", brand: "AXIS" },
      "smartfren-data": { category: "Data", brand: "Smartfren" },
    };

    // Cache harga per provider agar tidak fetch ulang saat ganti operator
    const priceCache = new Map<string, Map<string, any>>();

    // Fetch harga live dari Worker untuk satu provider
    async function fetchLive(
      providerName: string,
    ): Promise<Map<string, any> | null> {
      if (priceCache.has(providerName)) return priceCache.get(providerName)!;

      const mapping = BRAND_MAP[providerName];
      if (!mapping) return null;

      try {
        const res = await fetch(WORKER_URL, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            type: "prepaid",
            category: mapping.category,
            brand: mapping.brand,
          }),
        });
        const data = await res.json();
        if (data.result !== "success") return null;

        const map = new Map<string, any>(
          data.message.map((item: any) => [item.buyer_sku_code, item]),
        );
        priceCache.set(providerName, map);
        return map;
      } catch {
        return null;
      }
    }

    // Update harga di semua .nominal-btn__price dalam satu container grid
    function patchGrid(container: HTMLElement, liveMap: Map<string, any>) {
      const btns =
        container.querySelectorAll<HTMLButtonElement>(".nominal-btn");
      btns.forEach((btn) => {
        const code = btn
          .querySelector(".nominal-btn__code")
          ?.textContent?.trim();
        if (!code) return;
        const live = liveMap.get(code);
        if (!live) return;

        // Update harga display
        const priceEl = btn.querySelector(".nominal-btn__price");
        if (priceEl) priceEl.textContent = live.harga_jual_display;

        // Simpan harga live ke dataset untuk dipakai openModal via event
        btn.dataset.liveHarga = String(live.harga_jual);

        // Redup dan disable jika tidak tersedia
        if (!live.tersedia) {
          btn.disabled = true;
          btn.style.opacity = "0.45";
          btn.style.cursor = "not-allowed";
          const badgeEl = btn.querySelector<HTMLElement>(".nominal-btn__badge");
          if (badgeEl) {
            badgeEl.textContent = "Habis";
            badgeEl.style.background = "#fee2e2";
            badgeEl.style.color = "#dc2626";
          }
        }
      });
    }

    // Patch configData di memory (injectMap & voucherMap) dengan harga live
    // Supaya openModal() yang membaca pkg.price langsung pakai harga live
    function patchConfigPrices(
      cfg: any,
      providerName: string,
      liveMap: Map<string, any>,
    ) {
      // Patch injectMap
      if (cfg.injectMap?.[providerName]) {
        cfg.injectMap[providerName] = cfg.injectMap[providerName].map(
          (sub: any) => ({
            ...sub,
            packages: sub.packages.map((pkg: any) => {
              const live = liveMap.get(pkg.code);
              return live ? { ...pkg, price: live.harga_jual } : pkg;
            }),
          }),
        );
      }
      // Patch voucherMap
      if (cfg.voucherMap?.[providerName]) {
        cfg.voucherMap[providerName] = cfg.voucherMap[providerName].map(
          (sub: any) => ({
            ...sub,
            packages: sub.packages.map((pkg: any) => {
              const live = liveMap.get(pkg.code);
              return live ? { ...pkg, price: live.harga_jual } : pkg;
            }),
          }),
        );
      }

      // Update script#config supaya openModal baca harga live
      const configEl = document.getElementById(
        "config",
      ) as HTMLScriptElement | null;
      if (configEl) configEl.textContent = JSON.stringify(cfg);
    }

    // Observer: pantau kapan products-grid-inject / products-grid-voucher berubah
    // (karena buildGrid() dipanggil setiap ganti operator)
    let currentProvider: string | null = null;

    const gridInject = document.getElementById("products-grid-inject");
    const gridVoucher = document.getElementById("products-grid-voucher");

    // Baca cfg awal
    let cfg: any;
    try {
      cfg = JSON.parse(
        (document.getElementById("config") as HTMLScriptElement).textContent!,
      );
    } catch {
      return;
    }

    // MutationObserver: deteksi kapan grid di-render ulang (ganti operator)
    const observer = new MutationObserver(async () => {
      // Deteksi provider aktif dari judul produk
      const titleEl = document.getElementById("products-title");
      if (!titleEl) return;

      const titleText = titleEl.textContent ?? "";

      // Map judul → provider name
      const titleToProvider: Record<string, string> = {
        Telkomsel: "telkomsel-data",
        Indosat: "indosat-data",
        XL: "xl-data",
        Tri: "tri-data",
        AXIS: "axis-data",
        Axis: "axis-data",
        Smartfren: "smartfren-data",
      };

      let detectedProvider: string | null = null;
      for (const [keyword, pName] of Object.entries(titleToProvider)) {
        if (titleText.includes(keyword)) {
          detectedProvider = pName;
          break;
        }
      }

      if (!detectedProvider || detectedProvider === currentProvider) return;
      currentProvider = detectedProvider;

      // Fetch harga live
      const liveMap = await fetchLive(detectedProvider);
      if (!liveMap) return;

      // Patch config di memory
      patchConfigPrices(cfg, detectedProvider, liveMap);

      // Patch tampilan grid
      if (gridInject) patchGrid(gridInject, liveMap);
      if (gridVoucher) patchGrid(gridVoucher, liveMap);
    });

    // Observe perubahan di products-grid-inject (trigger saat operator berubah)
    if (gridInject) {
      observer.observe(gridInject, { childList: true, subtree: true });
    }
  })();
</script>