  /* ══ FLOATING WA BUTTON ══ */
  .wa-fab-wrap {
    position: fixed;
    bottom: 28px;
    right: 24px;
    z-index: 900;
    animation: fabIn 0.5s 1.5s cubic-bezier(0.16, 1, 0.3, 1) both;
    touch-action: none;
    user-select: none;
    will-change: transform;
  }

  @keyframes fabIn {
    from {
      opacity: 0;
      transform: translateY(16px) scale(0.9);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .wa-fab {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #25d366;
    color: #fff;
    text-decoration: none;
    border-radius: 50px;
    padding: 13px 20px 13px 15px;
    box-shadow:
      0 4px 20px rgba(37, 211, 102, 0.4),
      0 2px 8px rgba(0, 0, 0, 0.12);
    font-size: 13px;
    font-weight: 700;
    white-space: nowrap;
    transition:
      background 0.2s ease,
      box-shadow 0.2s ease,
      border-radius 0.35s cubic-bezier(0.4, 0, 0.2, 1),
      padding 0.35s cubic-bezier(0.4, 0, 0.2, 1),
      gap 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .wa-fab:hover {
    background: #1dba58;
    box-shadow:
      0 8px 28px rgba(37, 211, 102, 0.45),
      0 4px 12px rgba(0, 0, 0, 0.14);
  }

  .wa-fab__icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .wa-fab__label {
    display: inline-block;
    max-width: 160px;
    overflow: hidden;
    opacity: 1;
    transition:
      max-width 0.35s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.2s ease,
      margin 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    line-height: 1;
  }

  .wa-fab-wrap.collapsed .wa-fab {
    border-radius: 50%;
    padding: 15px;
    gap: 0;
  }
  .wa-fab-wrap.collapsed .wa-fab__label {
    max-width: 0;
    opacity: 0;
    margin: 0;
  }
  .wa-fab-wrap.dragging {
    transition: none;
    cursor: grabbing;
  }

  .wa-fab-wrap.dragging .wa-fab {
    opacity: 0.9;
    transform: scale(1.06);
    box-shadow:
      0 12px 32px rgba(37, 211, 102, 0.45),
      0 6px 16px rgba(0, 0, 0, 0.18);
  }

  @media (max-width: 480px) {
