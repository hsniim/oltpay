      width: 52px;
      height: 52px;
      padding: 0 !important;
      border-radius: 50% !important;
      justify-content: center;
      gap: 0 !important;
    }
    .wa-fab__label {
      display: none !important;
    }
  }

  /* ══ ANIMATIONS ══ */
  @keyframes fadeIn {
    from {
