  }

  .modal-footer {
    padding: 12px 20px 20px;
    display: flex;
    gap: 8px;
  }

  .btn-cancel {
    height: 46px;
    padding: 0 18px;
    border: 1.5px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-bg);
