</style>

<script>
  (function () {
    // ── CONFIG ──────────────────────────────────────────────────────────────
    const cfg: {
      wa: string;
      name: string;
      title: string;
      inputLabel: string;
      isPhoneInput: boolean;
      isNumericInput: boolean;
      accent: string;
      badgeLabel: string;
      packages: Array<{
        code: string;
        name: string;
        desc: string;
        price: number;
      }>;
    } = JSON.parse(
      (document.getElementById("config") as HTMLScriptElement).textContent!,
    );

    const {
      wa: waNumber,
      title: brandTitle,
      isPhoneInput,
      isNumericInput,
      accent,
      badgeLabel,
      packages,
    } = cfg;

    // ── STATE ───────────────────────────────────────────────────────────────
    let selectedPkg: (typeof packages)[0] | null = null;

    // ── DOM REFS ────────────────────────────────────────────────────────────
    const $ = (id: string) => document.getElementById(id)!;
    const userInput = $("user-input") as HTMLInputElement;
    const inputWrap = $("input-wrap");
    const inputHint = $("input-hint");
    const emptyState = $("empty-state");
    const productsSection = $("products-section");
    const productsContainer = $("products-container");
    const productsGrid = $("products-grid");
    const productsTitleEl = $("products-title");
    const productsCountEl = $("products-count");
    const productsLogoEl = $("products-provider-logo");
    const modalOverlay = $("modal-overlay");
    const detailNominal = $("detail-nominal");
    const detailProduct = $("detail-product");
    const detailDesc = $("detail-desc");
    const detailTarget = $("detail-target");
    const detailPrice = $("detail-price");
    const waPreviewText = $("wa-preview-text");

    // ── HELPERS ─────────────────────────────────────────────────────────────
    const rpFmt = new Intl.NumberFormat("id-ID", {
      style: "currency",
      currency: "IDR",
      minimumFractionDigits: 0,
    });
    const formatRp = (n: number) => rpFmt.format(n);

    // Normalisasi → selalu format 08xx...
    function normalizePhone(val: string) {
      let n = val.replace(/\D/g, "");
      if (n.startsWith("62")) n = "0" + n.slice(2);
      if (n.startsWith("8")) n = "0" + n;
      return n;
    }

    // Semua prefix operator Indonesia yang valid (4 digit pertama setelah 0)
    const VALID_PREFIXES = new Set([
      // Telkomsel
      "0811",
      "0812",
      "0813",
      "0821",
      "0822",
      "0823",
      "0851",
      "0852",
      "0853",
      // Indosat
      "0814",
      "0815",
      "0816",
      "0855",
      "0856",
      "0857",
      "0858",
      // XL Axiata
      "0817",
      "0818",
      "0819",
      "0859",
      "0877",
      "0878",
      // Axis
      "0831",
      "0832",
      "0833",
      "0838",
      // Tri
      "0895",
      "0896",
      "0897",
      "0898",
      "0899",
      // Smartfren
      "0881",
      "0882",
      "0883",
      "0884",
      "0885",
      "0886",
      "0887",
      "0888",
      "0889",
      // Telkom (PSTN/FWA — jarang, tapi valid)
      "0820",
      "0840",
    ]);

    // Cek apakah nomor punya prefix operator yang dikenal
    function isValidIndonesianPhone(normalized: string): boolean {
      if (normalized.length < 10 || normalized.length > 13) return false;
      return VALID_PREFIXES.has(normalized.slice(0, 4));
    }

    // Status validasi nomor — untuk feedback bertahap ke user
    function phoneStatus(
      raw: string,
    ): "empty" | "typing" | "invalid_prefix" | "valid" {
      const n = normalizePhone(raw);
      if (!n) return "empty";
      if (n.length < 7) return "typing";
      // Cukup 4 digit pertama untuk cek prefix
      if (n.length >= 4 && !VALID_PREFIXES.has(n.slice(0, 4)))
        return "invalid_prefix";
      if (n.length < 10) return "typing";
      return "valid";
    }

    function debounce<T extends (...a: unknown[]) => void>(fn: T, ms: number) {
      let t: ReturnType<typeof setTimeout>;
      return (...a: Parameters<T>) => {
        clearTimeout(t);
        t = setTimeout(() => fn(...a), ms);
      };
    }

    // Validasi final sebelum buka modal
    function isInputValid(raw: string) {
      if (isPhoneInput) return phoneStatus(raw) === "valid";
      return nonPhoneStatus(raw) === "valid";
    }

    // Status validasi bertahap untuk non-phone input
    function nonPhoneStatus(
      raw: string,
    ): "empty" | "typing" | "invalid" | "valid" {
      const val = raw.trim();
      if (!val) return "empty";
      if (isNumericInput) {
        // PLN token: nomor meter 11–12 digit
        // Maxim: ID driver minimal 5 digit
        const minLen = cfg.name === "plntoken" ? 11 : 5;
        const maxLen = cfg.name === "plntoken" ? 12 : 20;
        if (!/^\d+$/.test(val)) return "invalid";
        if (val.length < minLen) return "typing";
        if (val.length > maxLen) return "invalid";
        return "valid";
      }
      // Google Play gift card: format GPA.XXXX-XXXX-XXXX atau kode 15-20 karakter alfanumerik
      if (cfg.name === "gplay") {
        if (val.length < 15) return "typing";
        if (val.length > 25) return "invalid";
        return "valid";
      }
      // Teks bebas lainnya: minimal 4 karakter
      if (val.length < 4) return "typing";
      return "valid";
    }

    // ── RENDER (sekali saat load) ────────────────────────────────────────────
    function initProducts() {
      productsTitleEl.textContent = `Pilih Nominal ${brandTitle}`;
      productsCountEl.textContent = `${packages.length} pilihan tersedia`;

      // Provider dot warna
      ($("modal-provider-dot") as HTMLElement).style.background = accent;

      // Logo: coba load dari /logos/{name}_logo.svg, fallback ke inisial berwarna
      const img = document.createElement("img");
      img.src = `/logos/${cfg.name}_logo.svg`;
      img.alt = brandTitle;
      img.onload = () => {
        productsLogoEl.style.cssText =
          "background:transparent;border:none;border-radius:0";
        productsLogoEl.innerHTML = "";
        productsLogoEl.appendChild(img);
      };
      img.onerror = () => {
        productsLogoEl.textContent = brandTitle.slice(0, 2).toUpperCase();
        productsLogoEl.style.cssText = `background:${accent};border-radius:14px;border:none`;
      };

      // Render grid nominal
      const frag = document.createDocumentFragment();
      const header = document.createElement("div");
      header.className = "subcategory-header";
      header.innerHTML = `<span class="subcategory-title">Nominal ${brandTitle}</span><span class="subcategory-line"></span>`;
      frag.appendChild(header);

      const grid = document.createElement("div");
      grid.className = "nominals-grid";

      packages.forEach((pkg, i) => {
        const btn = document.createElement("button");
        btn.className = "nominal-btn";
        btn.style.animationDelay = `${i * 20}ms`;
        btn.innerHTML = `
          <div class="nominal-btn__top">
            <span class="nominal-btn__code">${pkg.code}</span>
            <span class="nominal-btn__badge">${badgeLabel}</span>
          </div>
          <div class="nominal-btn__value">
            <span class="nominal-btn__value-prefix">Rp</span>${pkg.name}
          </div>
          <span class="nominal-btn__desc">${pkg.desc}</span>
          <div class="nominal-btn__footer">
            <div>
              <div class="nominal-btn__price-label">Harga</div>
              <div class="nominal-btn__price">${formatRp(pkg.price)}</div>
            </div>
            <div class="nominal-btn__cta">›</div>
          </div>`;
        btn.addEventListener("click", () => openModal(pkg));
        grid.appendChild(btn);
      });

      frag.appendChild(grid);
      productsGrid.innerHTML = "";
      productsGrid.appendChild(frag);
    }

    // ── UI STATE ─────────────────────────────────────────────────────────────
    function setMode(mode: "empty" | "products") {
      productsSection.style.alignItems =
        mode === "products" ? "flex-start" : "center";
      emptyState.classList.toggle("hidden", mode !== "empty");
      productsContainer.classList.toggle("hidden", mode !== "products");
    }

    // ── INPUT HANDLER ────────────────────────────────────────────────────────
    function updateUI() {
      const raw = userInput.value.trim();

      if (isPhoneInput) {
        const status = phoneStatus(raw);
        if (status === "empty") {
          inputHint.textContent = `Masukkan nomor HP yang terdaftar di ${brandTitle}`;
          inputHint.className = "input-hint";
          inputWrap.classList.remove("error");
          setMode("empty");
        } else if (status === "typing") {
          inputHint.textContent = "Lanjutkan mengetik nomor HP Anda…";
          inputHint.className = "input-hint";
          inputWrap.classList.remove("error");
          setMode("empty");
        } else if (status === "invalid_prefix") {
          inputHint.textContent =
            "Nomor tidak dikenali — pastikan nomor HP Indonesia yang valid";
          inputHint.className = "input-hint error";
          inputWrap.classList.add("error");
          setMode("empty");
        } else {
          // valid
          const display = `+62 ${normalizePhone(raw).slice(1)}`;
          inputHint.textContent = `✓ ${display} siap diisi ${brandTitle}`;
          inputHint.className = "input-hint success";
          inputWrap.classList.remove("error");
          setMode("products");
        }
        return;
      }

      // Non-phone input (PLN, Maxim, Google Play, dll)
      const status = nonPhoneStatus(raw);
      if (status === "empty") {
        inputHint.textContent = `Masukkan ${cfg.inputLabel.toLowerCase()} Anda`;
        inputHint.className = "input-hint";
        inputWrap.classList.remove("error");
        setMode("empty");
        return;
      }
      if (status === "typing") {
        // Pesan typing spesifik per brand
        let hint = "Lanjutkan mengisi data…";
        if (cfg.name === "plntoken") {
          hint = `Nomor meter PLN harus 11–12 digit (sudah ${raw.trim().length} digit)`;
        } else if (cfg.name === "maximdriv") {
          hint = `ID Maxim harus minimal 5 digit (sudah ${raw.trim().length} digit)`;
        } else if (cfg.name === "gplay") {
          hint = `Kode Gift Card minimal 15 karakter (sudah ${raw.trim().length} karakter)`;
        }
        inputHint.textContent = hint;
        inputHint.className = "input-hint";
        inputWrap.classList.remove("error");
        setMode("empty");
        return;
      }
      if (status === "invalid") {
        let hint = "Format tidak valid — periksa kembali";
        if (cfg.name === "plntoken") {
          hint = `Nomor meter PLN harus 11–12 digit angka`;
        } else if (cfg.name === "gplay") {
          hint = "Kode Gift Card terlalu panjang — periksa kembali";
        }
        inputHint.textContent = hint;
        inputHint.className = "input-hint error";
        inputWrap.classList.add("error");
        setMode("empty");
        return;
      }
      // valid
      inputHint.textContent = `✓ ${raw.trim()} siap di-top up`;
      inputHint.className = "input-hint success";
      inputWrap.classList.remove("error");
      setMode("products");
    }

    // ── MODAL ────────────────────────────────────────────────────────────────
    function openModal(pkg: (typeof packages)[0]) {
      const raw = userInput.value.trim();
      if (!isInputValid(raw)) {
        inputWrap.classList.add("error");
        inputHint.textContent = `Isi ${cfg.inputLabel.toLowerCase()} yang valid terlebih dahulu!`;
        inputHint.className = "input-hint error";
        userInput.focus();
        return;
      }
      selectedPkg = pkg;

      const display = isPhoneInput
        ? `+62 ${normalizePhone(raw).slice(1)}`
        : raw;

      detailNominal.textContent = `Rp${pkg.name}`;
      detailProduct.textContent = `${brandTitle} — ${pkg.desc}`;
      detailDesc.textContent = pkg.desc;
      detailTarget.textContent = display;
      detailPrice.textContent = formatRp(pkg.price);
      waPreviewText.textContent =
        `Halo min! 👋\n\n` +
        `Saya mau *Top Up ${brandTitle} Rp${pkg.name}*, ` +
        `kirim ke *${display}* ya!\n\n` +
        `Detail:\n• Produk: ${pkg.desc}\n• Harga: ${formatRp(pkg.price)}\n\n` +
        `Mohon diproses, terima kasih 🙏`;

      modalOverlay.classList.remove("hidden");
      document.body.style.overflow = "hidden";
    }

    function closeModal() {
      modalOverlay.classList.add("hidden");
      document.body.style.overflow = "";
      selectedPkg = null;
    }

    // ── SEND WA ──────────────────────────────────────────────────────────────
    function sendOrder() {
      if (!selectedPkg) return;
      const raw = userInput.value.trim();
      const display = isPhoneInput
        ? `+62 ${normalizePhone(raw).slice(1)}`
        : raw;
      const msg = encodeURIComponent(
        `Halo min! 👋\n\n` +
          `Saya mau *Top Up ${brandTitle} Rp${selectedPkg.name}*, ` +
          `kirim ke *${display}* ya!\n\n` +
          `Detail:\n• Produk: ${selectedPkg.desc}\n• Harga: ${formatRp(selectedPkg.price)}\n\n` +
          `Mohon diproses, terima kasih 🙏`,
      );
      window.open(`https://wa.me/${waNumber}?text=${msg}`, "_blank");
      closeModal();
    }

    // ── BOOT ─────────────────────────────────────────────────────────────────
    initProducts();
    setMode("empty");

    const debouncedUpdate = debounce(updateUI, 120);
    userInput.addEventListener("input", debouncedUpdate, { passive: true });

    // ── INPUT SANITIZATION ───────────────────────────────────────────────────
    // Semua input nomor (HP termasuk wifidi, PLN, Maxim): hanya angka — blokir keypress & sanitasi paste
    if (isPhoneInput || isNumericInput) {
      // Blokir karakter non-angka saat mengetik
      userInput.addEventListener("keydown", (e) => {
        const allowed = [
          "Backspace",
          "Delete",
          "ArrowLeft",
          "ArrowRight",
          "ArrowUp",
          "ArrowDown",
          "Tab",
          "Enter",
          "Home",
          "End",
        ];
        if (allowed.includes(e.key)) return;
        if (!/^\d$/.test(e.key)) e.preventDefault();
      });
      // Sanitasi paste — buang semua selain angka
      userInput.addEventListener("paste", (e) => {
        e.preventDefault();
        const text =
          (e.clipboardData ?? (window as any).clipboardData)?.getData("text") ??
          "";
        const digits = text.replace(/\D/g, "");
        document.execCommand("insertText", false, digits);
      });
    }

    $("modal-close").addEventListener("click", closeModal);
    $("btn-cancel").addEventListener("click", closeModal);
    $("btn-order").addEventListener("click", sendOrder);
    modalOverlay.addEventListener("click", (e) => {
      if (e.target === modalOverlay) closeModal();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeModal();
    });
  })();
</script>

<script>
  /* ── FAB drag + collapse ── */
  (function () {
    const wrap = document.getElementById("wa-fab-wrap") as HTMLElement;
    if (!wrap) return;
    let isDragging = false,
      didDrag = false;
    let startX = 0,
      startY = 0,
      origLeft = 0,
      origTop = 0,
      collapsed = false;

    window.addEventListener(
      "scroll",
      () => {
        if (window.innerWidth <= 480) return;
        const y = window.scrollY;
        if (y > 80 && !collapsed) {
          collapsed = true;
          wrap.classList.add("collapsed");
        } else if (y <= 80 && collapsed) {
          collapsed = false;
          wrap.classList.remove("collapsed");
        }
      },
      { passive: true },
    );

    function startDrag(cx: number, cy: number) {
      isDragging = true;
      didDrag = false;
      const r = wrap.getBoundingClientRect();
      origLeft = r.left;
      origTop = r.top;
      startX = cx;
      startY = cy;
      wrap.style.right = "auto";
      wrap.style.bottom = "auto";
      wrap.style.left = origLeft + "px";
      wrap.style.top = origTop + "px";
      wrap.classList.add("dragging");
    }
    function moveDrag(cx: number, cy: number) {
      if (!isDragging) return;
      const dx = cx - startX,
        dy = cy - startY;
      if (Math.abs(dx) > 3 || Math.abs(dy) > 3) didDrag = true;
      wrap.style.left =
        Math.max(
          8,
          Math.min(window.innerWidth - wrap.offsetWidth - 8, origLeft + dx),
        ) + "px";
      wrap.style.top =
        Math.max(
          8,
          Math.min(window.innerHeight - wrap.offsetHeight - 8, origTop + dy),
        ) + "px";
    }
    function endDrag(e: Event) {
      if (!isDragging) return;
      isDragging = false;
      wrap.classList.remove("dragging");
      if (!didDrag) return;
      const r = wrap.getBoundingClientRect();
      wrap.style.left = "auto";
      wrap.style.right = "auto";
      wrap.style.top = r.top + "px";
      wrap.style.bottom = "auto";
      wrap.style[
        r.left + r.width / 2 < window.innerWidth / 2 ? "left" : "right"
      ] = "20px";
      e.preventDefault();
    }

    wrap.addEventListener("mousedown", (e) => startDrag(e.clientX, e.clientY));
    window.addEventListener("mousemove", (e) => moveDrag(e.clientX, e.clientY));
    window.addEventListener("mouseup", endDrag);
    wrap.addEventListener(
      "touchstart",
      (e) => startDrag(e.touches[0].clientX, e.touches[0].clientY),
      { passive: true },
    );
    window.addEventListener(
      "touchmove",
      (e) => moveDrag(e.touches[0].clientX, e.touches[0].clientY),
      { passive: true },
    );
    window.addEventListener("touchend", endDrag);
  })();
</script>