    const mWaText = document.getElementById("m-wa-text") as HTMLDivElement;
    const modalDot = document.getElementById(
      "modal-provider-dot",
    ) as HTMLDivElement;

    /* ── STATE ── */
    type CatKey = "pulsa" | "data" | "ewallet" | "token" | "game";
    let activeCat: CatKey = "pulsa";
    let activeProv: string | null = null;
    let activeSubcat: string | null = null;
    let query = "";
    let selectedPkg: Pkg | null = null;
    let selectedProv: Provider | null = null;

    /* ── HELPERS ── */
    const fmt = (n: number) => "Rp " + n.toLocaleString("id-ID");
    const show = (el: HTMLElement) => el.classList.remove("hidden");
    const hide = (el: HTMLElement) => el.classList.add("hidden");

    function allStatesHide() {
      hide(stateEmpty);
      hide(stateSelProv);
      hide(stateNoRes);
      hide(prodWrap);
      // provSel TIDAK disembunyikan di sini — dikelola langsung di renderProducts
      // agar dropdown tidak flicker saat re-render
    }

    /* ── SEARCH LOCK: disable search sampai provider/layanan dipilih ── */
    function setSearchLock(locked: boolean) {
      if (locked) {
        searchInp.parentElement!.classList.add("disabled");
        searchInp.disabled = true;
        const lockHints: Record<string, string> = {
          pulsa: "Pilih provider dulu untuk mengaktifkan pencarian",
          data: "Pilih provider dulu",
          ewallet: "Pilih brand e-wallet dulu untuk mengaktifkan pencarian",
          token: "",
          game: "Pilih game dulu untuk mengaktifkan pencarian",
        };
        searchHint.textContent =
          lockHints[activeCat] ?? "Pilih dulu untuk mengaktifkan pencarian";
        searchHint.classList.add("search-hint--locked");
      } else {
        searchInp.parentElement!.classList.remove("disabled");
        searchInp.disabled = false;
        if (!query) {
          searchHint.textContent = "";
          searchHint.classList.remove("search-hint--locked");
        }
      }
    }

    function getProviders(): Provider[] {
      return (cfg[activeCat] as Provider[]) ?? [];
    }

    // Token PLN = tampil langsung tanpa pilih provider
    function isDirectShow(): boolean {
      return activeCat === "token";
    }

    // Pulsa, paket data, e-wallet, game = perlu pilih provider/layanan dulu
    function needsProviderSelect(): boolean {
      return (
        activeCat === "pulsa" ||
        activeCat === "data" ||
        activeCat === "ewallet" ||
        activeCat === "game"
      );
    }

    function catLabel(): string {
      const labels: Record<CatKey, string> = {
        pulsa: "operator",
        data: "operator",
        ewallet: "layanan",
        token: "-",
        game: "game",
      };
      return labels[activeCat];
    }

    /* ── RENDER PROVIDERS (custom dropdown) ── */
    function renderProviders() {
      const provs = getProviders();
      const selected = provs.find((p) => p.name === activeProv);
      ddValue.textContent = selected ? selected.title : "Pilih...";
      ddContainer.classList.toggle("selected", !!activeProv);
      ddMenu.innerHTML = provs
        .map((p) => {
          const isActive = p.name === activeProv;
          return `<div class="dd-option${isActive ? " active" : ""}" data-prov="${p.name}">
          <span>${p.title}</span>
          <svg class="dd-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
        </div>`;
        })
        .join("");
    }

    /* ── TOGGLE DROPDOWN ── */
    function openDropdown() {
      ddContainer.classList.add("open");
      ddContainer.setAttribute("aria-expanded", "true");
    }
    function closeDropdown() {
      ddContainer.classList.remove("open");
      ddContainer.setAttribute("aria-expanded", "false");
    }
    function toggleDropdown() {
      ddContainer.classList.contains("open") ? closeDropdown() : openDropdown();
    }

    /* ── BUILD PRODUCT CARD HTML ── */
    function buildCard(pkg: Pkg, delay: number): string {
      return `
        <button class="nominal-btn" data-code="${pkg.code}" style="animation-delay:${delay}ms">
          <div class="nominal-btn__top">
            <span class="nominal-btn__code">${pkg.code}</span>
          </div>
          <div class="nominal-btn__value">${pkg.name}</div>
          <div class="nominal-btn__desc">${pkg.desc}</div>
          <div class="nominal-btn__footer">
            <div>
              <div class="nominal-btn__price-label">Harga</div>
              <div class="nominal-btn__price">${fmt(pkg.price)}</div>
            </div>
            <div class="nominal-btn__cta">›</div>
          </div>
        </button>`;
    }

    /* ── RENDER PRODUCTS ── */
    function renderProducts() {
      allStatesHide(); // hides all state panels and prodWrap
      const provs = getProviders();

      /* ══ PATH 1: Token PLN — tampil langsung tanpa provider selector ══ */
      if (isDirectShow()) {
        hide(provSel);
        setSearchLock(false);
        if (!provs.length) {
          show(stateEmpty);
          return;
        }
        let filtered: Array<{ prov: Provider; pkg: Pkg }> = [];
        for (const prov of provs) {
          for (const pkg of prov.packages ?? []) {
            if (!query || matchQuery(pkg, prov.title))
              filtered.push({ prov, pkg });
          }
        }
        if (!filtered.length) {
          stateNoResDesc.textContent = `Tidak ada hasil untuk "${query}"`;
          show(stateNoRes);
          return;
        }
        show(prodWrap);
        // Logo PLN pakai gambar
        const plnLogoUrl = providerLogos["plntoken"];
        phLogo.innerHTML = "";
        if (plnLogoUrl) {
          phLogo.style.cssText =
            "background:transparent;border:none;border-radius:0";
          const img = document.createElement("img");
          img.src = plnLogoUrl;
          img.alt = "PLN";
          img.onerror = () => {
            phLogo.innerHTML = "";
            phLogo.textContent = "PLN";
            phLogo.style.cssText =
              "background:linear-gradient(135deg,#1e8c4a,#166038);border-radius:14px;border:none";
          };
          phLogo.appendChild(img);
        } else {
          phLogo.textContent = "PLN";
          phLogo.style.cssText =
            "background:linear-gradient(135deg,#1e8c4a,#166038);border-radius:14px;border:none";
        }
        phTitle.textContent = "Token Listrik PLN";
        phCount.textContent = `${filtered.length} produk`;
        let html = '<div class="nominals-grid">';
        filtered.forEach((item, i) => {
          html += buildCard(item.pkg, i * 30);
        });
        html += "</div>";
        prodGrid.innerHTML = html;
        return;
      }

      /* ══ PATH 2: Pulsa, Paket Data, E-Wallet, Game — perlu pilih provider ══ */
      const catDropdownLabels: Record<string, string> = {
        pulsa: "Provider",
        data: "Provider",
        ewallet: "Brand",
        game: "Game",
        token: "",
      };
      const catStateTitles: Record<string, string> = {
        pulsa: "Pilih provider",
        data: "Pilih provider",
        ewallet: "Pilih brand e-wallet",
        game: "Pilih game",
        token: "",
      };
      show(provSel);
      provLabel.textContent = catDropdownLabels[activeCat] ?? "Pilih";
      stateSelProvTitle.textContent = catStateTitles[activeCat] ?? "Pilih";
      renderProviders();

      // Lock search sampai provider dipilih
      if (!activeProv) {
        setSearchLock(true);
        show(stateSelProv);
        return;
      }
      setSearchLock(false);

      const prov = provs.find((p) => p.name === activeProv);
      if (!prov) {
        show(stateSelProv);
        return;
      }

      show(prodWrap);
      // Logo provider pakai gambar (sama seperti page paket data)
      const logoUrl = providerLogos[prov.name];
      phLogo.innerHTML = "";
      if (logoUrl) {
        phLogo.style.cssText =
          "background:transparent;border:none;border-radius:0";
        const img = document.createElement("img");
        img.src = logoUrl;
        img.alt = prov.title;
        img.onerror = () => {
          phLogo.innerHTML = "";
          phLogo.textContent =
            providerInitials[prov.name] ?? prov.title.slice(0, 2).toUpperCase();
          phLogo.style.cssText = `background:${providerColors[prov.name] ?? "linear-gradient(135deg,#0a0a0a,#333)"};border-radius:14px;border:none`;
        };
        phLogo.appendChild(img);
      } else {
        phLogo.textContent =
          providerInitials[prov.name] ?? prov.title.slice(0, 2).toUpperCase();
        phLogo.style.cssText = `background:${providerColors[prov.name] ?? "linear-gradient(135deg,#0a0a0a,#333)"};border-radius:14px;border:none`;
      }
      phTitle.textContent = prov.title;

      if (activeCat === "data" && prov.subCategories?.length) {
        // Paket data: tampilkan semua sub-kategori sekaligus, masing-masing dengan header
        let totalPkgs = 0;
        let html = "";
        let delay = 0;
        for (const sc of prov.subCategories) {
          const pkgs = query
            ? sc.packages.filter((p) => matchQuery(p, prov.title))
            : sc.packages;
          if (!pkgs.length) continue;
          totalPkgs += pkgs.length;
          html += `<div class="subcategory-header">
            <span class="subcategory-title">${sc.title}</span>
            <div class="subcategory-line"></div>
          </div>`;
          html += '<div class="nominals-grid">';
          pkgs.forEach((pkg) => {
            html += buildCard(pkg, delay);
            delay += 20;
          });
          html += "</div>";
        }
        if (!totalPkgs) {
          hide(prodWrap);
          stateNoResDesc.textContent = `Tidak ada hasil untuk "${query}"`;
          show(stateNoRes);
          return;
        }
        phCount.textContent = `${totalPkgs} produk tersedia`;
        prodGrid.innerHTML = html;
      } else {
        // Kategori lain: flat list
        const packages = prov.packages ?? [];
        const filtered = query
          ? packages.filter((p) => matchQuery(p, prov.title))
          : packages;
        if (!filtered.length) {
          hide(prodWrap);
          stateNoResDesc.textContent = query
            ? `Tidak ada hasil untuk "${query}" di ${prov.title}`
            : `Belum ada produk untuk ${prov.title}`;
          show(stateNoRes);
          return;
        }
        phCount.textContent = `${filtered.length} produk tersedia`;
        let html = '<div class="nominals-grid">';
        filtered.forEach((pkg, i) => {
          html += buildCard(pkg, i * 30);
        });
        html += "</div>";
        prodGrid.innerHTML = html;
      }
    }

    function matchQuery(pkg: Pkg, provTitle: string): boolean {
      const q = query.toLowerCase();
      return (
        pkg.name.toLowerCase().includes(q) ||
        pkg.desc.toLowerCase().includes(q) ||
        pkg.code.toLowerCase().includes(q) ||
        String(pkg.price).includes(q) ||
        provTitle.toLowerCase().includes(q)
      );
    }

    /* ── MINI MODAL ── */
    function openModal(pkg: Pkg, prov: Provider) {
      selectedPkg = pkg;
      selectedProv = prov;

      mNominal.textContent = pkg.name;
      mProduct.textContent = pkg.desc;
      mCode.textContent = pkg.code;
      mPrice.textContent = fmt(pkg.price);
      modalDot.style.background = colorMap[prov.name] ?? "#0a0a0a";

      // Arahkan tombol "Lihat & Order" ke halaman order (pakai # sementara)
      btnOrder.setAttribute("href", "#");

      show(modalOverlay);
      document.body.style.overflow = "hidden";
    }

    function closeModal() {
      hide(modalOverlay);
      document.body.style.overflow = "";
      selectedPkg = null;
      selectedProv = null;
    }

    /* sendOrder tidak lagi digunakan — navigasi ditangani langsung oleh <a href> */

    /* ── EVENT DELEGATION: products grid ── */
    prodGrid.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(
        ".nominal-btn",
      );
      if (!btn) return;
      const code = btn.dataset.code!;
      const provs = getProviders();
      let foundPkg: Pkg | null = null;
      let foundProv: Provider | null = null;

      for (const prov of provs) {
        if (prov.packages) {
          const p = prov.packages.find((pk) => pk.code === code);
          if (p) {
            foundPkg = p;
            foundProv = prov;
            break;
          }
        }
        if (prov.subCategories) {
          for (const sc of prov.subCategories) {
            const p = sc.packages.find((pk) => pk.code === code);
            if (p) {
              foundPkg = p;
              foundProv = prov;
              break;
            }
          }
          if (foundPkg) break;
        }
      }
      if (foundPkg && foundProv) openModal(foundPkg, foundProv);
    });

    /* ── EVENT: category tabs ── */
    catBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        catBtns.forEach((b) => {
          b.classList.remove("active");
          b.setAttribute("aria-selected", "false");
        });
        btn.classList.add("active");
        btn.setAttribute("aria-selected", "true");
        activeCat = btn.dataset.cat as CatKey;
        activeProv = null;
        activeSubcat = null;
        query = "";
        searchInp.value = "";
        hide(searchClear);
        searchHint.textContent = "";
        if (ddContainer.classList.contains("open")) {
          closeDropdown();
          // Tunggu animasi close (14ms) sebelum re-render agar tidak glitch
          setTimeout(() => renderProducts(), 15);
        } else {
          renderProducts();
        }
      });
    });

    /* ── EVENT: custom dropdown ── */
    ddTrigger.addEventListener("click", (e) => {
      e.stopPropagation();
      toggleDropdown();
    });

    ddMenu.addEventListener("click", (e) => {
      const opt = (e.target as HTMLElement).closest<HTMLDivElement>(
        ".dd-option",
      );
      if (!opt) return;
      activeProv = opt.dataset.prov!;
      activeSubcat = null;
      // Tutup dulu, baru render setelah animasi close selesai (14ms)
      closeDropdown();
      requestAnimationFrame(() => renderProducts());
    });

    // Tutup dropdown jika klik di luar
    document.addEventListener("click", (e) => {
      if (!ddContainer.contains(e.target as Node)) closeDropdown();
    });

    /* ── EVENT: search ── */
    searchInp.addEventListener("input", () => {
      query = searchInp.value.trim();
      if (query) {
        show(searchClear);
        searchHint.textContent = `Mencari "${query}"...`;
      } else {
        hide(searchClear);
        searchHint.textContent = "";
      }
      renderProducts();
    });

    searchClear.addEventListener("click", () => {
      searchInp.value = "";
      query = "";
      hide(searchClear);
      searchHint.textContent = "";
      renderProducts();
      searchInp.focus();
    });

    /* ── EVENT: modal ── */
    modalClose.addEventListener("click", closeModal);
    btnCancel.addEventListener("click", closeModal);
    // btnOrder adalah <a> — navigasi terjadi secara natural; tutup modal setelahnya
    btnOrder.addEventListener("click", () => {
      setTimeout(closeModal, 120);
    });
    modalOverlay.addEventListener("click", (e) => {
      if (e.target === modalOverlay) closeModal();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeModal();
    });

    /* ── INIT: baca ?tab= dari URL dan aktifkan tab yang sesuai ── */
    (function () {
      const params = new URLSearchParams(window.location.search);
      const tabParam = params.get("tab");
      const validTabs = ["pulsa", "data", "ewallet", "token", "game"];
      if (tabParam && validTabs.includes(tabParam)) {
        const targetBtn = Array.from(catBtns).find(
          (b) => b.dataset.cat === tabParam,
        );
        if (targetBtn && !targetBtn.classList.contains("active")) {
          catBtns.forEach((b) => {
            b.classList.remove("active");
            b.setAttribute("aria-selected", "false");
          });
          targetBtn.classList.add("active");
          targetBtn.setAttribute("aria-selected", "true");
          activeCat = tabParam as CatKey;
          activeProv = null;
          activeSubcat = null;
        }
      }
    })();

    renderProducts();

    /* ── FLOATING WA BUTTON: collapse on scroll ── */
    const wrapEl = document.getElementById("wa-fab-wrap") as HTMLElement;
    let collapsed = false;
    window.addEventListener(
      "scroll",
      () => {
        if (window.innerWidth <= 480) return;
        const y = window.scrollY;
        if (y > 80 && !collapsed) {
          collapsed = true;
          wrapEl.classList.add("collapsed");
        } else if (y <= 80 && collapsed) {
          collapsed = false;
          wrapEl.classList.remove("collapsed");
        }
      },
      { passive: true },
    );
  })();
</script>
