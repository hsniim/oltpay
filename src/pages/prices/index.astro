---
import Navbar from "../../components/Navbar.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  pulsaProviders,
  paketDataInjectProviders,
  topupProducts,
  gameProducts,
} from "../../data/products.js";

const waNumber = "6289501450667";

// Pisahkan topupProducts menjadi e-wallet dan token PLN berdasarkan name
// E-wallet: gopay, ovo, spay, dana, linkaja, gojekdriv, grabdriv, maximdriv
// Token: plntoken
// E-wallet murni: gopay, ovo, spay, dana, linkaja, gojekdriv, grabdriv, maximdriv
const EWALLET_NAMES = new Set([
  "gopay",
  "ovo",
  "spay",
  "dana",
  "linkaja",
  "gojekdriv",
  "grabdriv",
  "maximdriv",
]);
const TOKEN_NAMES = new Set(["plntoken"]);

const ewalletProducts = topupProducts.filter((p) => EWALLET_NAMES.has(p.name));
const tokenProducts = topupProducts.filter((p) => TOKEN_NAMES.has(p.name));

const configData = JSON.stringify({
  wa: waNumber,
  pulsa: pulsaProviders.map((p) => ({
    name: p.name,
    title: p.title,
    prefixes: p.prefixes,
    packages: p.packages,
  })),
  data: paketDataInjectProviders.map((p) => ({
    name: p.name,
    title: p.title,
    prefixes: p.prefixes,
    subCategories: p.subCategories,
  })),
  ewallet: ewalletProducts.map((p) => ({
    name: p.name,
    title: p.title,
    inputLabel: p.inputLabel ?? "Nomor / Username",
    packages: p.packages,
  })),
  token: tokenProducts.map((p) => ({
    name: p.name,
    title: p.title,
    inputLabel: p.inputLabel ?? "Nomor Meter",
    packages: p.packages,
  })),
  game: gameProducts.map((p) => ({
    name: p.name,
    title: p.title,
    inputLabel: p.inputLabel ?? "ID Game",
    packages: p.packages,
  })),
});
---

<BaseLayout
  title="Cek Harga | Oltpay"
  description="Cek harga pulsa, paket data, e-wallet, token PLN, dan voucher game."
>
  <Navbar />

  <!-- ══ SVG SYMBOLS ══ -->
  <svg
    aria-hidden="true"
    style="display:none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <symbol
      id="icon-tag"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path
        d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"
      ></path>
      <line x1="7" y1="7" x2="7.01" y2="7"></line>
    </symbol>
    <symbol
      id="icon-search"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </symbol>
    <symbol
      id="icon-close"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </symbol>
    <symbol
      id="icon-phone"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect>
      <line x1="12" y1="18" x2="12.01" y2="18"></line>
    </symbol>
    <symbol
      id="icon-clock"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"></path>
    </symbol>
    <symbol
      id="icon-alert"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="12" cy="12" r="10"></circle>
      <line x1="12" y1="8" x2="12" y2="12"></line>
      <line x1="12" y1="16" x2="12.01" y2="16"></line>
    </symbol>
    <symbol id="icon-wa" viewBox="0 0 24 24" fill="currentColor">
      <path
        d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
      ></path>
      <path
        d="M11.99 0C5.374 0 0 5.373 0 11.988c0 2.114.549 4.099 1.504 5.83L0 24l6.335-1.652A11.939 11.939 0 0 0 11.99 24C18.626 24 24 18.626 24 12.012 24 5.373 18.626 0 11.99 0zm0 21.785a9.796 9.796 0 0 1-4.994-1.365l-.357-.212-3.758.98.999-3.647-.233-.374A9.722 9.722 0 0 1 2.203 12c0-5.398 4.394-9.791 9.787-9.791 5.394 0 9.788 4.393 9.788 9.791 0 5.398-4.394 9.785-9.788 9.785z"
      ></path>
    </symbol>
  </svg>

  <div class="page-wrapper">
    <main>
      <!-- ══ HEADER SECTION ══ -->
      <section class="input-section">
        <div class="page-title-row">
          <div class="page-title-icon">
            <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true"
              ><use href="#icon-tag"></use></svg
            >
          </div>
          <div>
            <h1 class="page-title">Cek Harga</h1>
            <p class="page-subtitle">
              Pulsa, data, e-wallet, token PLN &amp; voucher game — semua ada
            </p>
          </div>
        </div>

        <!-- ══ CATEGORY TABS ══ -->
        <div
          class="cat-tab-bar"
          id="cat-tab-bar"
          role="tablist"
          aria-label="Kategori produk"
        >
          <button
            class="cat-tab-btn active"
            data-cat="pulsa"
            role="tab"
            aria-selected="true">Pulsa</button
          >
          <button
            class="cat-tab-btn"
            data-cat="data"
            role="tab"
            aria-selected="false">Paket Data</button
          >
          <button
            class="cat-tab-btn"
            data-cat="ewallet"
            role="tab"
            aria-selected="false">E-Wallet</button
          >
          <button
            class="cat-tab-btn"
            data-cat="token"
            role="tab"
            aria-selected="false">Token PLN</button
          >
          <button
            class="cat-tab-btn"
            data-cat="game"
            role="tab"
            aria-selected="false">Game</button
          >
        </div>

        <!-- ══ SEARCH BAR ══ -->
        <div class="search-wrap">
          <div class="search-input-wrap" id="search-input-wrap">
            <svg
              viewBox="0 0 24 24"
              width="16"
              height="16"
              aria-hidden="true"
              class="search-icon"><use href="#icon-search"></use></svg
            >
            <input
              type="text"
              id="search-input"
              placeholder="Cari nominal, nama paket, atau kode..."
              autocomplete="off"
              spellcheck="false"
            />
            <button
              class="search-clear hidden"
              id="search-clear"
              aria-label="Hapus pencarian"
            >
              <svg viewBox="0 0 24 24" width="12" height="12" aria-hidden="true"
                ><use href="#icon-close"></use></svg
              >
            </button>
          </div>
          <p class="search-hint" id="search-hint"></p>
        </div>
      </section>

      <!-- ══ PRODUCTS SECTION ══ -->
      <section class="products-section" id="products-section">
        <!-- Custom dropdown selector -->
        <div class="selector-row hidden" id="provider-selector">
          <p class="selector-label" id="provider-selector-label">Provider</p>
          <div
            class="cust-dropdown"
            id="provider-grid"
            role="listbox"
            aria-expanded="false"
          >
            <div class="cust-dropdown__trigger" id="dd-trigger">
              <span class="cust-dropdown__value" id="dd-value">Pilih...</span>
              <svg
                class="cust-dropdown__chevron"
                viewBox="0 0 24 24"
                width="16"
                height="16"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><polyline points="6 9 12 15 18 9"></polyline></svg
              >
            </div>
            <div class="cust-dropdown__menu" id="dd-menu"></div>
          </div>
        </div>

        <!-- Empty / loading / no-result states -->
        <div class="state-wrap" id="state-empty">
          <div class="state-icon">
            <svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true"
              ><use href="#icon-tag"></use></svg
            >
          </div>
          <p class="state-title">Pilih kategori di atas</p>
          <p class="state-desc">Harga semua produk akan ditampilkan di sini</p>
        </div>

        <div class="state-wrap hidden" id="state-select-provider">
          <div class="state-icon">
            <svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true"
              ><use href="#icon-phone"></use></svg
            >
          </div>
          <p class="state-title" id="state-select-provider-title">
            Pilih provider
          </p>
          <p class="state-desc">Tap salah satu provider untuk melihat harga</p>
        </div>

        <div class="state-wrap hidden" id="state-no-result">
          <div class="state-icon state-icon--warn">
            <svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true"
              ><use href="#icon-alert"></use></svg
            >
          </div>
          <p class="state-title">Tidak ada hasil</p>
          <p class="state-desc" id="state-no-result-desc">
            Coba kata kunci lain
          </p>
        </div>

        <!-- Products list -->
        <div class="products-wrap hidden" id="products-wrap">
          <div class="products-header">
            <div class="products-header-left">
              <div class="provider-logo" id="ph-logo"></div>
              <div>
                <h2 class="products-title" id="ph-title">—</h2>
                <p class="products-count" id="ph-count"></p>
              </div>
            </div>
          </div>
          <div id="products-grid"></div>
        </div>
      </section>
    </main>
  </div>

  <!-- ══ MINI MODAL — "Mau beli produk ini?" ══ -->
  <div class="modal-overlay hidden" id="modal-overlay">
    <div
      class="mini-modal"
      id="modal"
      role="dialog"
      aria-modal="true"
      aria-labelledby="modal-title"
    >
      <button class="mini-modal__close" id="modal-close" aria-label="Tutup">
        <svg viewBox="0 0 24 24" width="12" height="12" aria-hidden="true"
          ><use href="#icon-close"></use></svg
        >
      </button>

      <p class="mini-modal__eyebrow">Mau beli produk ini?</p>

      <div class="mini-modal__product">
        <div class="mini-modal__dot" id="modal-provider-dot"></div>
        <div class="mini-modal__info">
          <div class="mini-modal__name" id="m-nominal">—</div>
          <div class="mini-modal__desc" id="m-product">—</div>
        </div>
        <div class="mini-modal__price" id="m-price">—</div>
      </div>

      <div class="mini-modal__code-row">
        <span class="mini-modal__code-label">Kode Produk</span>
        <span class="mini-modal__code" id="m-code">—</span>
      </div>

      <div class="mini-modal__actions">
        <button class="btn-cancel" id="btn-cancel">Tutup</button>
        <a class="btn-order" id="btn-order" href="#">
          Lihat &amp; Order
          <svg
            viewBox="0 0 24 24"
            width="14"
            height="14"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Config data -->
  <script id="config" type="application/json" set:html={configData} />

  <!-- ══ FLOATING WA BUTTON ══ -->
  <div class="wa-fab-wrap" id="wa-fab-wrap">
    <a
      href={`https://wa.me/${waNumber}`}
      target="_blank"
      rel="noopener noreferrer"
      class="wa-fab"
      id="wa-fab"
      aria-label="Chat WhatsApp Admin"
    >
      <svg
        class="wa-fab__icon"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"><use href="#icon-wa"></use></svg
      >
      <span class="wa-fab__label">Butuh bantuan?</span>
    </a>
  </div>
</BaseLayout>

<style>
  /* ══ LAYOUT ══ */
  main {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 48px var(--content-px) 80px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  @media (max-width: 640px) {
    main {
      padding: 20px 12px 80px;
    }
  }

  /* ══ INPUT SECTION ══ */
  .input-section {
    background: var(--color-bg);
    border-radius: 20px;
    padding: 28px 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .page-title-row {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .page-title-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .page-title-icon svg {
    width: 24px;
    height: 24px;
    color: var(--color-text);
  }

  .page-title {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-text);
    margin: 0 0 3px;
    letter-spacing: -0.3px;
  }
  .page-subtitle {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin: 0;
  }

  /* ══ CATEGORY TABS ══ */
  .cat-tab-bar {
    display: flex;
    gap: 0;
    background: #f0f0f0;
    border-radius: 14px;
    padding: 4px;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .cat-tab-bar::-webkit-scrollbar {
    display: none;
  }

  .cat-tab-btn {
    flex: 1;
    min-width: max-content;
    height: 38px;
    padding: 0 14px;
    border: none;
    border-radius: 10px;
    background: transparent;
    font-size: 12.5px;
    font-weight: 600;
    color: var(--color-muted);
    cursor: pointer;
    white-space: nowrap;
    transition:
      background 0.18s,
      color 0.18s,
      box-shadow 0.18s;
  }
  .cat-tab-btn.active {
    background: var(--color-bg);
    color: var(--color-text);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.1);
  }

  /* ══ SEARCH ══ */
  .search-wrap {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .search-input-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
    border: 1.5px solid var(--color-border);
    border-radius: 14px;
    padding: 0 14px;
    height: 48px;
    background: var(--color-bg);
    transition: border-color 0.2s;
  }
  .search-input-wrap:focus-within {
    border-color: var(--color-text);
  }

  .search-icon {
    color: var(--color-muted);
    flex-shrink: 0;
  }

  .search-input-wrap input {
    flex: 1;
    border: none;
    outline: none;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text);
    background: transparent;
  }
  .search-input-wrap input::placeholder {
    color: #c4c4c4;
    font-weight: 400;
  }

  .search-clear {
    width: 22px;
    height: 22px;
    border: 1.5px solid var(--color-border);
    border-radius: 6px;
    background: #f0f0f0;
    color: var(--color-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.1s;
  }
  .search-clear:hover {
    background: var(--color-border);
  }

  .search-hint {
    font-size: 12px;
    color: var(--color-muted);
    margin: 0;
  }

  /* ══ PRODUCTS SECTION ══ */
  .products-section {
    background: var(--color-bg);
    border-radius: 20px;
    overflow: hidden;
    min-height: 240px;
    display: flex;
    flex-direction: column;
  }

  /* ══ CUSTOM SELECTOR ══ */
  .selector-row {
    padding: 20px 28px 0;
  }
  @media (max-width: 600px) {
    .selector-row {
      padding: 16px 16px 0;
    }
  }

  .selector-label {
    font-size: 11px;
    font-weight: 700;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin: 0 0 8px;
  }

  /* ── Custom dropdown ── */
  .cust-dropdown {
    position: relative;
    width: 100%;
    user-select: none;
  }

  .cust-dropdown__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    height: 48px;
    padding: 0 16px;
    border: none;
    border-radius: 12px;
    background: #f0f0f0;
    cursor: pointer;
    transition: background 0.15s;
  }
  .cust-dropdown__trigger:hover {
    background: #e8e8e8;
  }
  .cust-dropdown.open .cust-dropdown__trigger {
    background: #e8e8e8;
    border-radius: 12px 12px 0 0;
  }

  .cust-dropdown__value {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-muted);
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: color 0.15s;
  }
  .cust-dropdown.selected .cust-dropdown__value {
    color: var(--color-text);
  }

  .cust-dropdown__chevron {
    flex-shrink: 0;
    color: var(--color-muted);
    transition: transform 0.12s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .cust-dropdown.open .cust-dropdown__chevron {
    transform: rotate(180deg);
  }

  .cust-dropdown__menu {
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    background: #f0f0f0;
    border-radius: 0 0 12px 12px;
    overflow: hidden;
    z-index: 100;
    max-height: 0;
    overflow-y: auto;
    transition: max-height 0.14s cubic-bezier(0.4, 0, 0.2, 1);
    scrollbar-width: none;
  }
  .cust-dropdown__menu::-webkit-scrollbar {
    display: none;
  }
  .cust-dropdown.open .cust-dropdown__menu {
    max-height: 280px;
  }

  :global(.dd-option) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 11px 16px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text);
    cursor: pointer;
    transition: background 0.1s;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }
  :global(.dd-option:first-child) {
    border-top: none;
  }
  :global(.dd-option:hover) {
    background: #e4e4e4;
  }
  :global(.dd-option.active) {
    background: var(--color-text);
    color: var(--color-bg);
    font-weight: 700;
  }
  :global(.dd-option.active .dd-check) {
    opacity: 1;
  }
  :global(.dd-check) {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    opacity: 0;
  }

  /* ══ STATE WRAPPERS ══ */
  .state-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 56px 24px;
    text-align: center;
    gap: 10px;
  }
  .state-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 4px;
  }
  .state-icon svg {
    width: 26px;
    height: 26px;
    color: #000;
  }
  .state-icon--warn svg {
    color: #d97706;
  }
  .state-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }
  .state-desc {
    font-size: 13px;
    color: var(--color-muted);
    margin: 0;
    max-width: 280px;
    line-height: 1.5;
  }

  /* ══ PRODUCTS WRAP ══ */
  .products-wrap {
    width: 100%;
    padding: 24px 28px 32px;
  }

  .products-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 24px;
  }
  .products-header-left {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .provider-logo {
    width: 40px;
    height: 40px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 900;
    color: white;
    flex-shrink: 0;
    letter-spacing: -0.5px;
    overflow: hidden;
    background: transparent;
  }
  .provider-logo img {
    width: 100%;
